#!/bin/bash
# Prevent AI/Claude references in commit messages

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

BLOCKED_PATTERNS=(
  "Co-Authored-By:.*Claude"
  "Co-Authored-By:.*Anthropic"
  "Co-Authored-By:.*noreply@anthropic"
  "Generated by Claude"
  "Generated by AI"
  "Claude Code"
  "ChatGPT"
  "Copilot"
)

for pattern in "${BLOCKED_PATTERNS[@]}"; do
  if echo "$COMMIT_MSG" | grep -qiE "$pattern"; then
    echo "ERROR: Commit message contains AI reference matching: $pattern"
    echo "Remove AI/Claude references from the commit message."
    exit 1
  fi
done

exit 0
