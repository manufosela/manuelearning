---
/**
 * @typedef {Object} Props
 * @property {string} [title] - Page title
 * @property {string} [description] - Meta description
 * @property {boolean} [hideAuthButton] - Hide the login button in header
 */

import { SITE } from '../config/site.config.js';

/** @type {Props} */
const {
  title = `${SITE.name} | ${SITE.tagline}`,
  description = SITE.tagline,
  hideAuthButton = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#84cc16" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="ManuElearning" />
  <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Lexend:wght@400;500;600;700;800;900&display=swap"
    rel="stylesheet"
  />
  <link
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
    rel="stylesheet"
  />
  <title>{title}</title>
  <script is:inline>
    (function() {
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = stored || (prefersDark ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
</head>
<body>
  <div class="page-wrapper">
    <!-- Header -->
    <header class="site-header">
      <a href="/" class="site-header__brand">
        <img src="/logo.svg" alt={SITE.name} class="site-header__logo" />
      </a>
      <div class="site-header__actions">
        <button
          id="theme-toggle"
          class="theme-toggle"
          aria-label="Cambiar tema"
          type="button"
        >
          <span class="material-symbols-outlined theme-toggle__icon theme-toggle__icon--light">light_mode</span>
          <span class="material-symbols-outlined theme-toggle__icon theme-toggle__icon--dark">dark_mode</span>
        </button>
      {!hideAuthButton && (
        <div class="site-header__auth" id="header-auth">
          <a href="/login" class="btn btn--primary btn--sm" id="header-login-btn">Acceder</a>
          <div class="header-user" id="header-user" style="display:none;">
            <a href="/dashboard" class="header-user__link">
              <img id="header-user-avatar" class="header-user__avatar" src="" alt="" />
              <span id="header-user-name" class="header-user__name"></span>
            </a>
            <button id="header-logout-btn" class="header-user__logout" aria-label="Cerrar sesión">
              <span class="material-symbols-outlined">logout</span>
            </button>
          </div>
        </div>
      )}
      </div>
    </header>

    <!-- Main content -->
    <main class="site-main">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="site-footer__grid">
        <div class="site-footer__brand">
          <div class="site-footer__logo">
            <img src="/logo.svg" alt={SITE.name} height="32" />
          </div>
          <p>{SITE.tagline}</p>
          <div class="site-footer__social">
            <a href="#" aria-label="Web"><span class="material-symbols-outlined">public</span></a>
            <a href="#" aria-label="Chat"><span class="material-symbols-outlined">chat</span></a>
            <a href="#" aria-label="Email"><span class="material-symbols-outlined">mail</span></a>
          </div>
        </div>
        <div class="site-footer__links">
          <h4>Cursos</h4>
          <ul>
            <li><a href="/curso?c=docker">Docker</a></li>
            <li><a href="/curso?c=javascript">JavaScript</a></li>
            <li><a href="/cursos">Ver todos</a></li>
          </ul>
        </div>
        <div class="site-footer__links">
          <h4>Recursos</h4>
          <ul>
            <li><a href="#">GitHub del curso</a></li>
            <li><a href="#">Blog</a></li>
            <li><a href="/sobre-manu">Sobre Mánu</a></li>
          </ul>
        </div>
        <div class="site-footer__links">
          <h4>Contacto</h4>
          <ul>
            <li><span class="material-symbols-outlined">location_on</span> Madrid, España</li>
            <li><span class="material-symbols-outlined">mail</span> {SITE.contactEmail}</li>
          </ul>
        </div>
      </div>
      <div class="site-footer__bottom">
        <p>&copy; {SITE.copyrightYear} {SITE.name}. Todos los derechos reservados.</p>
        <div class="site-footer__legal">
          <a href="/privacidad">Política de Privacidad</a>
          <a href="/terminos">Términos de Servicio</a>
          <a href="/cookies">Política de Cookies</a>
        </div>
      </div>
    </footer>
  </div>
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/service-worker.js');
      });
    }
  </script>
  <script>
    const themeToggle = document.getElementById('theme-toggle');
    if (themeToggle) {
      themeToggle.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });
    }
  </script>
  <script>
    import { onAuthChange, logoutUser } from '../lib/firebase/auth.js';

    const loginBtn = document.getElementById('header-login-btn');
    const userBlock = document.getElementById('header-user');
    const userAvatar = document.getElementById('header-user-avatar');
    const userName = document.getElementById('header-user-name');
    const logoutBtn = document.getElementById('header-logout-btn');

    if (loginBtn && userBlock) {
      onAuthChange((user) => {
        if (user) {
          loginBtn.style.display = 'none';
          userBlock.style.display = 'flex';
          userName.textContent = user.displayName || user.email;
          if (user.photoURL) {
            userAvatar.src = user.photoURL;
            userAvatar.alt = user.displayName || '';
            userAvatar.style.display = 'block';
          } else {
            userAvatar.style.display = 'none';
          }
        } else {
          loginBtn.style.display = '';
          userBlock.style.display = 'none';
        }
      });

      logoutBtn?.addEventListener('click', async () => {
        await logoutUser();
        window.location.href = '/';
      });
    }
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  /* --- Page wrapper --- */
  .page-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* --- Header --- */
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    white-space: nowrap;
    border-bottom: 1px solid var(--color-border);
    padding: 1rem var(--section-px);
    background-color: var(--color-bg-white);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .site-header__brand {
    display: flex;
    align-items: center;
  }

  .site-header__logo {
    height: 2rem;
    width: auto;
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    transition: color var(--transition-fast), background-color var(--transition-fast);
  }

  .theme-toggle:hover {
    color: var(--color-text-primary);
    background-color: var(--color-primary-light);
  }

  .theme-toggle__icon {
    font-size: 1.25rem;
  }

  /* Show sun icon in dark mode, moon icon in light mode */
  .theme-toggle__icon--light {
    display: none;
  }
  .theme-toggle__icon--dark {
    display: block;
  }
  [data-theme="dark"] .theme-toggle__icon--light {
    display: block;
  }
  [data-theme="dark"] .theme-toggle__icon--dark {
    display: none;
  }

  .site-header__auth {
    display: flex;
    align-items: center;
  }

  .header-user {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .header-user__link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-text-primary);
  }

  .header-user__avatar {
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-full);
    object-fit: cover;
  }

  .header-user__logout {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    padding: 0.25rem;
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast);
  }

  .header-user__logout:hover {
    color: #991b1b;
  }

  .header-user__logout .material-symbols-outlined {
    font-size: 1.25rem;
  }

  .header-user__name {
    display: none;
    font-size: 0.875rem;
    font-weight: 600;
    max-width: 150px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (min-width: 768px) {
    .header-user__name {
      display: inline;
    }
  }

  /* --- Main --- */
  .site-main {
    flex: 1;
  }

  /* --- Footer --- */
  .site-footer {
    background-color: var(--color-bg-slate-950);
    color: var(--color-text-on-dark);
    padding: 5rem var(--section-px) 3rem;
  }

  .site-footer__grid {
    max-width: var(--container-max);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
  }

  @media (min-width: 768px) {
    .site-footer__grid {
      grid-template-columns: 1fr 1fr 1fr 1fr;
    }
  }

  .site-footer__brand p {
    font-size: 0.875rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .site-footer__logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-white);
    margin-bottom: 1.5rem;
  }

  .site-footer__logo span {
    font-size: 1.5rem;
  }

  .site-footer__logo h2 {
    font-size: 1.125rem;
    font-weight: 900;
    letter-spacing: -0.02em;
  }

  .site-footer__social {
    display: flex;
    gap: 1rem;
  }

  .site-footer__social a {
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-full);
    background-color: #1e293b;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-white);
    transition: background-color var(--transition-base);
  }

  .site-footer__social a:hover {
    background-color: var(--color-primary);
  }

  .site-footer__social a span {
    font-size: 1.125rem;
  }

  .site-footer__links h4 {
    color: var(--color-text-white);
    font-weight: 700;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
  }

  .site-footer__links ul {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    font-size: 0.875rem;
  }

  .site-footer__links li {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .site-footer__links li span {
    font-size: 0.875rem;
  }

  .site-footer__links a:hover {
    color: var(--color-text-white);
    transition: color var(--transition-fast);
  }

  .site-footer__bottom {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border-dark);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    font-size: 0.75rem;
  }

  @media (min-width: 768px) {
    .site-footer__bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .site-footer__legal {
    display: flex;
    gap: 1.5rem;
  }

  .site-footer__legal a:hover {
    color: var(--color-text-white);
    transition: color var(--transition-fast);
  }
</style>
