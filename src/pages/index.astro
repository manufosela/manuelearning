---
import MainLayout from '../layouts/MainLayout.astro';
import { SITE } from '../config/site.config.js';
---

<MainLayout>
  <!-- Hero Section -->
  <section class="hero-wrapper">
    <div class="hero" style="background-image: linear-gradient(to right, #0f172a 0%, #1a2e05 100%), url('/images/hero-background.jpg');">
      <div class="hero__content">
        <div class="hero__badge">
          <span class="material-symbols-outlined">verified</span>
          <span>Formación directa, práctica y sin filtros</span>
        </div>
        <h1 class="hero__title">
          Aprende tecnología de verdad.
          <br /><span class="hero__title--accent">Sin rodeos.</span>
        </h1>
        <p class="hero__description">
          Plataforma de formación online de Mánu Fosela — cursos prácticos de desarrollo web, Docker y más, para quien quiera aprender con quien ya lo ha vivido.
        </p>
        <div class="hero__actions">
          <a href="#services" class="btn btn--primary btn--lg hero__btn-white">Ver cursos disponibles</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="services" id="services">
    <div class="services__header">
      <h2 class="section-label">Cursos</h2>
      <h3 class="section-title">¿Qué cursos ofrezco?</h3>
      <div class="section-divider"></div>
    </div>
    <div class="services__grid">
      <article class="service-card">
        <div class="service-card__icon">
          <span class="material-symbols-outlined">deployed_code</span>
        </div>
        <h4 class="service-card__title">Docker desde cero</h4>
        <p class="service-card__text">Contenedores, imágenes, volúmenes, redes y docker-compose. Del "funciona en mi máquina" al despliegue real.</p>
      </article>
      <article class="service-card">
        <div class="service-card__icon">
          <span class="material-symbols-outlined">code</span>
        </div>
        <h4 class="service-card__title">JavaScript moderno</h4>
        <p class="service-card__text">Fundamentos sólidos, DOM, fetch, promesas y patrones reales. El JS que se usa, no el de los libros.</p>
      </article>
      <article class="service-card">
        <div class="service-card__icon">
          <span class="material-symbols-outlined">directions_car</span>
        </div>
        <h4 class="service-card__title">Aprende a conducir</h4>
        <p class="service-card__text">Teoría, señales, maniobras y test de práctica. Todo lo que necesitas para sacarte el carné.</p>
      </article>
    </div>
  </section>

  <!-- Why Lean Section -->
  <section class="why-lean" id="why-lean">
    <div class="why-lean__grid">
      <div class="why-lean__image-wrapper">
        <div class="why-lean__image">
          <img src="/images/engineer-tablet.jpg" alt="Profesional de construcción revisando planos digitales en una tablet" />
        </div>
        <div class="why-lean__stats">
          <div class="why-lean__stat">
            <p class="why-lean__stat-number">+25</p>
            <p class="why-lean__stat-label">desarrollando software</p>
          </div>
          <div class="why-lean__stat">
            <p class="why-lean__stat-number">+15</p>
            <p class="why-lean__stat-label">mentorizando juniors</p>
          </div>
          <div class="why-lean__stat">
            <p class="why-lean__stat-number">+10</p>
            <p class="why-lean__stat-label">liderando equipos</p>
          </div>
        </div>
      </div>
      <div class="why-lean__content">
        <h2 class="section-label">¿Para quién es esto?</h2>
        <h3 class="why-lean__title">Para quien quiere aprender con alguien de verdad</h3>
        <p class="why-lean__description">
          Esta plataforma no es un marketplace ni una academia masiva. Es un espacio de formación personal donde comparto lo que sé con personas a las que conozco o que me conocen. Si estás empezando en el mundo del desarrollo, si quieres entender Docker de una vez, o si buscas algo más cercano que un tutorial de YouTube — puede que estés en el sitio correcto.
        </p>
        <ul class="why-lean__features">
          <li>
            <span class="material-symbols-outlined">check_circle</span>
            <span>Acceso solo por invitación — aprendes con contexto y sin ruido</span>
          </li>
          <li>
            <span class="material-symbols-outlined">check_circle</span>
            <span>Cursos basados en proyectos reales, no en ejemplos de juguete</span>
          </li>
          <li>
            <span class="material-symbols-outlined">check_circle</span>
            <span>Soporte directo — puedes preguntarme a mí</span>
          </li>
        </ul>
        <a href="/solicitar-acceso" class="btn btn--primary btn--md">Solicitar acceso</a>
      </div>
    </div>
  </section>

</MainLayout>

<style>
  /* --- Hero --- */
  .hero-wrapper {
    padding: 2rem var(--section-px);
  }

  .hero {
    position: relative;
    min-height: 560px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    overflow: hidden;
    border-radius: var(--radius-xl);
    padding: 2rem;
    background-size: cover;
    background-position: center;
  }

  @media (min-width: 768px) {
    .hero {
      padding: 2rem 4rem;
    }
  }

  .hero__content {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    background: linear-gradient(to right, rgba(132, 204, 22, 0.15), rgba(251, 146, 60, 0.15));
    color: var(--color-primary);
    border: 1px solid rgba(132, 204, 22, 0.3);
    width: fit-content;
  }

  .hero__badge span.material-symbols-outlined {
    font-size: 0.875rem;
  }

  .hero__badge span:last-child {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .hero__title {
    font-size: clamp(2.5rem, 6vw, 3.75rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.02em;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__title--accent {
    opacity: 0.85;
  }

  .hero__description {
    color: #f1f5f9;
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 400;
    line-height: 1.6;
    opacity: 0.9;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 1rem;
  }

  .hero__btn-white {
    background: var(--gradient-primary);
    color: #0f172a;
    box-shadow: var(--shadow-lg);
  }

  .hero__btn-white:hover {
    transform: scale(1.05);
    filter: brightness(1.1);
  }

  /* --- Services --- */
  .services {
    padding: var(--section-py) var(--section-px);
    background-color: var(--color-bg-white);
  }

  .services__header {
    max-width: var(--container-max);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 4rem;
    text-align: center;
    align-items: center;
  }

  .services__grid {
    max-width: var(--container-max);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .services__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .service-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    border-radius: var(--radius-xl);
    border: 2px solid var(--color-border);
    background-color: var(--color-bg-white);
    padding: 2rem;
    transition: all var(--transition-base);
  }

  .service-card:hover {
    box-shadow: var(--shadow-2xl);
    border-color: var(--color-primary);
  }

  .service-card__icon {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: var(--radius-md);
    background-color: rgba(34, 211, 238, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-secondary);
    transition: all var(--transition-base);
  }

  .service-card:hover .service-card__icon {
    background-color: var(--color-secondary);
    color: #0f172a;
  }

  .service-card__icon span {
    font-size: 1.875rem;
  }

  .service-card__title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .service-card__text {
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  /* --- Why Lean --- */
  .why-lean {
    padding: 6rem var(--section-px);
    background-color: var(--color-bg-slate-50);
    color: var(--color-text-primary);
  }

  .why-lean__grid {
    max-width: var(--container-max);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .why-lean__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .why-lean__image-wrapper {
    position: relative;
  }

  .why-lean__image {
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    box-shadow: var(--shadow-2xl);
  }

  .why-lean__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .why-lean__stats {
    display: none;
    position: absolute;
    bottom: -1.5rem;
    right: -1.5rem;
    gap: 0.75rem;
  }

  @media (min-width: 768px) {
    .why-lean__stats {
      display: flex;
    }
  }

  .why-lean__stat {
    background: var(--gradient-primary);
    color: #0f172a;
    padding: 1rem 1.25rem;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl);
    text-align: center;
    min-width: 5.5rem;
  }

  .why-lean__stat-number {
    font-size: 1.75rem;
    font-weight: 900;
    line-height: 1;
  }

  .why-lean__stat-label {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0.25rem;
  }

  .why-lean__content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .why-lean__title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    line-height: 1.15;
    color: var(--color-text-primary);
  }

  .why-lean__description {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .why-lean__features {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .why-lean__features li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .why-lean__features li span.material-symbols-outlined {
    color: var(--color-primary);
    flex-shrink: 0;
  }

</style>
