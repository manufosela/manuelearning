---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="404 | Página no encontrada">
  <section class="error-page">
    <div class="error-page__content">
      <span class="material-symbols-outlined error-page__icon">explore_off</span>
      <p class="error-page__code">404</p>
      <h1 class="error-page__title">Página no encontrada</h1>
      <p class="error-page__subtitle">
        La página que buscas no existe o ha sido movida.
      </p>
      <div class="error-page__actions">
        <a href="/" class="btn btn--primary btn--md">Ir al inicio</a>
        <a href="/dashboard" class="btn btn--secondary btn--md">Ir al dashboard</a>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .error-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 200px);
    padding: 2rem var(--section-px);
    text-align: center;
  }

  .error-page__content {
    max-width: 480px;
  }

  .error-page__icon {
    font-size: 4rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .error-page__code {
    font-family: var(--font-display);
    font-size: clamp(5rem, 15vw, 8rem);
    font-weight: 900;
    line-height: 1;
    color: var(--color-primary);
    letter-spacing: -0.04em;
  }

  .error-page__title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-top: 0.5rem;
  }

  .error-page__subtitle {
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin-top: 0.75rem;
    line-height: 1.6;
  }

  .error-page__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 2rem;
    flex-wrap: wrap;
  }
</style>
