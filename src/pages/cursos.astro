---
import MainLayout from '../layouts/MainLayout.astro';
import { SITE } from '../config/site.config.js';

const courses = [
  {
    id: 'docker',
    title: 'Docker desde cero',
    description: 'Aprende Docker y docker-compose creando una aplicación fullstack con Node, MongoDB y Nginx.',
    icon: 'deployed_code',
    modules: 4,
    color: '#0db7ed',
  },
  {
    id: 'javascript',
    title: 'JavaScript Moderno',
    description: 'Domina JavaScript: desde los fundamentos hasta patrones avanzados, asincronía, módulos y testing.',
    icon: 'code',
    modules: 14,
    color: '#f7df1e',
  },
];
---

<MainLayout title={`Cursos | ${SITE.name}`}>
  <section class="courses-page">
    <div class="courses-header">
      <h1>Cursos disponibles</h1>
      <p>Elige un curso y empieza a aprender a tu ritmo</p>
    </div>

    <div class="courses-grid">
      {courses.map((course) => (
        <a href={`/curso?c=${course.id}`} class="course-card">
          <div class="course-card__icon" style={`background-color: ${course.color}20; color: ${course.color};`}>
            <span class="material-symbols-outlined">{course.icon}</span>
          </div>
          <h2 class="course-card__title">{course.title}</h2>
          <p class="course-card__desc">{course.description}</p>
          <div class="course-card__meta">
            <span class="material-symbols-outlined">school</span>
            {course.modules} módulos
          </div>
          <div class="course-card__cta">
            Ver temario
            <span class="material-symbols-outlined">arrow_forward</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</MainLayout>

<style>
  .courses-page {
    padding: 3rem var(--section-px);
    max-width: 900px;
    margin: 0 auto;
  }

  .courses-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .courses-header h1 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 900;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }

  .courses-header p {
    color: var(--color-text-secondary);
    font-size: 1.125rem;
  }

  .courses-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .course-card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    border-radius: var(--radius-xl, 1rem);
    border: 1px solid var(--color-border);
    background: var(--color-bg-white);
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
    color: inherit;
  }

  .course-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  .course-card__icon {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .course-card__icon .material-symbols-outlined {
    font-size: 1.75rem;
  }

  .course-card__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }

  .course-card__desc {
    color: var(--color-text-secondary);
    font-size: 0.938rem;
    line-height: 1.6;
    flex: 1;
    margin-bottom: 1rem;
  }

  .course-card__meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.813rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .course-card__meta .material-symbols-outlined {
    font-size: 1rem;
  }

  .course-card__cta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-weight: 600;
    font-size: 0.938rem;
    color: var(--color-primary);
  }

  .course-card__cta .material-symbols-outlined {
    font-size: 1.125rem;
    transition: transform 0.2s;
  }

  .course-card:hover .course-card__cta .material-symbols-outlined {
    transform: translateX(4px);
  }
</style>
