---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Preguntas | Admin">
  <div class="admin-questions">
    <div class="admin-questions__header">
      <h1>Gestión de preguntas</h1>
      <p>Revisa y responde las preguntas de los estudiantes</p>
    </div>
    <admin-questions-list></admin-questions-list>
  </div>
</AdminLayout>

<script>
  import '../../components/admin-questions-list.js';
</script>

<style>
  .admin-questions__header {
    margin-bottom: 2rem;
  }

  .admin-questions__header h1 {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--color-text-primary);
    margin-bottom: 0.25rem;
  }

  .admin-questions__header p {
    color: var(--color-text-secondary);
    font-size: 0.938rem;
  }
</style>
