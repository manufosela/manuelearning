---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Módulos | Admin">
  <div class="admin-modules">
    <div class="admin-modules__header">
      <h1>Gestión de módulos y clases</h1>
      <p>Organiza el contenido del curso en módulos con clases</p>
    </div>
    <admin-modules-list></admin-modules-list>
  </div>
</AdminLayout>

<script>
  import '../../components/admin-modules-list.js';
</script>

<style>
  .admin-modules__header {
    margin-bottom: 2rem;
  }

  .admin-modules__header h1 {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--color-text-primary);
    margin-bottom: 0.25rem;
  }

  .admin-modules__header p {
    color: var(--color-text-secondary);
    font-size: 0.938rem;
  }
</style>
