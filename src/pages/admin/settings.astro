---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Configuración | Admin">
  <div class="admin-settings">
    <div class="admin-settings__header">
      <h1>Configuración del sitio</h1>
      <p>Gestiona la configuración general de la plataforma</p>
    </div>
    <registration-toggle></registration-toggle>
  </div>
</AdminLayout>

<script>
  import '../../components/registration-toggle.js';
</script>

<style>
  .admin-settings__header {
    margin-bottom: 2rem;
  }

  .admin-settings__header h1 {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--color-text-primary);
    margin-bottom: 0.25rem;
  }

  .admin-settings__header p {
    color: var(--color-text-secondary);
    font-size: 0.938rem;
  }
</style>
