---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Sesiones | Admin">
  <div class="admin-sessions">
    <div class="admin-sessions__header">
      <h1>Gestión de sesiones síncronas</h1>
      <p>Programa y administra las sesiones en vivo por Zoom</p>
    </div>
    <admin-sessions-list></admin-sessions-list>
  </div>
</AdminLayout>

<script>
  import '../../components/admin-sessions-list.js';
</script>

<style>
  .admin-sessions__header {
    margin-bottom: 2rem;
  }

  .admin-sessions__header h1 {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--color-text-primary);
    margin-bottom: 0.25rem;
  }

  .admin-sessions__header p {
    color: var(--color-text-secondary);
    font-size: 0.938rem;
  }
</style>
