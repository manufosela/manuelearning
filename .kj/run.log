01:20:29.694 [agent:output] [coder] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MX4eNGCLRjh8kFULeLvo3n","type":"tool_result","content":"     1→import {\n     2→  collection,\n     3→  doc,\n     4→  getDoc,\n     5→  getDocs,\n     6→  addDoc,\n     7→  updateDoc,\n     8→  deleteDoc,\n     9→  query,\n    10→  where,\n    11→  orderBy,\n    12→  serverTimestamp,\n    13→} from 'firebase/firestore';\n    14→import { db } from './config.js';\n    15→\n    16→const QUIZZES = 'quizzes';\n    17→const RESPONSES = 'quizResponses';\n    18→\n    19→/**\n    20→ * @typedef {Object} QuizQuestion\n    21→ * @property {string} text\n    22→ * @property {'open'|'multiple'} type\n    23→ * @property {string[]} [options]\n    24→ */\n    25→\n    26→/**\n    27→ * @typedef {Object} Quiz\n    28→ * @property {string} [id]\n    29→ * @property {string} title\n    30→ * @property {string} moduleId\n    31→ * @property {string} lessonId\n    32→ * @property {QuizQuestion[]} questions\n    33→ * @property {*} [createdAt]\n    34→ */\n    35→\n    36→/**\n    37→ * Validate quiz data.\n    38→ * @param {Partial<Quiz>} data\n    39→ * @returns {{ valid: boolean, error?: string }}\n    40→ */\n    41→export function validateQuiz(data) {\n    42→  if (!data.title || data.title.trim().length === 0) {\n    43→    return { valid: false, error: 'El título es obligatorio' };\n    44→  }\n    45→\n    46→  if (!data.moduleId) {\n    47→    return { valid: false, error: 'El módulo es obligatorio' };\n    48→  }\n    49→\n    50→  if (!data.questions || data.questions.length === 0) {\n    51→    return { valid: false, error: 'Debe tener al menos una pregunta' };\n    52→  }\n    53→\n    54→  for (const q of data.questions) {\n    55→    if (!q.text || q.text.trim().length === 0) {\n    56→      return { valid: false, error: 'Todas las preguntas deben tener texto' };\n    57→    }\n    58→    if (q.type === 'multiple' && (!q.options || q.options.length === 0)) {\n    59→      return { valid: false, error: 'Las preguntas de selección múltiple necesitan opciones' };\n    60→    }\n    61→  }\n    62→\n    63→  return { valid: true };\n    64→}\n    65→\n    66→/**\n    67→ * Fetch all quizzes.\n    68→ * @returns {Promise<{success: boolean, quizzes?: Quiz[], error?: string}>}\n    69→ */\n    70→export async function fetchAllQuizzes() {\n    71→  try {\n    72→    const ref = collection(db, QUIZZES);\n    73→    const q = query(ref, orderBy('createdAt', 'desc'));\n    74→    const snapshot = await getDocs(q);\n    75→    const quizzes = snapshot.docs.map((d) => ({ id: d.id, ...d.data() }));\n    76→    return { success: true, quizzes };\n    77→  } catch (err) {\n    78→    return { success: false, error: 'Error al cargar quizzes' };\n    79→  }\n    80→}\n    81→\n    82→/**\n    83→ * Fetch a single quiz.\n    84→ * @param {string} id\n    85→ * @returns {Promise<{success: boolean, quiz?: Quiz, error?: string}>}\n    86→ */\n    87→export async function fetchQuiz(id) {\n    88→  if (!id) return { success: false, error: 'ID es obligatorio' };\n    89→\n    90→  try {\n    91→    const snap = await getDoc(doc(db, QUIZZES, id));\n    92→    if (!snap.exists()) return { success: false, error: 'Quiz no encontrado' };\n    93→    return { success: true, quiz: { id: snap.id, ...snap.data() } };\n    94→  } catch (err) {\n    95→    return { success: false, error: 'Error al cargar el quiz' };\n    96→  }\n    97→}\n    98→\n    99→/**\n   100→ * Create a new quiz.\n   101→ * @param {Omit<Quiz, 'id'>} data\n   102→ * @returns {Promise<{success: boolean, id?: string, error?: string}>}\n   103→ */\n   104→export async function createQuiz(data) {\n   105→  const validation = validateQuiz(data);\n   106→  if (!validation.valid) return { success: false, error: validation.error };\n   107→\n   108→  try {\n   109→    const ref = await addDoc(collection(db, QUIZZES), {\n   110→      title: data.title.trim(),\n   111→      moduleId: data.moduleId,\n   112→      lessonId: data.lessonId || '',\n   113→      questions: data.questions,\n   114→      createdAt: serverTimestamp(),\n   115→    });\n   116→    return { success: true, id: ref.id };\n   117→  } catch (err) {\n   118→    return { success: false, error: 'Error al crear el quiz' };\n   119→  }\n   120→}\n   121→\n   122→/**\n   123→ * Update a quiz.\n   124→ * @param {string} id\n   125→ * @param {Partial<Quiz>} updates\n   126→ * @returns {Promise<{success: boolean, error?: string}>}\n   127→ */\n   128→export async function updateQuiz(id, updates) {\n   129→  if (!id) return { success: false, error: 'ID es obligatorio' };\n   130→\n   131→  try {\n   132→    await updateDoc(doc(db, QUIZZES, id), updates);\n   133→    return { success: true };\n   134→  } catch (err) {\n   135→    return { success: false, error: 'Error al actualizar el quiz' };\n   136→  }\n   137→}\n   138→\n   139→/**\n   140→ * Delete a quiz.\n   141→ * @param {string} id\n   142→ * @returns {Promise<{success: boolean, error?: string}>}\n   143→ */\n   144→export async function deleteQuiz(id) {\n   145→  if (!id) return { success: false, error: 'ID es obligatorio' };\n   146→\n   147→  try {\n   148→    await deleteDoc(doc(db, QUIZZES, id));\n   149→    return { success: true };\n   150→  } catch (err) {\n   151→    return { success: false, error: 'Error al eliminar el quiz' };\n   152→  }\n   153→}\n   154→\n   155→/* ── Quiz Responses ─────────────────────────────────────────── */\n   156→\n   157→/**\n   158→ * Submit a quiz response.\n   159→ * @param {string} userId\n   160→ * @param {string} quizId\n   161→ * @param {string[]} answers\n   162→ * @returns {Promise<{success: boolean, id?: string, error?: string}>}\n   163→ */\n   164→export async function submitQuizResponse(userId, quizId, answers) {\n   165→  if (!userId) return { success: false, error: 'userId es obligatorio' };\n   166→  if (!quizId) return { success: false, error: 'quizId es obligatorio' };\n   167→  if (!answers || answers.length === 0) return { success: false, error: 'Las respuestas son obligatorias' };\n   168→\n   169→  try {\n   170→    const ref = await addDoc(collection(db, RESPONSES), {\n   171→      userId,\n   172→      quizId,\n   173→      answers,\n   174→      completedAt: serverTimestamp(),\n   175→    });\n   176→    return { success: true, id: ref.id };\n   177→  } catch (err) {\n   178→    return { success: false, error: 'Error al enviar las respuestas' };\n   179→  }\n   180→}\n   181→\n   182→/**\n   183→ * Get a user's response to a quiz.\n   184→ * @param {string} userId\n   185→ * @param {string} quizId\n   186→ * @returns {Promise<{success: boolean, response?: Object|null, error?: string}>}\n   187→ */\n   188→export async function getUserQuizResponse(userId, quizId) {\n   189→  if (!userId || !quizId) return { success: false, error: 'userId y quizId son obligatorios' };\n   190→\n   191→  try {\n   192→    const ref = collection(db, RESPONSES);\n   193→    const q = query(ref, where('userId', '==', userId), where('quizId', '==', quizId));\n   194→    const snapshot = await getDocs(q);\n   195→\n   196→    if (snapshot.docs.length === 0) return { success: true, response: null };\n   197→    return { success: true, response: { id: snapshot.docs[0].id, ...snapshot.docs[0].data() } };\n   198→  } catch (err) {\n   199→    return { success: false, error: 'Error al cargar la respuesta' };\n   200→  }\n   201→}\n   202→\n   203→/**\n   204→ * Get all responses for a quiz (admin).\n   205→ * @param {string} quizId\n   206→ * @returns {Promise<{success: boolean, responses?: Object[], error?: string}>}\n   207→ */\n   208→export async function getQuizResponses(quizId) {\n   209→  if (!quizId) return { success: false, error: 'quizId es obligatorio' };\n   210→\n   211→  try {\n   212→    const ref = collection(db, RESPONSES);\n   213→    const q = query(ref, where('quizId', '==', quizId));\n   214→    const snapshot = await getDocs(q);\n   215→\n   216→    const responses = snapshot.docs.map((d) => ({ id: d.id, ...d.data() }));\n   217→    return { success: true, responses };\n   218→  } catch (err) {\n   219→    return { success: false, error: 'Error al cargar las respuestas' };\n   220→  }\n   221→}\n   222→\n   223→/**\n   224→ * @typedef {Object} QuizResultDetail\n   225→ * @property {string} responseId\n   226→ * @property {string} quizId\n   227→ * @property {string} quizTitle\n   228→ * @property {QuizQuestion[]} questions\n   229→ * @property {string[]} userAnswers\n   230→ * @property {*} completedAt\n   231→ */\n   232→\n   233→/**\n   234→ * Get all quiz results for a user, including quiz details.\n   235→ * @param {string} userId\n   236→ * @returns {Promise<{success: boolean, results?: QuizResultDetail[], error?: string}>}\n   237→ */\n   238→export async function getUserQuizResults(userId) {\n   239→  if (!userId) return { success: false, error: 'userId es obligatorio' };\n   240→\n   241→  try {\n   242→    const ref = collection(db, RESPONSES);\n   243→    const q = query(ref, where('userId', '==', userId));\n   244→    const snapshot = await getDocs(q);\n   245→\n   246→    if (snapshot.docs.length === 0) {\n   247→      return { success: true, results: [] };\n   248→    }\n   249→\n   250→    const results = [];\n   251→    for (const responseDoc of snapshot.docs) {\n   252→      const responseData = responseDoc.data();\n   253→      const quizSnap = await getDoc(doc(db, QUIZZES, responseData.quizId));\n   254→\n   255→      if (quizSnap.exists()) {\n   256→        const quizData = quizSnap.data();\n   257→        results.push({\n   258→          responseId: responseDoc.id,\n   259→          quizId: responseData.quizId,\n   260→          quizTitle: quizData.title,\n   261→          questions: quizData.questions || [],\n   262→          userAnswers: responseData.answers || [],\n   263→          completedAt: responseData.completedAt,\n   264→        });\n   265→      }\n   266→    }\n   267→\n   268→    return { success: true, results };\n   269→  } catch (err) {\n   270→    return { success: false, error: 'Error al cargar los resultados de quizzes' };\n   271→  }\n   272→}\n   273→"}]},"parent_tool_use_id":null,"session_id":"7178526a-f4c2-4836-bbb3-d8ca7b58fdc9","uuid":"e5c3d9c0-7822-4d8c-8396-f20a15bdd000","tool_use_result":{"type":"text","file":{"filePath":"/home/manu/ws_firebase/manuelearning/src/lib/firebase/quizzes.js","content":"import {\n  collection,\n  doc,\n  getDoc,\n  getDocs,\n  addDoc,\n  updateDoc,\n  deleteDoc,\n  query,\n  where,\n  orderBy,\n  serverTimestamp,\n} from 'firebase/firestore';\nimport { db } from './config.js';\n\nconst QUIZZES = 'quizzes';\nconst RESPONSES = 'quizResponses';\n\n/**\n * @typedef {Object} QuizQuestion\n * @property {string} text\n * @property {'open'|'multiple'} type\n * @property {string[]} [options]\n */\n\n/**\n * @typedef {Object} Quiz\n * @property {string} [id]\n * @property {string} title\n * @property {string} moduleId\n * @property {string} lessonId\n * @property {QuizQuestion[]} questions\n * @property {*} [createdAt]\n */\n\n/**\n * Validate quiz data.\n * @param {Partial<Quiz>} data\n * @returns {{ valid: boolean, error?: string }}\n */\nexport function validateQuiz(data) {\n  if (!data.title || data.title.trim().length === 0) {\n    return { valid: false, error: 'El título es obligatorio' };\n  }\n\n  if (!data.moduleId) {\n    return { valid: false, error: 'El módulo es obligatorio' };\n  }\n\n  if (!data.questions || data.questions.length === 0) {\n    return { valid: false, error: 'Debe tener al menos una pregunta' };\n  }\n\n  for (const q of data.questions) {\n    if (!q.text || q.text.trim().length === 0) {\n      return { valid: false, error: 'Todas las preguntas deben tener texto' };\n    }\n    if (q.type === 'multiple' && (!q.options || q.options.length === 0)) {\n      return { valid: false, error: 'Las preguntas de selección múltiple necesitan opciones' };\n    }\n  }\n\n  return { valid: true };\n}\n\n/**\n * Fetch all quizzes.\n * @returns {Promise<{success: boolean, quizzes?: Quiz[], error?: string}>}\n */\nexport async function fetchAllQuizzes() {\n  try {\n    const ref = collection(db, QUIZZES);\n    const q = query(ref, orderBy('createdAt', 'desc'));\n    const snapshot = await getDocs(q);\n    const quizzes = snapshot.docs.map((d) => ({ id: d.id, ...d.data() }));\n    return { success: true, quizzes };\n  } catch (err) {\n    return { success: false, error: 'Error al cargar quizzes' };\n  }\n}\n\n/**\n * Fetch a single quiz.\n * @param {string} id\n * @returns {Promise<{success: boolean, quiz?: Quiz, error?: string}>}\n */\nexport async function fetchQuiz(id) {\n  if (!id) return { success: false, error: 'ID es obligatorio' };\n\n  try {\n    const snap = await getDoc(doc(db, QUIZZES, id));\n    if (!snap.exists()) return { success: false, error: 'Quiz no encontrado' };\n    return { success: true, quiz: { id: snap.id, ...snap.data() } };\n  } catch (err) {\n    return { success: false, error: 'Error al cargar el quiz' };\n  }\n}\n\n/**\n * Create a new quiz.\n * @param {Omit<Quiz, 'id'>} data\n * @returns {Promise<{success: boolean, id?: string, error?: string}>}\n */\nexport async function createQuiz(data) {\n  const validation = validateQuiz(data);\n  if (!validation.valid) return { success: false, error: validation.error };\n\n  try {\n    const ref = await addDoc(collection(db, QUIZZES), {\n      title: data.title.trim(),\n      moduleId: data.moduleId,\n      lessonId: data.lessonId || '',\n      questions: data.questions,\n      createdAt: serverTimestamp(),\n    });\n    return { success: true, id: ref.id };\n  } catch (err) {\n    return { success: false, error: 'Error al crear el quiz' };\n  }\n}\n\n/**\n * Update a quiz.\n * @param {string} id\n * @param {Partial<Quiz>} updates\n * @returns {Promise<{success: boolean, error?: string}>}\n */\nexport async function updateQuiz(id, updates) {\n  if (!id) return { success: false, error: 'ID es obligatorio' };\n\n  try {\n    await updateDoc(doc(db, QUIZZES, id), updates);\n    return { success: true };\n  } catch (err) {\n    return { success: false, error: 'Error al actualizar el quiz' };\n  }\n}\n\n/**\n * Delete a quiz.\n * @param {string} id\n * @returns {Promise<{success: boolean, error?: string}>}\n */\nexport async function deleteQuiz(id) {\n  if (!id) return { success: false, error: 'ID es obligatorio' };\n\n  try {\n    await deleteDoc(doc(db, QUIZZES, id));\n    return { success: true };\n  } catch (err) {\n    return { success: false, error: 'Error al eliminar el quiz' };\n  }\n}\n\n/* ── Quiz Responses ─────────────────────────────────────────── */\n\n/**\n * Submit a quiz response.\n * @param {string} userId\n * @param {string} quizId\n * @param {string[]} answers\n * @returns {Promise<{success: boolean, id?: string, error?: string}>}\n */\nexport async function submitQuizResponse(userId, quizId, answers) {\n  if (!userId) return { success: false, error: 'userId es obligatorio' };\n  if (!quizId) return { success: false, error: 'quizId es obligatorio' };\n  if (!answers || answers.length === 0) return { success: false, error: 'Las respuestas son obligatorias' };\n\n  try {\n    const ref = await addDoc(collection(db, RESPONSES), {\n      userId,\n      quizId,\n      answers,\n      completedAt: serverTimestamp(),\n    });\n    return { success: true, id: ref.id };\n  } catch (err) {\n    return { success: false, error: 'Error al enviar las respuestas' };\n  }\n}\n\n/**\n * Get a user's response to a quiz.\n * @param {string} userId\n * @param {string} quizId\n * @returns {Promise<{success: boolean, response?: Object|null, error?: string}>}\n */\nexport async function getUserQuizResponse(userId, quizId) {\n  if (!userId || !quizId) return { success: false, error: 'userId y quizId son obligatorios' };\n\n  try {\n    const ref = collection(db, RESPONSES);\n    const q = query(ref, where('userId', '==', userId), where('quizId', '==', quizId));\n    const snapshot = await getDocs(q);\n\n    if (snapshot.docs.length === 0) return { success: true, response: null };\n    return { success: true, response: { id: snapshot.docs[0].id, ...snapshot.docs[0].data() } };\n  } catch (err) {\n    return { success: false, error: 'Error al cargar la respuesta' };\n  }\n}\n\n/**\n * Get all responses for a quiz (admin).\n * @param {string} quizId\n * @returns {Promise<{success: boolean, responses?: Object[], error?: string}>}\n */\nexport async function getQuizResponses(quizId) {\n  if (!quizId) return { success: false, error: 'quizId es obligatorio' };\n\n  try {\n    const ref = collection(db, RESPONSES);\n    const q = query(ref, where('quizId', '==', quizId));\n    const snapshot = await getDocs(q);\n\n    const responses = snapshot.docs.map((d) => ({ id: d.id, ...d.data() }));\n    return { success: true, responses };\n  } catch (err) {\n    return { success: false, error: 'Error al cargar las respuestas' };\n  }\n}\n\n/**\n * @typedef {Object} QuizResultDetail\n * @property {string} responseId\n * @property {string} quizId\n * @property {string} quizTitle\n * @property {QuizQuestion[]} questions\n * @property {string[]} userAnswers\n * @property {*} completedAt\n */\n\n/**\n * Get all quiz results for a user, including quiz details.\n * @param {string} userId\n * @returns {Promise<{success: boolean, results?: QuizResultDetail[], error?: string}>}\n */\nexport async function getUserQuizResults(userId) {\n  if (!userId) return { success: false, error: 'userId es obligatorio' };\n\n  try {\n    const ref = collection(db, RESPONSES);\n    const q = query(ref, where('userId', '==', userId));\n    const snapshot = await getDocs(q);\n\n    if (snapshot.docs.length === 0) {\n      return { success: true, results: [] };\n    }\n\n    const results = [];\n    for (const responseDoc of snapshot.docs) {\n      const responseData = responseDoc.data();\n      const quizSnap = await getDoc(doc(db, QUIZZES, responseData.quizId));\n\n      if (quizSnap.exists()) {\n        const quizData = quizSnap.data();\n        results.push({\n          responseId: responseDoc.id,\n          quizId: responseData.quizId,\n          quizTitle: quizData.title,\n          questions: quizData.questions || [],\n          userAnswers: responseData.answers || [],\n          completedAt: responseData.completedAt,\n        });\n      }\n    }\n\n    return { success: true, results };\n  } catch (err) {\n    return { success: false, error: 'Error al cargar los resultados de quizzes' };\n  }\n}\n","numLines":273,"startLine":1,"totalLines":273}}} (stream=stdout)
