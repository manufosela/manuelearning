/\n    62→export function validateLesson(data) {\n    63→  if (!data.title || data.title.trim().length === 0) {\n    64→    return { valid: false, error: 'El título es obligatorio' };\n    65→  }\n    66→\n    67→  if (data.order === undefined || data.order === null || typeof data.order !== 'number' || data.order < 0) {\n    68→    return { valid: false, error: 'El orden debe ser un número positivo' };\n    69→  }\n    70→\n    71→  return { valid: true };\n    72→}\n    73→\n    74→/**\n    75→ * Fetch all modules ordered by order ascending.\n    76→ * @returns {Promise<{success: boolean, modules?: Module[], error?: string}>}\n    77→ */\n    78→export async function fetchAllModules() {\n    79→  try {\n    80→    const ref = collection(db, COLLECTION);\n    81→    const q = query(ref, orderBy('order', 'asc'));\n    82→    const snapshot = await getDocs(q);\n    83→\n    84→    const modules = snapshot.docs.map((d) => ({ id: d.id, ...d.data() }));\n    85→    return { success: true, modules };\n    86→  } catch (err) {\n    87→    return { success: false, error: 'Error al cargar módulos' };\n    88→  }\n    89→}\n    90→\n    91→/**\n    92→ * Fetch modules filtered by course name.\n    93→ * @param {string} courseName\n    94→ * @returns {Promise<{success: boolean, modules?: Module[], error?: string}>}\n    95→ */\n    96→export async function fetchModulesByCourse(courseName) {\n    97→  if (!courseName) return fetchAllModules();\n    98→\n    99→  try {\n   100→    const ref = collection(db, COLLECTION);\n   101→    const q = query(ref, where('course', '==', courseName), orderBy('order', 'asc'));\n   102→    const snapshot = await getDocs(q);\n   103→\n   104→    const modules = snapshot.docs.map((d) => ({ id: d.id, ...d.data() }));\n   105→    return { success: true, modules };\n   106→  } catch (err) {\n   107→    return { success: false, error: 'Error al cargar módulos del curso' };\n   108→  }\n   109→}\n   110→\n   111→/**\n   112→ * Fetch distinct course names from modules.\n   113→ * @returns {Promise<{success: boolean, courses?: string[], error?: string}>}\n   114→ */\n   115→export async function fetchCourseList() {\n   116→  try {\n   117→    const ref = collection(db, COLLECTION);\n   118→    const snapshot = await getDocs(ref);\n   119→\n   120→    const courseSet = new Set();\n   121→    snapshot.docs.forEach((d) => {\n   122→      const course = d.data().course;\n   123→      if (course) courseSet.add(course);\n   124→    });\n   125→\n   126→    return { success: true, courses: [...courseSet].sort() };\n   127→  } catch (err) {\n   128→    return { success: false, error: 'Error al cargar lista de cursos' };\n   129→  }\n   130→}\n   131→\n   132→/**\n   133→ * Fetch a single module by ID.\n   134→ * @param {string} id\n   135→ * @returns {Promise<{success: boolean, module?: Module, error?: string}>}\n   136→ */\n   137→export async function fetchModule(id) {\n   138→  if (!id) return { success: false, error: 'ID es obligatorio' };\n   139→\n   140→  try {\n   141→    const snap = await getDoc(doc(db, COLLECTION, id));\n   142→    if (!snap.exists()) return { success: false, error: 'Módulo no encontrado' };\n   143→    return { success: true, module: { id: snap.id, ...snap.data() } };\n   144→  } catch (err) {\n   145→    return { success: false, error: 'Error al cargar el módulo' };\n   146→  }\n   147→}\n   148→\n   149→/**\n   150→ * Create a new module."}]},"parent_tool_use_id":"toolu_01PviopKjwtvPxPXj5fcZ46W","session_id":"6dab462c-976e-4fe8-a358-d44adb2c1366","uuid":"e99969b2-327c-4a5d-8b6a-d3fef5929809"} (stream=stdout)
