Quiz({ ...valid, title: '' }).valid).toBe(false);\n    54→  });\n    55→\n    56→  it('should reject missing moduleId', () => {\n    57→    expect(validateQuiz({ ...valid, moduleId: '' }).valid).toBe(false);\n    58→  });\n    59→\n    60→  it('should reject empty questions', () => {\n    61→    expect(validateQuiz({ ...valid, questions: [] }).valid).toBe(false);\n    62→  });\n    63→\n    64→  it('should reject question without text', () => {\n    65→    expect(validateQuiz({ ...valid, questions: [{ text: '', type: 'open' }] }).valid).toBe(false);\n    66→  });\n    67→\n    68→  it('should reject multiple type without options', () => {\n    69→    expect(validateQuiz({ ...valid, questions: [{ text: 'Q', type: 'multiple', options: [] }] }).valid).toBe(false);\n    70→  });\n    71→\n    72→  it('should accept valid quiz', () => {\n    73→    expect(validateQuiz(valid).valid).toBe(true);\n    74→  });\n    75→});\n    76→\n    77→/* ── fetchAllQuizzes ────────────────────────────────────────── */\n    78→describe('fetchAllQuizzes', () => {\n    79→  beforeEach(() => vi.clearAllMocks());\n    80→\n    81→  it('should return quizzes on success', async () => {\n    82→    mockGetDocs.mockResolvedValue({\n    83→      docs: [\n    84→        { id: 'q1', data: () => ({ title: 'Quiz 1' }) },\n    85→      ],\n    86→    });\n    87→    const result = await fetchAllQuizzes();\n    88→    expect(result.success).toBe(true);\n    89→    expect(result.quizzes).toHaveLength(1);\n    90→  });\n    91→\n    92→  it('should handle errors', async () => {\n    93→    mockGetDocs.mockRejectedValue(new Error('err'));\n    94→    expect((await fetchAllQuizzes()).success).toBe(false);\n    95→  });\n    96→});\n    97→\n    98→/* ── fetchQuiz ──────────────────────────────────────────────── */\n    99→describe('fetchQuiz', () => {\n   100→  beforeEach(() => vi.clearAllMocks());\n   101→\n   102→  it('should reject empty id', async () => {\n   103→    expect((await fetchQuiz('')).succes