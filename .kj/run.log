ckground: #fff;\n    color: #991b1b;\n    border: 1px solid #fecaca;\n    border-radius: 0.5rem;\n    font-size: 0.813rem;\n    font-weight: 600;\n    font-family: inherit;\n    cursor: pointer;\n    transition: background-color 0.15s;\n  }\n\n  .state-retry-btn:hover {\n    background: #fef2f2;\n  }\n\n  .state-retry-btn .material-symbols-outlined {\n    font-size: 1rem;\n  }\n`;\n","numLines":82,"startLine":1,"totalLines":82}}} (stream=stdout)
