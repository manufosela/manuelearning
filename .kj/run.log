rl = '';\n    64→  }\n    65→\n    66→  render() {\n    67→    const videoId = extractYouTubeId(this.url);\n    68→\n    69→    if (!videoId) {\n    70→      return html`\n    71→        ${materialIconsLink}\n    72→        <div class=\"no-video\">\n    73→          <span class=\"material-symbols-outlined\">videocam_off</span>\n    74→          <p>No hay video disponible para esta clase</p>\n    75→        </div>\n    76→      `;\n    77→    }\n    78→\n    79→    const embedUrl = buildEmbedUrl(videoId);\n    80→\n    81→    return html`\n    82→      <div class=\"video-container\">\n    83→        <iframe\n    84→          src=${embedUrl}\n    85→          title=\"Video de la clase\"\n    86→          allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\"\n    87→          allowfullscreen\n    88→          loading=\"lazy\"\n    89→          @load=${this._onLoad}\n    90→        ></iframe>\n    91→      </div>\n    92→    `;\n    93→  }\n    94→\n    95→  _onLoad() {\n    96→    this.dispatchEvent(new CustomEvent('video-ready', { bubbles: true, composed: true }));\n    97→  }\n    98→}\n    99→\n   100→customElements.define('video-player', VideoPlayer);\n   101→"}]},"parent_tool_use_id":"toolu_017tkSLw7CGRsjySeyqz2Ko1","session_id":"29ef6fdd-2401-4391-a139-b7ef9e423188","uuid":"8b6a94ae-dac9-42e1-96b0-7d25be0ff937"} (stream=stdout)
