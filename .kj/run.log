width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem; font-family: inherit; box-sizing: border-box; }\n    63→    .form-group input:focus, .form-group textarea:focus { outline: none; border-color: #84cc16; box-shadow: 0 0 0 3px rgba(132,204,22,0.1); }\n    64→    .form-error { color: #991b1b; font-size: 0.813rem; margin-bottom: 1rem; }\n    65→    .form-actions { display: flex; justify-content: flex-end; gap: 0.5rem; margin-top: 1.5rem; }\n    66→\n    67→    .question-block { background: #f8fafc; padding: 1rem; border-radius: 0.5rem; margin-bottom: 0.75rem; border: 1px solid #e2e8f0; }\n    68→    .question-block-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }\n    69→    .question-number { font-size: 0.75rem; font-weight: 700; color: #475569; }\n    70→\n    71→    .loading, .error-msg { text-align: center; padding: 3rem; color: #475569; }\n    72→    .error-msg { color: #991b1b; }\n    73→    .spinner { width: 1.5rem; height: 1.5rem; border: 3px solid #e2e8f0; border-top-color: #84cc16; border-radius: 50%; animation: spin 0.6s linear infinite; margin: 0 auto 0.75rem; }\n    74→    @keyframes spin { to { transform: rotate(360deg); } }\n    75→    .empty-state { text-align: center; padding: 3rem; color: #64748b; }\n    76→  `;\n    77→\n    78→  constructor() {\n    79→    super();\n    80→    this._quizzes = [];\n    81→    this._loading = true;\n    82→    this._error = '';\n    83→    this._showForm = false;\n    84→    this._editingId = null;\n    85→    this._formData = this._emptyForm();\n    86→    this._formError = '';\n    87→    this._saving = false;\n    88→    this._viewingResponses = null;\n    89→    this._responses = [];\n    90→  }\n    91→\n    92→  connectedCallback() {\n    93→    super.connectedCallback();\n    94→    waitForAuth().then(() => this._loadQuizzes());\n    95→  }\n    96→\n    97→  _emptyForm() {\n    98→    return {\n    99→      title: '',\n   100→      moduleId: '',\n   101→      lessonId: '',\n   102→      questions: [{ text: '', type: 'open', options: [] }],\n   103→    };\n   104→  }\n   105→\n   106→  async _loadQuizzes() {\n   107→    this._loading = true;\n   108→    const result = await fetchAllQuizzes();\n   109→    this._loading = false;\n   110→    if (result.success) { this._quizzes = result.quizzes; } else { this._error = result.error; }\n   111→  }\n   112→\n   113→  _openCreate() {\n   114→    this._editingId = null;\n   115→    this._formData = this._emptyForm();\n   116→    this._formError = '';\n   117→    this._showForm = true;\n   118→  }\n   119→\n   120→  _openEdit(quiz) {\n   121→    this._editingId = quiz.id;\n   122→    this._formData = {\n   123→      title: quiz.title || '',\n   124→      moduleId: quiz.moduleId || '',\n   125→      lessonId: quiz.lessonId || '',\n   126→      questions: (quiz.questions || []).map((q) => ({ ...q, options: q.options || [] })),\n   127→    };\n   128→    this._formError = '';\n   129→    this._showForm = true;\n   130→  }\n   131→\n   132→  _closeForm() { this._showForm = false; this._editingId = null; this._formError = ''; }\n   133→\n   134→  _handleInput(e) {\n   135→    const input = /** @type {HTMLInputElement} */ (e.target);\n   136→    this._formData = { ...this._formData, [input.name]: input.value };\n   137→  }\n   138→\n   139→  _handleQuestionInput(index, field, value) {\n   140→    const questions = [...this._formData.questions];\n   141→    questions[index] = { ...questions[index], [field]: value };\n   142→    this._formData = { ...this._formData, questions };\n   143→  }\n   144→\n   145→  _addQuestion() {\n   146→    this._formData = {\n   147→      ...this._formData,\n   148→      questions: [...this._formData.questions, { text: '', type: 'open', options: [] }],\n   149→    };\n   150→  }\n   151→\n   152→  _removeQuestion(index) {\n   153→    const questions = this._formData.questions.filter((_, i) => i !== index);\n   154→    this._formData = { ...this._formData, questions };\n   155→  }\n   156→\n   157→  async _handleSubmit(e) {\n   158→    e.preventDefault();\n   159→    this._formError = '';\n   160→    const validation = validateQuiz(this._formData);\n   161→    if (!validation.valid) { this._formError = validation.error; return; }\n   162→\n   163→    this._saving = true;\n   164→    let result;\n   165→    if (this._editingId) {\n   166→      result = await updateQuiz(this._editingId, {\n   167→        title: this._formData.title.trim(),\n   168→        moduleId: this._formData.moduleId,\n   169→        lessonId: this._formData.lessonId || '',\n   170→        questions: this._formData.questions,\n   171→      });\n   172→    } else {\n   173→      result = await createQuiz(this._formData);\n   174→    }\n   175→    this._saving = false;\n   176→    if (result.success) { this._closeForm(); await this._loadQuizzes(); } else { this._formError = result.error; }\n   177→  }\n   178→\n   179→  async _handleDelete(quizId) {\n   180→    const result = await deleteQuiz(quizId);\n   181→    if (result.success) await this._loadQuizzes();\n   182→  }\n   183→\n   184→  _exportResponses(quiz) {\n   185→    const questionCount = quiz.questions?.length || 0;\n   186→    const headers = ['Usuario', ...Array.from({ length: questionCount }, (_, i) => `Pregunta ${i + 1}`)];\n   187→    const rows = this._responses.map((r) => [\n   188→      r.userId,\n   189→      ...Array.from({ length: questionCount }, (_, i) => r.answers[i] || ''),\n   190→    ]);\n   191→    const safeName = quiz.title.replace(/[^a-zA-Z0-9]/g, '_').toLowerCase();\n   192→    exportCsv(headers, rows, `quiz_${safeName}.csv`);\n   193→  }\n   194→\n   195→  async _toggleResponses(quizId) {\n   196→    if (this._viewingResponses === quizId) { this._viewingResponses = null; return; }\n   197→    this._viewingResponses = quizId;\n   198→    const result = await getQuizResponses(quizId);\n   199→    this._responses = result.success ? result.responses : [];\n   200→  }\n   201→\n   202→  render() {\n   203→    if (this._loading) return html`<div class=\"loading\"><div class=\"spinner\"></div><p>Cargando quizzes...</p></div>`;\n   204→    if (this._error) return html`<div class=\"error-msg\">${this._error}</div>`;\n   205→\n   206→    return html`\n   207→      ${materialIconsLink}\n   208→      <div class=\"toolbar\">\n   209→        <span>${this._quizzes.length} quiz${this._quizzes.length !== 1 ? 'zes' : ''}</span>\n   210→        <button class=\"btn btn--primary\" @click=${this._openCreate}>\n   211→          <span class=\"material-symbols-outlined\">add</span> Nuevo quiz\n   212→        </button>\n   213→      </div>\n   214→\n   215→      ${this._quizzes.length === 0\n   216→        ? html`<div class=\"empty-state\"><p>No hay quizzes creados</p></div>`\n   217→        : this._quizzes.map((q) => this._renderQuiz(q))}\n   218→\n   219→      ${this._showForm ? this._renderForm() : ''}\n   220→    `;\n   221→  }\n   222→\n   223→  _renderQuiz(q) {\n   224→    const isViewing = this._viewingResponses === q.id;\n   225→    return html`\n   226→      <div class=\"quiz-card\">\n   227→        <div class=\"quiz-header\">\n   228→          <span class=\"quiz-title\">${q.title}</span>\n   229→          <div class=\"quiz-actions\">\n   230→            <button class=\"btn btn--secondary btn--small\" @click=${() => this._openEdit(q)}>Editar</button>\n   231→            <button class=\"btn btn--secondary btn--small\" @click=${() => this._toggleResponses(q.id)}>\n   232→              ${isViewing ? 'Ocultar' : 'Respuestas'}\n   233→            </button>\n   234→            <button class=\"btn btn--danger btn--small\" @click=${() => this._handleDelete(q.id)}>Eliminar</button>\n   235→          </div>\n   236→        </div>\n   237→        <div class=\"quiz-meta\">${q.questions?.length || 0} preguntas · Módulo: ${q.moduleId}</div>\n   238→\n   239→        ${isViewing ? html`\n   240→          <div class=\"responses-panel\">\n   241→            ${this._responses.length > 0 ? html`\n   242→              <div style=\"margin-bottom: 0.75rem;\">\n   243→                <button class=\"btn btn--secondary btn--small\" @click=${() => this._exportResponses(q)}>\n   244→                  <span class=\"material-symbols-outlined\" style=\"font-size: 0.875rem;\">download</span>\n   245→                  Exportar resultados\n   246→                </button>\n   247→              </div>\n   248→            ` : ''}\n   249→            ${this._responses.length === 0\n   250→              ? html`<p class=\"quiz-meta\">Sin respuestas aún</p>`\n   251→              : this._responses.map((r) => html`\n   252→                  <div class=\"response-item\">\n   253→                    <div class=\"response-user\">${r.userId}</div>\n   254→                    ${r.answers.map((a, i) => html`<div class=\"response-answer\"><strong>P${i + 1}:</strong> ${a}</div>`)}\n   255→                  </div>\n   256→                `)}\n   257→          </div>\n   258→        ` : ''}\n   259→      </div>\n   260→    `;\n   261→  }\n   262→\n   263→  _renderForm() {\n   264→    return html`\n   265→      <div class=\"form-overlay\" @click=${this._closeForm}>\n   266→        <div class=\"form-card\" @click=${(e) => e.stopPropagation()}>\n   267→          <h3>${this._editingId ? 'Editar quiz' : 'Nuevo quiz'}</h3>\n   268→          <form @submit=${this._handleSubmit}>\n   269→            <div class=\"form-group\">\n   270→              <label for=\"quiz-title\">Título</label>\n   271→              <input id=\"quiz-title\" name=\"title\" type=\"text\" .value=${this._formData.title} @input=${this._handleInput} required />\n   272→            </div>\n   273→            <div class=\"form-group\">\n   274→              <label for=\"quiz-module\">ID del Módulo</label>\n   275→              <input id=\"quiz-module\" name=\"moduleId\" type=\"text\" .value=${this._formData.moduleId} @input=${this._handleInput} required />\n   276→            </div>\n   277→            <div class=\"form-group\">\n   278→              <label for=\"quiz-lesson\">ID de la Clase (opcional)</label>\n   279→              <input id=\"quiz-lesson\" name=\"lessonId\" type=\"text\" .value=${this._formData.lessonId} @input=${this._handleInput} />\n   280→            </div>\n   281→\n   282→            <h4 style=\"margin: 1rem 0 0.75rem; font-size: 0.875rem; color: #0f172a;\">Preguntas</h4>\n   283→            ${this._formData.questions.map((q, i) => html`\n   284→              <div class=\"question-block\">\n   285→                <div class=\"question-block-header\">\n   286→                  <span class=\"question-number\">Pregunta ${i + 1}</span>\n   287→                  ${this._formData.questions.length > 1 ? html`\n   288→                    <button type=\"button\" class=\"btn btn--danger btn--small\" @click=${() => this._removeQuestion(i)}>Quitar</button>\n   289→                  ` : ''}\n   290→                </div>\n   291→                <div class=\"form-group\">\n   292→                  <input type=\"text\" .value=${q.text} @input=${(e) => this._handleQuestionInput(i, 'text', e.target.value)} placeholder=\"Texto de la pregunta\" required />\n   293→                </div>\n   294→                <div class=\"form-group\">\n   295→                  <select .value=${q.type} @change=${(e) => this._handleQuestionInput(i, 'type', e.target.value)}>\n   296→                    <option value=\"open\">Respuesta abierta</option>\n   297→                    <option value=\"multiple\">Selección múltiple</option>\n   298→                  </select>\n   299→                </div>\n   300→                ${q.type === 'multiple' ? html`\n   301→                  <div class=\"form-group\">\n   302→                    <label>Opciones (una por línea)</label>\n   303→                    <textarea\n   304→                      .value=${(q.options || []).join('\\n')}\n   305→                      @input=${(e) => this._handleQuestionInput(i, 'options', e.target.value.split('\\n').filter(Boolean))}\n   306→                      placeholder=\"Opción A\\nOpción B\\nOpción C\"\n   307→                      rows=\"3\"\n   308→                    ></textarea>\n   309→                  </div>\n   310→                ` : ''}\n   311→              </div>\n   312→            `)}\n   313→\n   314→            <button type=\"button\" class=\"btn btn--secondary\" @click=${this._addQuestion} style=\"margin-bottom: 1rem;\">\n   315→              + Añadir pregunta\n   316→            </button>\n   317→\n   318→            ${this._formError ? html`<div class=\"form-error\">${this._formError}</div>` : ''}\n   319→            <div class=\"form-actions\">\n   320→              <button type=\"button\" class=\"btn btn--secondary\" @click=${this._closeForm}>Cancelar</button>\n   321→              <button type=\"submit\" class=\"btn btn--primary\" ?disabled=${this._saving}>${this._saving ? 'Guardando...' : this._editingId ? 'Guardar' : 'Crear'}</button>\n   322→            </div>\n   323→          </form>\n   324→        </div>\n   325→      </div>\n   326→    `;\n   327→  }\n   328→}\n   329→\n   330→customElements.define('admin-quizzes-list', AdminQuizzesList);\n   331→"}]},"parent_tool_use_id":"toolu_017tkSLw7CGRsjySeyqz2Ko1","session_id":"29ef6fdd-2401-4391-a139-b7ef9e423188","uuid":"6dd6d96a-e3c2-4ec7-9555-ec72a63be7f9"} (stream=stdout)
