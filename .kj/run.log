 padding: 0.5rem 1rem; border: none; border-radius: 0.5rem; font-size: 0.813rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: background-color 0.15s; }\n    43→    .btn--primary { background: linear-gradient(to right, #84cc16, #fb923c); color: #0f172a; align-self: flex-end; }\n    44→    .btn--primary:hover { background: #d11111; }\n    45→    .btn:disabled { opacity: 0.6; cursor: not-allowed; }\n    46→\n    47→    .question-item {\n    48→      background: #fff;\n    49→      border-radius: 0.5rem;\n    50→      padding: 1rem;\n    51→      margin-bottom: 0.75rem;\n    52→      box-shadow: 0 1px 2px rgb(0 0 0 / 0.05);\n    53→      border-left: 3px solid #84cc16;\n    54→    }\n    55→\n    56→    .question-text { font-size: 0.938rem; color: #0f172a; margin-bottom: 0.375rem; }\n    57→    .question-meta { font-size: 0.75rem; color: #94a3b8; }\n    58→    .privacy-badge { display: inline-flex; align-items: center; gap: 0.25rem; font-size: 0.688rem; color: #64748b; background: #f1f5f9; padding: 0.125rem 0.5rem; border-radius: 9999px; margin-left: 0.5rem; }\n    59→    .privacy-badge .material-symbols-outlined { font-size: 0.75rem; }\n    60→\n    61→    .answer-list { margin-top: 0.5rem; padding-left: 1rem; border-left: 2px solid #e2e8f0; }\n    62→    .answer-item { padding: 0.5rem 0; }\n    63→    .answer-text { font-size: 0.875rem; color: #334155; }\n    64→    .answer-meta { font-size: 0.688rem; color: #94a3b8; margin-top: 0.125rem; }\n    65→\n    66→    .empty-state { text-align: center; padding: 2rem; color: #94a3b8; font-size: 0.875rem; }\n    67→    .loading { text-align: center; padding: 1rem; color: #94a3b8; font-size: 0.875rem; }\n    68→  `];\n    69→\n    70→  constructor() {\n    71→    super();\n    72→    this.lessonId = '';\n    73→    this.moduleId = '';\n    74→    this.userId = '';\n    75→    this.userName = '';\n    76→    this._questions = [];\n    77→    this._loading = true;\n    78→    this._newQuestion = '';\n    79→    this._submitting = false;\n    80→    this._error = '';\n    81→  }\n    82→\n    83→  connectedCallback() {\n    84→    super.connectedCallback();\n    85→    waitForAuth().then(() => {\n    86→      if (this.lessonId) this._loadQuestions();\n    87→    });\n    88→  }\n    89→\n    90→  async _loadQuestions() {\n    91→    this._loading = true;\n    92→    this._error = '';\n    93→    const result = await fetchQuestionsByLesson(this.lessonId, this.userId);\n    94→    this._loading = false;\n    95→    if (result.success) {\n    96→      this._questions = result.questions;\n    97→    } else {\n    98→      this._error = result.error || 'Error al cargar las preguntas';\n    99→    }\n   100→  }\n   101→\n   102→  async _handleSubmit(e) {\n   103→    e.preventDefault();\n   104→    if (!this._newQuestion.trim() || !this.userId) return;\n   105→\n   106→    this._submitting = true;\n   107→    const result = await createQuestion({\n   108→      text: this._newQuestion,\n   109→      userId: this.userId,\n   110→      userName: this.userName,\n   111→      lessonId: this.lessonId,\n   112→      moduleId: this.moduleId,\n   113→    });\n   114→    this._submitting = false;\n   115→\n   116→    if (result.success) {\n   117→      this._newQuestion = '';\n   118→      await this._loadQuestions();\n   119→    }\n   120→  }\n   121→\n   122→  render() {\n   123→    return html`\n   124→      ${materialIconsLink}\n   125→      <h3>Preguntas y respuestas</h3>\n   126→\n   127→      ${this.userId ? html`\n   128→        <form class=\"qa-form\" @submit=${this._handleSubmit}>\n   129→          <textarea\n   130→            placeholder=\"Escribe tu pregunta sobre esta clase...\"\n   131→            .value=${this._newQuestion}\n   132→            @input=${(e) => { this._newQuestion = e.target.value; }}\n   133→            rows=\"2\"\n   134→          ></textarea>\n   135→          <button type=\"submit\" class=\"btn btn--primary\" ?disabled=${this._submitting || !this._newQuestion.trim()}>\n   136→            ${this._submitting ? 'Enviando...' : 'Preguntar'}\n   137→          </button>\n   138→        </form>\n   139→      ` : ''}\n   140→\n   141→      ${this._loading ? html`<div class=\"loading\">Cargando preguntas...</div>` : ''}\n   142→\n   143→      ${!this._loading && this._error ? html`\n   144→        <div class=\"state-error\">\n   145→          <p>${this._error}</p>\n   146→          <button class=\"state-retry-btn\" @click=${this._loadQuestions}>\n   147→            <span class=\"material-symbols-outlined\">refresh</span>\n   148→            Reintentar\n   149→          </button>\n   150→        </div>\n   151→      ` : ''}\n   152→\n   153→      ${!this._loading && !this._error && this._questions.length === 0\n   154→        ? html`<div class=\"empty-state\">No hay preguntas aún. Sé el primero en preguntar.</div>`\n   155→        : ''}\n   156→\n   157→      ${this._questions.map((q) => html`\n   158→        <div class=\"question-item\">\n   159→          <div class=\"question-text\">${q.text}</div>\n   160→          <div class=\"question-meta\">\n   161→            ${q.userName || 'Anónimo'} · ${this._formatDate(q.createdAt)}\n   162→            ${q.userId === this.userId && q.public !== true ? html`\n   163→              <span class=\"privacy-badge\">\n   164→                <span class=\"material-symbols-outlined\">lock</span>Solo tú y el profesor\n   165→              </span>\n   166→            ` : ''}\n   167→          </div>\n   168→          ${q.answers && q.answers.length > 0 ? html`\n   169→            <div class=\"answer-list\">\n   170→              ${q.answers.map((a) => html`\n   171→                <div class=\"answer-item\">\n   172→                  <div class=\"answer-text\">${a.text}</div>\n   173→                  <div class=\"answer-meta\">${a.userName || 'Admin'} · ${a.createdAt || ''}</div>\n   174→                </div>\n   175→              `)}\n   176→            </div>\n   177→          ` : ''}\n   178→        </div>\n   179→      `)}\n   180→    `;\n   181→  }\n   182→\n   183→  _formatDate(ts) {\n   184→    if (!ts) return '';\n   185→    if (ts.toDate) return ts.toDate().toLocaleDateString('es-ES');\n   186→    if (typeof ts === 'string') return new Date(ts).toLocaleDateString('es-ES');\n   187→    return '';\n   188→  }\n   189→}\n   190→\n   191→customElements.define('lesson-qa', LessonQA);\n   192→"}]},"parent_tool_use_id":"toolu_017tkSLw7CGRsjySeyqz2Ko1","session_id":"29ef6fdd-2401-4391-a139-b7ef9e423188","uuid":"9692d7dc-f817-4a7c-b9b5-8207699d8fa3"} (stream=stdout)
