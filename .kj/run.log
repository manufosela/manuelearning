02:03:10.174 [agent:output] [coder] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013Ho7T682RjJiMCZzTqnSBe","type":"tool_result","content":"     1→import { LitElement, html, css } from 'lit';\n     2→import {\n     3→  fetchAllQuizzes,\n     4→  createQuiz,\n     5→  updateQuiz,\n     6→  deleteQuiz,\n     7→  getQuizResponses,\n     8→  validateQuiz,\n     9→} from '../lib/firebase/quizzes.js';\n    10→import { waitForAuth } from '../lib/auth-ready.js';\n    11→import { exportCsv } from '../lib/csv-export.js';\n    12→import { materialIconsLink } from './shared/material-icons.js';\n    13→\n    14→/**\n    15→ * @element admin-quizzes-list\n    16→ * Admin panel for managing quizzes and viewing responses.\n    17→ */\n    18→export class AdminQuizzesList extends LitElement {\n    19→  static properties = {\n    20→    _quizzes: { type: Array, state: true },\n    21→    _loading: { type: Boolean, state: true },\n    22→    _error: { type: String, state: true },\n    23→    _showForm: { type: Boolean, state: true },\n    24→    _editingId: { type: String, state: true },\n    25→    _formData: { type: Object, state: true },\n    26→    _formError: { type: String, state: true },\n    27→    _saving: { type: Boolean, state: true },\n    28→    _viewingResponses: { type: String, state: true },\n    29→    _responses: { type: Array, state: true },\n    30→  };\n    31→\n    32→  static styles = css`\n    33→    :host { display: block; }\n    34→\n    35→    .toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }\n    36→    .btn { display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.5rem 1rem; border: none; border-radius: 0.5rem; font-size: 0.813rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: background-color 0.15s; }\n    37→    .btn--primary { background: linear-gradient(to right, #84cc16, #fb923c); color: #0f172a; }\n    38→    .btn--primary:hover { background: #d11111; }\n    39→    .btn--secondary { background: #f1f5f9; color: #334155; }\n    40→    .btn--secondary:hover { background: #e2e8f0; }\n    41→    .btn--danger { background: #fef2f2; color: #991b1b; }\n    42→    .btn--danger:hover { background: #fee2e2; }\n    43→    .btn--small { padding: 0.375rem 0.75rem; font-size: 0.75rem; }\n    44→    .btn:disabled { opacity: 0.6; cursor: not-allowed; }\n    45→\n    46→    .quiz-card { background: #fff; border-radius: 0.75rem; padding: 1.25rem; box-shadow: 0 1px 3px rgb(0 0 0 / 0.1); margin-bottom: 1rem; }\n    47→    .quiz-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }\n    48→    .quiz-title { font-size: 1rem; font-weight: 700; color: #0f172a; }\n    49→    .quiz-meta { font-size: 0.813rem; color: #64748b; }\n    50→    .quiz-actions { display: flex; gap: 0.5rem; }\n    51→\n    52→    .responses-panel { border-top: 1px solid #f1f5f9; margin-top: 1rem; padding-top: 1rem; }\n    53→    .response-item { background: #f8fafc; padding: 0.75rem; border-radius: 0.5rem; margin-bottom: 0.5rem; font-size: 0.875rem; }\n    54→    .response-user { font-weight: 600; color: #0f172a; margin-bottom: 0.25rem; }\n    55→    .response-answer { color: #334155; }\n    56→\n    57→    .form-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; z-index: 100; }\n    58→    .form-card { background: #fff; border-radius: 0.75rem; padding: 2rem; width: 100%; max-width: 560px; box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.25); max-height: 90vh; overflow-y: auto; }\n    59→    .form-card h3 { margin: 0 0 1.5rem; font-size: 1.125rem; font-weight: 700; color: #0f172a; }\n    60→    .form-group { margin-bottom: 1rem; }\n    61→    .form-group label { display: block; font-size: 0.813rem; font-weight: 600; color: #334155; margin-bottom: 0.375rem; }\n    62→    .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem; font-family: inherit; box-sizing: border-box; }\n    63→    .form-group input:focus, .form-group textarea:focus { outline: none; border-color: #84cc16; box-shadow: 0 0 0 3px rgba(132,204,22,0.1); }\n    64→    .form-error { color: #991b1b; font-size: 0.813rem; margin-bottom: 1rem; }\n    65→    .form-actions { display: flex; justify-content: flex-end; gap: 0.5rem; margin-top: 1.5rem; }\n    66→\n    67→    .question-block { background: #f8fafc; padding: 1rem; border-radius: 0.5rem; margin-bottom: 0.75rem; border: 1px solid #e2e8f0; }\n    68→    .question-block-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }\n    69→    .question-number { font-size: 0.75rem; font-weight: 700; color: #475569; }\n    70→\n    71→    .loading, .error-msg { text-align: center; padding: 3rem; color: #475569; }\n    72→    .error-msg { color: #991b1b; }\n    73→    .spinner { width: 1.5rem; height: 1.5rem; border: 3px solid #e2e8f0; border-top-color: #84cc16; border-radius: 50%; animation: spin 0.6s linear infinite; margin: 0 auto 0.75rem; }\n    74→    @keyframes spin { to { transform: rotate(360deg); } }\n    75→    .empty-state { text-align: center; padding: 3rem; color: #64748b; }\n    76→  `;\n    77→\n    78→  constructor() {\n    79→    super();\n    80→    this._quizzes = [];\n    81→    this._loading = true;\n    82→    this._error = '';\n    83→    this._showForm = false;\n    84→    this._editingId = null;\n    85→    this._formData = this._emptyForm();\n    86→    this._formError = '';\n    87→    this._saving = false;\n    88→    this._viewingResponses = null;\n    89→    this._responses = [];\n    90→  }\n    91→\n    92→  connectedCallback() {\n    93→    super.connectedCallback();\n    94→    waitForAuth().then(() => this._loadQuizzes());\n    95→  }\n    96→\n    97→  _emptyForm() {\n    98→    return {\n    99→      title: '',\n   100→      moduleId: '',\n   101→      lessonId: '',\n   102→      questions: [{ text: '', type: 'open', options: [] }],\n   103→    };\n   104→  }\n   105→\n   106→  async _loadQuizzes() {\n   107→    this._loading = true;\n   108→    const result = await fetchAllQuizzes();\n   109→    this._loading = false;\n   110→    if (result.success) { this._quizzes = result.quizzes; } else { this._error = result.error; }\n   111→  }\n   112→\n   113→  _openCreate() {\n   114→    this._editingId = null;\n   115→    this._formData = this._emptyForm();\n   116→    this._formError = '';\n   117→    this._showForm = true;\n   118→  }\n   119→\n   120→  _openEdit(quiz) {\n   121→    this._editingId = quiz.id;\n   122→    this._formData = {\n   123→      title: quiz.title || '',\n   124→      moduleId: quiz.moduleId || '',\n   125→      lessonId: quiz.lessonId || '',\n   126→      questions: (quiz.questions || []).map((q) => ({ ...q, options: q.options || [] })),\n   127→    };\n   128→    this._formError = '';\n   129→    this._showForm = true;\n   130→  }\n   131→\n   132→  _closeForm() { this._showForm = false; this._editingId = null; this._formError = ''; }\n   133→\n   134→  _handleInput(e) {\n   135→    const input = /** @type {HTMLInputElement} */ (e.target);\n   136→    this._formData = { ...this._formData, [input.name]: input.value };\n   137→  }\n   138→\n   139→  _handleQuestionInput(index, field, value) {\n   140→    const questions = [...this._formData.questions];\n   141→    questions[index] = { ...questions[index], [field]: value };\n   142→    this._formData = { ...this._formData, questions };\n   143→  }\n   144→\n   145→  _addQuestion() {\n   146→    this._formData = {\n   147→      ...this._formData,\n   148→      questions: [...this._formData.questions, { text: '', type: 'open', options: [] }],\n   149→    };\n   150→  }\n   151→\n   152→  _removeQuestion(index) {\n   153→    const questions = this._formData.questions.filter((_, i) => i !== index);\n   154→    this._formData = { ...this._formData, questions };\n   155→  }\n   156→\n   157→  async _handleSubmit(e) {\n   158→    e.preventDefault();\n   159→    this._formError = '';\n   160→    const validation = validateQuiz(this._formData);\n   161→    if (!validation.valid) { this._formError = validation.error; return; }\n   162→\n   163→    this._saving = true;\n   164→    let result;\n   165→    if (this._editingId) {\n   166→      result = await updateQuiz(this._editingId, {\n   167→        title: this._formData.title.trim(),\n   168→        moduleId: this._formData.moduleId,\n   169→        lessonId: this._formData.lessonId || '',\n   170→        questions: this._formData.questions,\n   171→      });\n   172→    } else {\n   173→      result = await createQuiz(this._formData);\n   174→    }\n   175→    this._saving = false;\n   176→    if (result.success) { this._closeForm(); await this._loadQuizzes(); } else { this._formError = result.error; }\n   177→  }\n   178→\n   179→  async _handleDelete(quizId) {\n   180→    const result = await deleteQuiz(quizId);\n   181→    if (result.success) await this._loadQuizzes();\n   182→  }\n   183→\n   184→  _exportResponses(quiz) {\n   185→    const questionCount = quiz.questions?.length || 0;\n   186→    const headers = ['Usuario', ...Array.from({ length: questionCount }, (_, i) => `Pregunta ${i + 1}`)];\n   187→    const rows = this._responses.map((r) => [\n   188→      r.userId,\n   189→      ...Array.from({ length: questionCount }, (_, i) => r.answers[i] || ''),\n   190→    ]);\n   191→    const safeName = quiz.title.replace(/[^a-zA-Z0-9]/g, '_').toLowerCase();\n   192→    exportCsv(headers, rows, `quiz_${safeName}.csv`);\n   193→  }\n   194→\n   195→  async _toggleResponses(quizId) {\n   196→    if (this._viewingResponses === quizId) { this._viewingResponses = null; return; }\n   197→    this._viewingResponses = quizId;\n   198→    const result = await getQuizResponses(quizId);\n   199→    this._responses = result.success ? result.responses : [];\n   200→  }\n   201→\n   202→  render() {\n   203→    if (this._loading) return html`<div class=\"loading\"><div class=\"spinner\"></div><p>Cargando quizzes...</p></div>`;\n   204→    if (this._error) return html`<div class=\"error-msg\">${this._error}</div>`;\n   205→\n   206→    return html`\n   207→      ${materialIconsLink}\n   208→      <div class=\"toolbar\">\n   209→        <span>${this._quizzes.length} quiz${this._quizzes.length !== 1 ? 'zes' : ''}</span>\n   210→        <button class=\"btn btn--primary\" @click=${this._openCreate}>\n   211→          <span class=\"material-symbols-outlined\">add</span> Nuevo quiz\n   212→        </button>\n   213→      </div>\n   214→\n   215→      ${this._quizzes.length === 0\n   216→        ? html`<div class=\"empty-state\"><p>No hay quizzes creados</p></div>`\n   217→        : this._quizzes.map((q) => this._renderQuiz(q))}\n   218→\n   219→      ${this._showForm ? this._renderForm() : ''}\n   220→    `;\n   221→  }\n   222→\n   223→  _renderQuiz(q) {\n   224→    const isViewing = this._viewingResponses === q.id;\n   225→    return html`\n   226→      <div class=\"quiz-card\">\n   227→        <div class=\"quiz-header\">\n   228→          <span class=\"quiz-title\">${q.title}</span>\n   229→          <div class=\"quiz-actions\">\n   230→            <button class=\"btn btn--secondary btn--small\" @click=${() => this._openEdit(q)}>Editar</button>\n   231→            <button class=\"btn btn--secondary btn--small\" @click=${() => this._toggleResponses(q.id)}>\n   232→              ${isViewing ? 'Ocultar' : 'Respuestas'}\n   233→            </button>\n   234→            <button class=\"btn btn--danger btn--small\" @click=${() => this._handleDelete(q.id)}>Eliminar</button>\n   235→          </div>\n   236→        </div>\n   237→        <div class=\"quiz-meta\">${q.questions?.length || 0} preguntas · Módulo: ${q.moduleId}</div>\n   238→\n   239→        ${isViewing ? html`\n   240→          <div class=\"responses-panel\">\n   241→            ${this._responses.length > 0 ? html`\n   242→              <div style=\"margin-bottom: 0.75rem;\">\n   243→                <button class=\"btn btn--secondary btn--small\" @click=${() => this._exportResponses(q)}>\n   244→                  <span class=\"material-symbols-outlined\" style=\"font-size: 0.875rem;\">download</span>\n   245→                  Exportar resultados\n   246→                </button>\n   247→              </div>\n   248→            ` : ''}\n   249→            ${this._responses.length === 0\n   250→              ? html`<p class=\"quiz-meta\">Sin respuestas aún</p>`\n   251→              : this._responses.map((r) => html`\n   252→                  <div class=\"response-item\">\n   253→                    <div class=\"response-user\">${r.userId}</div>\n   254→                    ${r.answers.map((a, i) => html`<div class=\"response-answer\"><strong>P${i + 1}:</strong> ${a}</div>`)}\n   255→                  </div>\n   256→                `)}\n   257→          </div>\n   258→        ` : ''}\n   259→      </div>\n   260→    `;\n   261→  }\n   262→\n   263→  _renderForm() {\n   264→    return html`\n   265→      <div class=\"form-overlay\" @click=${this._closeForm}>\n   266→        <div class=\"form-card\" @click=${(e) => e.stopPropagation()}>\n   267→          <h3>${this._editingId ? 'Editar quiz' : 'Nuevo quiz'}</h3>\n   268→          <form @submit=${this._handleSubmit}>\n   269→            <div class=\"form-group\">\n   270→              <label for=\"quiz-title\">Título</label>\n   271→              <input id=\"quiz-title\" name=\"title\" type=\"text\" .value=${this._formData.title} @input=${this._handleInput} required />\n   272→            </div>\n   273→            <div class=\"form-group\">\n   274→              <label for=\"quiz-module\">ID del Módulo</label>\n   275→              <input id=\"quiz-module\" name=\"moduleId\" type=\"text\" .value=${this._formData.moduleId} @input=${this._handleInput} required />\n   276→            </div>\n   277→            <div class=\"form-group\">\n   278→              <label for=\"quiz-lesson\">ID de la Clase (opcional)</label>\n   279→              <input id=\"quiz-lesson\" name=\"lessonId\" type=\"text\" .value=${this._formData.lessonId} @input=${this._handleInput} />\n   280→            </div>\n   281→\n   282→            <h4 style=\"margin: 1rem 0 0.75rem; font-size: 0.875rem; color: #0f172a;\">Preguntas</h4>\n   283→            ${this._formData.questions.map((q, i) => html`\n   284→              <div class=\"question-block\">\n   285→                <div class=\"question-block-header\">\n   286→                  <span class=\"question-number\">Pregunta ${i + 1}</span>\n   287→                  ${this._formData.questions.length > 1 ? html`\n   288→                    <button type=\"button\" class=\"btn btn--danger btn--small\" @click=${() => this._removeQuestion(i)}>Quitar</button>\n   289→                  ` : ''}\n   290→                </div>\n   291→                <div class=\"form-group\">\n   292→                  <input type=\"text\" .value=${q.text} @input=${(e) => this._handleQuestionInput(i, 'text', e.target.value)} placeholder=\"Texto de la pregunta\" required />\n   293→                </div>\n   294→                <div class=\"form-group\">\n   295→                  <select .value=${q.type} @change=${(e) => this._handleQuestionInput(i, 'type', e.target.value)}>\n   296→                    <option value=\"open\">Respuesta abierta</option>\n   297→                    <option value=\"multiple\">Selección múltiple</option>\n   298→                  </select>\n   299→                </div>\n   300→                ${q.type === 'multiple' ? html`\n   301→                  <div class=\"form-group\">\n   302→                    <label>Opciones (una por línea)</label>\n   303→                    <textarea\n   304→                      .value=${(q.options || []).join('\\n')}\n   305→                      @input=${(e) => this._handleQuestionInput(i, 'options', e.target.value.split('\\n').filter(Boolean))}\n   306→                      placeholder=\"Opción A\\nOpción B\\nOpción C\"\n   307→                      rows=\"3\"\n   308→                    ></textarea>\n   309→                  </div>\n   310→                ` : ''}\n   311→              </div>\n   312→            `)}\n   313→\n   314→            <button type=\"button\" class=\"btn btn--secondary\" @click=${this._addQuestion} style=\"margin-bottom: 1rem;\">\n   315→              + Añadir pregunta\n   316→            </button>\n   317→\n   318→            ${this._formError ? html`<div class=\"form-error\">${this._formError}</div>` : ''}\n   319→            <div class=\"form-actions\">\n   320→              <button type=\"button\" class=\"btn btn--secondary\" @click=${this._closeForm}>Cancelar</button>\n   321→              <button type=\"submit\" class=\"btn btn--primary\" ?disabled=${this._saving}>${this._saving ? 'Guardando...' : this._editingId ? 'Guardar' : 'Crear'}</button>\n   322→            </div>\n   323→          </form>\n   324→        </div>\n   325→      </div>\n   326→    `;\n   327→  }\n   328→}\n   329→\n   330→customElements.define('admin-quizzes-list', AdminQuizzesList);\n   331→"}]},"parent_tool_use_id":null,"session_id":"6dab462c-976e-4fe8-a358-d44adb2c1366","uuid":"14546ec6-0a1b-4f67-9693-182360c543d2","tool_use_result":{"type":"text","file":{"filePath":"/home/manu/ws_firebase/manuelearning/src/components/admin-quizzes-list.js","content":"import { LitElement, html, css } from 'lit';\nimport {\n  fetchAllQuizzes,\n  createQuiz,\n  updateQuiz,\n  deleteQuiz,\n  getQuizResponses,\n  validateQuiz,\n} from '../lib/firebase/quizzes.js';\nimport { waitForAuth } from '../lib/auth-ready.js';\nimport { exportCsv } from '../lib/csv-export.js';\nimport { materialIconsLink } from './shared/material-icons.js';\n\n/**\n * @element admin-quizzes-list\n * Admin panel for managing quizzes and viewing responses.\n */\nexport class AdminQuizzesList extends LitElement {\n  static properties = {\n    _quizzes: { type: Array, state: true },\n    _loading: { type: Boolean, state: true },\n    _error: { type: String, state: true },\n    _showForm: { type: Boolean, state: true },\n    _editingId: { type: String, state: true },\n    _formData: { type: Object, state: true },\n    _formError: { type: String, state: true },\n    _saving: { type: Boolean, state: true },\n    _viewingResponses: { type: String, state: true },\n    _responses: { type: Array, state: true },\n  };\n\n  static styles = css`\n    :host { display: block; }\n\n    .toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }\n    .btn { display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.5rem 1rem; border: none; border-radius: 0.5rem; font-size: 0.813rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: background-color 0.15s; }\n    .btn--primary { background: linear-gradient(to right, #84cc16, #fb923c); color: #0f172a; }\n    .btn--primary:hover { background: #d11111; }\n    .btn--secondary { background: #f1f5f9; color: #334155; }\n    .btn--secondary:hover { background: #e2e8f0; }\n    .btn--danger { background: #fef2f2; color: #991b1b; }\n    .btn--danger:hover { background: #fee2e2; }\n    .btn--small { padding: 0.375rem 0.75rem; font-size: 0.75rem; }\n    .btn:disabled { opacity: 0.6; cursor: not-allowed; }\n\n    .quiz-card { background: #fff; border-radius: 0.75rem; padding: 1.25rem; box-shadow: 0 1px 3px rgb(0 0 0 / 0.1); margin-bottom: 1rem; }\n    .quiz-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }\n    .quiz-title { font-size: 1rem; font-weight: 700; color: #0f172a; }\n    .quiz-meta { font-size: 0.813rem; color: #64748b; }\n    .quiz-actions { display: flex; gap: 0.5rem; }\n\n    .responses-panel { border-top: 1px solid #f1f5f9; margin-top: 1rem; padding-top: 1rem; }\n    .response-item { background: #f8fafc; padding: 0.75rem; border-radius: 0.5rem; margin-bottom: 0.5rem; font-size: 0.875rem; }\n    .response-user { font-weight: 600; color: #0f172a; margin-bottom: 0.25rem; }\n    .response-answer { color: #334155; }\n\n    .form-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; z-index: 100; }\n    .form-card { background: #fff; border-radius: 0.75rem; padding: 2rem; width: 100%; max-width: 560px; box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.25); max-height: 90vh; overflow-y: auto; }\n    .form-card h3 { margin: 0 0 1.5rem; font-size: 1.125rem; font-weight: 700; color: #0f172a; }\n    .form-group { margin-bottom: 1rem; }\n    .form-group label { display: block; font-size: 0.813rem; font-weight: 600; color: #334155; margin-bottom: 0.375rem; }\n    .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem; font-family: inherit; box-sizing: border-box; }\n    .form-group input:focus, .form-group textarea:focus { outline: none; border-color: #84cc16; box-shadow: 0 0 0 3px rgba(132,204,22,0.1); }\n    .form-error { color: #991b1b; font-size: 0.813rem; margin-bottom: 1rem; }\n    .form-actions { display: flex; justify-content: flex-end; gap: 0.5rem; margin-top: 1.5rem; }\n\n    .question-block { background: #f8fafc; padding: 1rem; border-radius: 0.5rem; margin-bottom: 0.75rem; border: 1px solid #e2e8f0; }\n    .question-block-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }\n    .question-number { font-size: 0.75rem; font-weight: 700; color: #475569; }\n\n    .loading, .error-msg { text-align: center; padding: 3rem; color: #475569; }\n    .error-msg { color: #991b1b; }\n    .spinner { width: 1.5rem; height: 1.5rem; border: 3px solid #e2e8f0; border-top-color: #84cc16; border-radius: 50%; animation: spin 0.6s linear infinite; margin: 0 auto 0.75rem; }\n    @keyframes spin { to { transform: rotate(360deg); } }\n    .empty-state { text-align: center; padding: 3rem; color: #64748b; }\n  `;\n\n  constructor() {\n    super();\n    this._quizzes = [];\n    this._loading = true;\n    this._error = '';\n    this._showForm = false;\n    this._editingId = null;\n    this._formData = this._emptyForm();\n    this._formError = '';\n    this._saving = false;\n    this._viewingResponses = null;\n    this._responses = [];\n  }\n\n  connectedCallback() {\n    super.connectedCallback();\n    waitForAuth().then(() => this._loadQuizzes());\n  }\n\n  _emptyForm() {\n    return {\n      title: '',\n      moduleId: '',\n      lessonId: '',\n      questions: [{ text: '', type: 'open', options: [] }],\n    };\n  }\n\n  async _loadQuizzes() {\n    this._loading = true;\n    const result = await fetchAllQuizzes();\n    this._loading = false;\n    if (result.success) { this._quizzes = result.quizzes; } else { this._error = result.error; }\n  }\n\n  _openCreate() {\n    this._editingId = null;\n    this._formData = this._emptyForm();\n    this._formError = '';\n    this._showForm = true;\n  }\n\n  _openEdit(quiz) {\n    this._editingId = quiz.id;\n    this._formData = {\n      title: quiz.title || '',\n      moduleId: quiz.moduleId || '',\n      lessonId: quiz.lessonId || '',\n      questions: (quiz.questions || []).map((q) => ({ ...q, options: q.options || [] })),\n    };\n    this._formError = '';\n    this._showForm = true;\n  }\n\n  _closeForm() { this._showForm = false; this._editingId = null; this._formError = ''; }\n\n  _handleInput(e) {\n    const input = /** @type {HTMLInputElement} */ (e.target);\n    this._formData = { ...this._formData, [input.name]: input.value };\n  }\n\n  _handleQuestionInput(index, field, value) {\n    const questions = [...this._formData.questions];\n    questions[index] = { ...questions[index], [field]: value };\n    this._formData = { ...this._formData, questions };\n  }\n\n  _addQuestion() {\n    this._formData = {\n      ...this._formData,\n      questions: [...this._formData.questions, { text: '', type: 'open', options: [] }],\n    };\n  }\n\n  _removeQuestion(index) {\n    const questions = this._formData.questions.filter((_, i) => i !== index);\n    this._formData = { ...this._formData, questions };\n  }\n\n  async _handleSubmit(e) {\n    e.preventDefault();\n    this._formError = '';\n    const validation = validateQuiz(this._formData);\n    if (!validation.valid) { this._formError = validation.error; return; }\n\n    this._saving = true;\n    let result;\n    if (this._editingId) {\n      result = await updateQuiz(this._editingId, {\n        title: this._formData.title.trim(),\n        moduleId: this._formData.moduleId,\n        lessonId: this._formData.lessonId || '',\n        questions: this._formData.questions,\n      });\n    } else {\n      result = await createQuiz(this._formData);\n    }\n    this._saving = false;\n    if (result.success) { this._closeForm(); await this._loadQuizzes(); } else { this._formError = result.error; }\n  }\n\n  async _handleDelete(quizId) {\n    const result = await deleteQuiz(quizId);\n    if (result.success) await this._loadQuizzes();\n  }\n\n  _exportResponses(quiz) {\n    const questionCount = quiz.questions?.length || 0;\n    const headers = ['Usuario', ...Array.from({ length: questionCount }, (_, i) => `Pregunta ${i + 1}`)];\n    const rows = this._responses.map((r) => [\n      r.userId,\n      ...Array.from({ length: questionCount }, (_, i) => r.answers[i] || ''),\n    ]);\n    const safeName = quiz.title.replace(/[^a-zA-Z0-9]/g, '_').toLowerCase();\n    exportCsv(headers, rows, `quiz_${safeName}.csv`);\n  }\n\n  async _toggleResponses(quizId) {\n    if (this._viewingResponses === quizId) { this._viewingResponses = null; return; }\n    this._viewingResponses = quizId;\n    const result = await getQuizResponses(quizId);\n    this._responses = result.success ? result.responses : [];\n  }\n\n  render() {\n    if (this._loading) return html`<div class=\"loading\"><div class=\"spinner\"></div><p>Cargando quizzes...</p></div>`;\n    if (this._error) return html`<div class=\"error-msg\">${this._error}</div>`;\n\n    return html`\n      ${materialIconsLink}\n      <div class=\"toolbar\">\n        <span>${this._quizzes.length} quiz${this._quizzes.length !== 1 ? 'zes' : ''}</span>\n        <button class=\"btn btn--primary\" @click=${this._openCreate}>\n          <span class=\"material-symbols-outlined\">add</span> Nuevo quiz\n        </button>\n      </div>\n\n      ${this._quizzes.length === 0\n        ? html`<div class=\"empty-state\"><p>No hay quizzes creados</p></div>`\n        : this._quizzes.map((q) => this._renderQuiz(q))}\n\n      ${this._showForm ? this._renderForm() : ''}\n    `;\n  }\n\n  _renderQuiz(q) {\n    const isViewing = this._viewingResponses === q.id;\n    return html`\n      <div class=\"quiz-card\">\n        <div class=\"quiz-header\">\n          <span class=\"quiz-title\">${q.title}</span>\n          <div class=\"quiz-actions\">\n            <button class=\"btn btn--secondary btn--small\" @click=${() => this._openEdit(q)}>Editar</button>\n            <button class=\"btn btn--secondary btn--small\" @click=${() => this._toggleResponses(q.id)}>\n              ${isViewing ? 'Ocultar' : 'Respuestas'}\n            </button>\n            <button class=\"btn btn--danger btn--small\" @click=${() => this._handleDelete(q.id)}>Eliminar</button>\n          </div>\n        </div>\n        <div class=\"quiz-meta\">${q.questions?.length || 0} preguntas · Módulo: ${q.moduleId}</div>\n\n        ${isViewing ? html`\n          <div class=\"responses-panel\">\n            ${this._responses.length > 0 ? html`\n              <div style=\"margin-bottom: 0.75rem;\">\n                <button class=\"btn btn--secondary btn--small\" @click=${() => this._exportResponses(q)}>\n                  <span class=\"material-symbols-outlined\" style=\"font-size: 0.875rem;\">download</span>\n                  Exportar resultados\n                </button>\n              </div>\n            ` : ''}\n            ${this._responses.length === 0\n              ? html`<p class=\"quiz-meta\">Sin respuestas aún</p>`\n              : this._responses.map((r) => html`\n                  <div class=\"response-item\">\n                    <div class=\"response-user\">${r.userId}</div>\n                    ${r.answers.map((a, i) => html`<div class=\"response-answer\"><strong>P${i + 1}:</strong> ${a}</div>`)}\n                  </div>\n                `)}\n          </div>\n        ` : ''}\n      </div>\n    `;\n  }\n\n  _renderForm() {\n    return html`\n      <div class=\"form-overlay\" @click=${this._closeForm}>\n        <div class=\"form-card\" @click=${(e) => e.stopPropagation()}>\n          <h3>${this._editingId ? 'Editar quiz' : 'Nuevo quiz'}</h3>\n          <form @submit=${this._handleSubmit}>\n            <div class=\"form-group\">\n              <label for=\"quiz-title\">Título</label>\n              <input id=\"quiz-title\" name=\"title\" type=\"text\" .value=${this._formData.title} @input=${this._handleInput} required />\n            </div>\n            <div class=\"form-group\">\n              <label for=\"quiz-module\">ID del Módulo</label>\n              <input id=\"quiz-module\" name=\"moduleId\" type=\"text\" .value=${this._formData.moduleId} @input=${this._handleInput} required />\n            </div>\n            <div class=\"form-group\">\n              <label for=\"quiz-lesson\">ID de la Clase (opcional)</label>\n              <input id=\"quiz-lesson\" name=\"lessonId\" type=\"text\" .value=${this._formData.lessonId} @input=${this._handleInput} />\n            </div>\n\n            <h4 style=\"margin: 1rem 0 0.75rem; font-size: 0.875rem; color: #0f172a;\">Preguntas</h4>\n            ${this._formData.questions.map((q, i) => html`\n              <div class=\"question-block\">\n                <div class=\"question-block-header\">\n                  <span class=\"question-number\">Pregunta ${i + 1}</span>\n                  ${this._formData.questions.length > 1 ? html`\n                    <button type=\"button\" class=\"btn btn--danger btn--small\" @click=${() => this._removeQuestion(i)}>Quitar</button>\n                  ` : ''}\n                </div>\n                <div class=\"form-group\">\n                  <input type=\"text\" .value=${q.text} @input=${(e) => this._handleQuestionInput(i, 'text', e.target.value)} placeholder=\"Texto de la pregunta\" required />\n                </div>\n                <div class=\"form-group\">\n                  <select .value=${q.type} @change=${(e) => this._handleQuestionInput(i, 'type', e.target.value)}>\n                    <option value=\"open\">Respuesta abierta</option>\n                    <option value=\"multiple\">Selección múltiple</option>\n                  </select>\n                </div>\n                ${q.type === 'multiple' ? html`\n                  <div class=\"form-group\">\n                    <label>Opciones (una por línea)</label>\n                    <textarea\n                      .value=${(q.options || []).join('\\n')}\n                      @input=${(e) => this._handleQuestionInput(i, 'options', e.target.value.split('\\n').filter(Boolean))}\n                      placeholder=\"Opción A\\nOpción B\\nOpción C\"\n                      rows=\"3\"\n                    ></textarea>\n                  </div>\n                ` : ''}\n              </div>\n            `)}\n\n            <button type=\"button\" class=\"btn btn--secondary\" @click=${this._addQuestion} style=\"margin-bottom: 1rem;\">\n              + Añadir pregunta\n            </button>\n\n            ${this._formError ? html`<div class=\"form-error\">${this._formError}</div>` : ''}\n            <div class=\"form-actions\">\n              <button type=\"button\" class=\"btn btn--secondary\" @click=${this._closeForm}>Cancelar</button>\n              <button type=\"submit\" class=\"btn btn--primary\" ?disabled=${this._saving}>${this._saving ? 'Guardando...' : this._editingId ? 'Guardar' : 'Crear'}</button>\n            </div>\n          </form>\n        </div>\n      </div>\n    `;\n  }\n}\n\ncustomElements.define('admin-quizzes-list', AdminQuizzesList);\n","numLines":331,"startLine":1,"totalLines":331}}} (stream=stdout)
