01:20:05.885 [agent:output] [coder] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T8fwogzjvEMwKUBDgyw8dK","type":"tool_result","content":"     1→import {\n     2→  collection,\n     3→  getDocs,\n     4→  doc,\n     5→  getDoc,\n     6→  updateDoc,\n     7→  orderBy,\n     8→  query,\n     9→} from 'firebase/firestore';\n    10→import { db } from './config.js';\n    11→\n    12→/**\n    13→ * @typedef {Object} UserProfile\n    14→ * @property {string} uid\n    15→ * @property {string} email\n    16→ * @property {string} displayName\n    17→ * @property {string} role - 'student' | 'admin'\n    18→ * @property {string} [cohortId]\n    19→ * @property {*} createdAt\n    20→ */\n    21→\n    22→/**\n    23→ * Fetch all users from Firestore.\n    24→ * @returns {Promise<{success: boolean, users?: UserProfile[], error?: string}>}\n    25→ */\n    26→export async function fetchAllUsers() {\n    27→  try {\n    28→    const usersRef = collection(db, 'users');\n    29→    const q = query(usersRef, orderBy('createdAt', 'desc'));\n    30→    const snapshot = await getDocs(q);\n    31→\n    32→    const users = snapshot.docs.map((docSnap) => ({\n    33→      uid: docSnap.id,\n    34→      ...docSnap.data(),\n    35→    }));\n    36→\n    37→    return { success: true, users };\n    38→  } catch (err) {\n    39→    return { success: false, error: 'Error al cargar usuarios' };\n    40→  }\n    41→}\n    42→\n    43→/**\n    44→ * Fetch a single user profile by UID.\n    45→ * @param {string} uid\n    46→ * @returns {Promise<{success: boolean, user?: UserProfile, error?: string}>}\n    47→ */\n    48→export async function fetchUser(uid) {\n    49→  if (!uid) {\n    50→    return { success: false, error: 'UID es obligatorio' };\n    51→  }\n    52→\n    53→  try {\n    54→    const userRef = doc(db, 'users', uid);\n    55→    const docSnap = await getDoc(userRef);\n    56→\n    57→    if (!docSnap.exists()) {\n    58→      return { success: false, error: 'Usuario no encontrado' };\n    59→    }\n    60→\n    61→    return { success: true, user: { uid: docSnap.id, ...docSnap.data() } };\n    62→  } catch (err) {\n    63→    return { success: false, error: 'Error al cargar el usuario' };\n    64→  }\n    65→}\n    66→\n    67→/**\n    68→ * Update a user's role.\n    69→ * @param {string} uid\n    70→ * @param {string} role - 'student' | 'admin'\n    71→ * @returns {Promise<{success: boolean, error?: string}>}\n    72→ */\n    73→export async function updateUserRole(uid, role) {\n    74→  if (!uid) {\n    75→    return { success: false, error: 'UID es obligatorio' };\n    76→  }\n    77→\n    78→  const validRoles = ['student', 'admin'];\n    79→  if (!validRoles.includes(role)) {\n    80→    return { success: false, error: 'Rol no válido. Usa student o admin' };\n    81→  }\n    82→\n    83→  try {\n    84→    const userRef = doc(db, 'users', uid);\n    85→    await updateDoc(userRef, { role });\n    86→    return { success: true };\n    87→  } catch (err) {\n    88→    return { success: false, error: 'Error al actualizar el rol' };\n    89→  }\n    90→}\n    91→\n    92→/**\n    93→ * Toggle lifetime access for a user.\n    94→ * @param {string} uid\n    95→ * @param {boolean} lifetimeAccess\n    96→ * @returns {Promise<{success: boolean, error?: string}>}\n    97→ */\n    98→export async function toggleLifetimeAccess(uid, lifetimeAccess) {\n    99→  if (!uid) return { success: false, error: 'UID es obligatorio' };\n   100→\n   101→  try {\n   102→    const userRef = doc(db, 'users', uid);\n   103→    await updateDoc(userRef, { lifetimeAccess: !!lifetimeAccess });\n   104→    return { success: true };\n   105→  } catch (err) {\n   106→    return { success: false, error: 'Error al actualizar acceso vitalicio' };\n   107→  }\n   108→}\n   109→\n   110→/**\n   111→ * Update a user's display name.\n   112→ * @param {string} uid\n   113→ * @param {string} displayName\n   114→ * @returns {Promise<{success: boolean, error?: string}>}\n   115→ */\n   116→export async function updateUserDisplayName(uid, displayName) {\n   117→  if (!uid) return { success: false, error: 'UID es obligatorio' };\n   118→  if (!displayName || typeof displayName !== 'string' || displayName.trim().length === 0) {\n   119→    return { success: false, error: 'El nombre es obligatorio' };\n   120→  }\n   121→\n   122→  try {\n   123→    const userRef = doc(db, 'users', uid);\n   124→    await updateDoc(userRef, { displayName: displayName.trim() });\n   125→    return { success: true };\n   126→  } catch (err) {\n   127→    return { success: false, error: 'Error al actualizar el nombre' };\n   128→  }\n   129→}\n   130→\n   131→/**\n   132→ * Check if a user has admin role.\n   133→ * @param {string} uid\n   134→ * @returns {Promise<boolean>}\n   135→ */\n   136→export async function isAdmin(uid) {\n   137→  const result = await fetchUser(uid);\n   138→  return result.success && result.user?.role === 'admin';\n   139→}\n   140→"}]},"parent_tool_use_id":"toolu_01JPRvgEcpYxbW6C68j5BjvR","session_id":"7178526a-f4c2-4836-bbb3-d8ca7b58fdc9","uuid":"f368521b-714c-4d78-bd48-f218f6026220"} (stream=stdout)
