  <div class=\"responses-panel\">\n   241→            ${this._responses.length > 0 ? html`\n   242→              <div style=\"margin-bottom: 0.75rem;\">\n   243→                <button class=\"btn btn--secondary btn--small\" @click=${() => this._exportResponses(q)}>\n   244→                  <span class=\"material-symbols-outlined\" style=\"font-size: 0.875rem;\">download</span>\n   245→                  Exportar resultados\n   246→                </button>\n   247→              </div>\n   248→            ` : ''}\n   249→            ${this._responses.length === 0\n   250→              ? html`<p class=\"quiz-meta\">Sin respuestas aún</p>`\n   251→              : this._responses.map((r) => html`\n   252→                  <div class=\"response-item\">\n   253→                    <div class=\"response-user\">${r.userId}</div>\n   254→                    ${r.answers.map((a, i) => html`<div class=\"response-answer\"><strong>P${i + 1}:</strong> ${a}</div>`)}\n   255→                  </div>\n   256→                `)}\n   257→          </div>\n   258→        ` : ''}\n   259→      </div>\n   260→    `;\n   261→  }\n   262→\n   263→  _renderForm() {\n   264→    return html`\n   265→      <div class=\"form-overlay\" @click=${this._closeForm}>\n   266→        <div class=\"form-card\" @click=${(e) => e.stopPropagation()}>\n   267→          <h3>${this._editingId ? 'Editar quiz' : 'Nuevo quiz'}</h3>\n   268→          <form @submit=${this._handleSubmit}>\n   269→            <div class=\"form-group\">\n   270→              <label for=\"quiz-title\">Título</label>\n   271→              <input id=\"quiz-title\" name=\"title\" type=\"text\" .value=${this._formData.title} @input=${this._handleInput} required />\n   272→            </div>\n   273→            <div class=\"form-group\">\n   274→              <label for=\"quiz-module\">ID del Módulo</label>\n   275→              <input id=\"quiz-module\" name=\"moduleId\" type=\"text\" .value=${this._formData.moduleId} @input=${this._handleInput} required />\n   276→            </div>\n   277→            <div class=\"form-group\">\n   278→              <label for=\"quiz-lesson\">ID de la Clase (opcional)</label>\n   279→              <input id=\"quiz-lesson\" name=\"lessonId\" type=\"text\" .value=${this._formData.lessonId} @input=${this._handleInput} />\n   280→            </div>\n   281→\n   282→            <h4 style=\"margin: 1rem 0 0.75rem; font-size: 0.875rem; color: #0f172a;\">Preguntas</h4>\n   283→            ${this._formData.questions.map((q, i) => html`\n   284→              <div class=\"question-block\">\n   285→                <div class=\"question-block-header\">\n   286→                  <span class=\"question-number\">Pregunta ${i + 1}</span>\n   287→                  ${this._formData.questions.length > 1 ? html`\n   288→                    <button type=\"button\" class=\"btn btn--danger btn--small\" @click=${() => this._removeQuestion(i)}>Quitar</button>\n   289→                  ` : ''}\n   290→                </div>\n   291→                <div class=\"form-group\">\n   292→                  <input type=\"text\" .value=${q.text} @input=${(e) => this._handleQuestionInput(i, 'text', e.target.value)} placeholder=\"Texto de la pregunta\" required />\n   293→                </div>\n   294→                <div class=\"form-group\">\n   295→                  <select .value=${q.type} @change=${(e) => this._handleQuestionInput(i, 'type', e.target.value)}>\n   296→                    <option value=\"open\">Respuesta abierta</option>\n   297→                    <option value=\"multiple\">Selección múltiple</option>\n   298→                  </select>\n   299→                </div>\n   300→                ${q.type === 'multiple' ? html`\n   301→                  <div class=\"form-group\">\n   302→                    <label>Opciones (una por línea)</label>\n   303→                    <textarea\n   304→                      .value=${(q.options || []).join('\\n')}\n   305→                      @input=${(e) => this._handleQuestionInput(i, 'options', e.target.value.split('\\n').filter(Boolean))}\n   306→                      placeholder=\"Opción A\\nOpción B\\nOpción C\"\n   307→                      rows=\"3\"\n   308→                    ></textarea>\n   309→                  </div>\n   310→                ` : ''}\n   311→              </div>\n   312→            `)}\n   313→\n   314→            <button type=\"button\" class=\"btn btn--secondary\" @click=${this._addQuestion} style=\"margin-bottom: 1rem;\">\n   315→              + Añadir pregunta\n   316→            </button>\n   317→\n   318→            ${this._formError ? html`<div class=\"form-error\">${this._formError}</div>` : ''}\n   319→            <div class=\"form-actions\">\n   320→              <button type=\"button\" class=\"btn btn--secondary\" @click=${this._closeForm}>Cancelar</button>\n   321→              <button type=\"submit\" class=\"btn btn--primary\" ?disabled=${this._saving}>${this._saving ? 'Guardando...' : this._editingId ? 'Guardar' : 'Crear'}</button>\n   322→            </div>\n   323→          </form>\n   324→        </div>\n   325→      </div>\n   326→    `;\n   327→  }\n   328→}\n   329→\n   330→customElements.define('admin-quizzes-list', AdminQuizzesList);\n   331→"}]},"parent_tool_use_id":"toolu_01LnPPFjoXmnspzsy4vtQ17s","session_id":"bdd0c713-236c-4c4b-91a1-64825901815d","uuid":"171ddf87-72ee-40e7-b7bd-19272591ce5b"} (stream=stdout)
