9→      title: '',\n   100→      moduleId: '',\n   101→      lessonId: '',\n   102→      questions: [{ text: '', type: 'open', options: [] }],\n   103→    };\n   104→  }\n   105→\n   106→  async _loadQuizzes() {\n   107→    this._loading = true;\n   108→    const result = await fetchAllQuizzes();\n   109→    this._loading = false;\n   110→    if (result.success) { this._quizzes = result.quizzes; } else { this._error = result.error; }\n   111→  }\n   112→\n   113→  _openCreate() {\n   114→    this._editingId = null;\n   115→    this._formData = this._emptyForm();\n   116→    this._formError = '';\n   117→    this._showForm = true;\n   118→  }\n   119→\n   120→  _openEdit(quiz) {\n   121→    this._editingId = quiz.id;\n   122→    this._formData = {\n   123→      title: quiz.title || '',\n   124→      moduleId: quiz.moduleId || '',\n   125→      lessonId: quiz.lessonId || '',\n   126→      questions: (quiz.questions || []).map((q) => ({ ...q, options: q.options || [] })),\n   127→    };\n   128→    this._formError = '';\n   129→    this._showForm = true;\n   130→  }\n   131→\n   132→  _closeForm() { this._showForm = false; this._editingId = null; this._formError = ''; }\n   133→\n   134→  _handleInput(e) {\n   135→    const input = /** @type {HTMLInputElement} */ (e.target);\n   136→    this._formData = { ...this._formData, [input.name]: input.value };\n   137→  }\n   138→\n   139→  _handleQuestionInput(index, field, value) {\n   140→    const questions = [...this._formData.questions];\n   141→    questions[index] = { ...questions[index], [field]: value };\n   142→    this._formData = { ...this._formData, questions };\n   143→  }\n   144→\n   145→  _addQuestion() {\n   146→    this._formData = {\n   147→      ...this._formData,\n   148→      questions: [...this._formData.questions, { text: '', type: 'open', options: [] }],\n   149→    };\n   150→  }\n   151→\n   152→  _removeQuestion(index) {\n   153→    const questions = this._formData.questions.filter((_, i) => i !== index);\n   154→    this._formData = { ...this._formData, questions };\n   155→  }\n   156→\n   157→  async _handleSubmit(e) {\n   158→    e.preventDefault();\n   159→    this._formError = '';\n   160→    const validation = validateQuiz(this._formData);\n   161→    if (!validation.valid) { this._formError = validation.error; return; }\n   162→\n   163→    this._saving = true;\n   164→    let result;\n   165→    if (this._editingId) {\n   166→      result = await updateQuiz(this._editingId, {\n   167→        title: this._formData.title.trim(),\n   168→        moduleId: this._formData.moduleId,\n   169→        lessonId: this._formData.lessonId || '',\n   170→        questions: this._formData.questions,\n   171→      });\n   172→    } else {\n   173→      result = await createQuiz(this._formData);\n   174→    }\n   175→    this._saving = false;\n   176→    if (result.success) { this._closeForm(); await this._loadQuizzes(); } else { this._formError = result.error; }\n   177→  }\n   178→\n   179→  async _handleDelete(quizId) {\n   180→    const result = await deleteQuiz(quizId);\n   181→    if (result.success) await this._loadQuizzes();\n   182→  }\n   183→\n   184→  _exportResponses(quiz) {\n   185→    const questionCount = quiz.questions?.length || 0;\n   186→    const headers = ['Usuario', ...Array.from({ length: questionCount }, (_, i) => `Pregunta ${i + 1}`)];\n   187→    const rows = this._responses.map((r) => [\n   188→      r.userId,\n   189→      ...Array.from({ length: questionCount }, (_, i) => r.answers[i] || ''),\n   190→    ]);\n   191→    const safeName = quiz.title.replace(/[^a-zA-Z0-9]/g, '_').toLowerCase();\n   192→    exportCsv(headers, rows, `quiz_${safeName}.csv`);\n   193→  }\n   194→\n   195→  async _toggleResponses(quizId) {\n   196→    if (this._viewingResponses === quizId) { this._viewingResponses = null; return; }\n   197→    this._viewingResponses = quizId;\n   198→    const result = await getQuizResponses(quizId);\n   199→    this._responses