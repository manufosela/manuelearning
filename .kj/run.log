t = await submitQuizResponse('u1', 'q1', ['answer1', 'answer2']);\n   205→    expect(result.success).toBe(true);\n   206→    expect(result.id).toBe('resp-1');\n   207→  });\n   208→\n   209→  it('should handle errors', async () => {\n   210→    mockAddDoc.mockRejectedValue(new Error('err'));\n   211→    expect((await submitQuizResponse('u1', 'q1', ['a'])).success).toBe(false);\n   212→  });\n   213→});\n   214→\n   215→/* ── getUserQuizResponse ────────────────────────────────────── */\n   216→describe('getUserQuizResponse', () => {\n   217→  beforeEach(() => vi.clearAllMocks());\n   218→\n   219→  it('should reject empty params', async () => {\n   220→    expect((await getUserQuizResponse('', 'q1')).success).toBe(false);\n   221→  });\n   222→\n   223→  it('should return null when no response exists', async () => {\n   224→    mockGetDocs.mockResolvedValue({ docs: [] });\n   225→    const result = await getUserQuizResponse('u1', 'q1');\n   226→    expect(result.success).toBe(true);\n   227→    expect(result.response).toBeNull();\n   228→  });\n   229→\n   230→  it('should return response when exists', async () => {\n   231→    mockGetDocs.mockResolvedValue({\n   232→      docs: [{ id: 'r1', data: () => ({ answers: ['a1'] }) }],\n   233→    });\n   234→    const result = await getUserQuizResponse('u1', 'q1');\n   235→    expect(result.success).toBe(true);\n   236→    expect(result.response.answers).toEqual(['a1']);\n   237→  });\n   238→});\n   239→\n   240→/* ── getQuizResponses ───────────────────────────────────────── */\n   241→describe('getQuizResponses', () => {\n   242→  beforeEach(() => vi.clearAllMocks());\n   243→\n   244→  it('should reject empty quizId', async () => {\n   245→    expect((await getQuizResponses('')).success).toBe(false);\n   246→  });\n   247→\n   248→  it('should return all responses for a quiz', async () => {\n   249→    mockGetDocs.mockResolvedValue({\n   250→      docs: [\n   251→        { id: 'r1', data: () => ({ userId: 'u1', answer