23:43:51.148 [agent:output] [coder] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013eFPSU9WUSTvtia5rTCZmV","type":"tool_result","content":"     1→---\n     2→import MainLayout from '../layouts/MainLayout.astro';\n     3→import { SITE } from '../config/site.config.js';\n     4→---\n     5→\n     6→<MainLayout>\n     7→  <!-- Hero Section -->\n     8→  <section class=\"hero-wrapper\">\n     9→    <div class=\"hero\" style=\"background-image: linear-gradient(to right, #0f172a 0%, #1a2e05 100%), url('/images/hero-background.jpg');\">\n    10→      <div class=\"hero__content\">\n    11→        <div class=\"hero__badge\">\n    12→          <span class=\"material-symbols-outlined\">verified</span>\n    13→          <span>Formación directa, práctica y sin filtros</span>\n    14→        </div>\n    15→        <h1 class=\"hero__title\">\n    16→          Aprende tecnología de verdad.\n    17→          <br /><span class=\"hero__title--accent\">Sin rodeos.</span>\n    18→        </h1>\n    19→        <p class=\"hero__description\">\n    20→          Plataforma de formación online de Mánu Fosela — cursos prácticos de desarrollo web, Docker y más, para quien quiera aprender con quien ya lo ha vivido.\n    21→        </p>\n    22→        <div class=\"hero__actions\">\n    23→          <a href=\"/cursos\" class=\"btn btn--primary btn--lg hero__btn-white\">Ver cursos disponibles</a>\n    24→        </div>\n    25→      </div>\n    26→    </div>\n    27→  </section>\n    28→\n    29→  <!-- Services Section -->\n    30→  <section class=\"services\" id=\"services\">\n    31→    <div class=\"services__header\">\n    32→      <h2 class=\"section-label\">Cursos</h2>\n    33→      <h3 class=\"section-title\">¿Qué cursos ofrezco?</h3>\n    34→      <div class=\"section-divider\"></div>\n    35→    </div>\n    36→    <div class=\"services__grid\">\n    37→      <article class=\"service-card\">\n    38→        <div class=\"service-card__icon\">\n    39→          <span class=\"material-symbols-outlined\">deployed_code</span>\n    40→        </div>\n    41→        <h4 class=\"service-card__title\">Docker desde cero</h4>\n    42→        <p class=\"service-card__text\">Contenedores, imágenes, volúmenes, redes y docker-compose. Del \"funciona en mi máquina\" al despliegue real.</p>\n    43→      </article>\n    44→      <article class=\"service-card\">\n    45→        <div class=\"service-card__icon\">\n    46→          <span class=\"material-symbols-outlined\">code</span>\n    47→        </div>\n    48→        <h4 class=\"service-card__title\">JavaScript moderno</h4>\n    49→        <p class=\"service-card__text\">Fundamentos sólidos, DOM, fetch, promesas y patrones reales. El JS que se usa, no el de los libros.</p>\n    50→      </article>\n    51→      <article class=\"service-card\">\n    52→        <div class=\"service-card__icon\">\n    53→          <span class=\"material-symbols-outlined\">directions_car</span>\n    54→        </div>\n    55→        <h4 class=\"service-card__title\">Aprende a conducir</h4>\n    56→        <p class=\"service-card__text\">Teoría, señales, maniobras y test de práctica. Todo lo que necesitas para sacarte el carné.</p>\n    57→      </article>\n    58→    </div>\n    59→  </section>\n    60→\n    61→  <!-- Why Lean Section -->\n    62→  <section class=\"why-lean\" id=\"why-lean\">\n    63→    <div class=\"why-lean__grid\">\n    64→      <div class=\"why-lean__image-wrapper\">\n    65→        <div class=\"why-lean__image\">\n    66→          <img src=\"/images/engineer-tablet.jpg\" alt=\"Profesional de construcción revisando planos digitales en una tablet\" />\n    67→        </div>\n    68→        <div class=\"why-lean__stats\">\n    69→          <div class=\"why-lean__stat\">\n    70→            <p class=\"why-lean__stat-number\">+25</p>\n    71→            <p class=\"why-lean__stat-label\">desarrollando software</p>\n    72→          </div>\n    73→          <div class=\"why-lean__stat\">\n    74→            <p class=\"why-lean__stat-number\">+15</p>\n    75→            <p class=\"why-lean__stat-label\">mentorizando juniors</p>\n    76→          </div>\n    77→          <div class=\"why-lean__stat\">\n    78→            <p class=\"why-lean__stat-number\">+10</p>\n    79→            <p class=\"why-lean__stat-label\">liderando equipos</p>\n    80→          </div>\n    81→        </div>\n    82→      </div>\n    83→      <div class=\"why-lean__content\">\n    84→        <h2 class=\"section-label\">¿Para quién es esto?</h2>\n    85→        <h3 class=\"why-lean__title\">Para quien quiere aprender con alguien de verdad</h3>\n    86→        <p class=\"why-lean__description\">\n    87→          Esta plataforma no es un marketplace ni una academia masiva. Es un espacio de formación personal donde comparto lo que sé con personas a las que conozco o que me conocen. Si estás empezando en el mundo del desarrollo, si quieres entender Docker de una vez, o si buscas algo más cercano que un tutorial de YouTube — puede que estés en el sitio correcto.\n    88→        </p>\n    89→        <ul class=\"why-lean__features\">\n    90→          <li>\n    91→            <span class=\"material-symbols-outlined\">check_circle</span>\n    92→            <span>Acceso solo por invitación — aprendes con contexto y sin ruido</span>\n    93→          </li>\n    94→          <li>\n    95→            <span class=\"material-symbols-outlined\">check_circle</span>\n    96→            <span>Cursos basados en proyectos reales, no en ejemplos de juguete</span>\n    97→          </li>\n    98→          <li>\n    99→            <span class=\"material-symbols-outlined\">check_circle</span>\n   100→            <span>Soporte directo — puedes preguntarme a mí</span>\n   101→          </li>\n   102→        </ul>\n   103→        <a href=\"/solicitar-acceso\" class=\"btn btn--primary btn--md\" id=\"cta-access\">Solicitar acceso</a>\n   104→      </div>\n   105→    </div>\n   106→  </section>\n   107→\n   108→</MainLayout>\n   109→\n   110→<script>\n   111→  import { onAuthChange } from '../lib/firebase/auth.js';\n   112→\n   113→  const ctaBtn = document.getElementById('cta-access');\n   114→  if (ctaBtn) {\n   115→    onAuthChange((user) => {\n   116→      if (user) {\n   117→        ctaBtn.href = '/cursos';\n   118→        ctaBtn.textContent = 'Ir a mis cursos';\n   119→      }\n   120→    });\n   121→  }\n   122→</script>\n   123→\n   124→<style>\n   125→  /* --- Hero --- */\n   126→  .hero-wrapper {\n   127→    padding: 2rem var(--section-px);\n   128→  }\n   129→\n   130→  .hero {\n   131→    position: relative;\n   132→    min-height: 560px;\n   133→    display: flex;\n   134→    flex-direction: column;\n   135→    align-items: flex-start;\n   136→    justify-content: center;\n   137→    overflow: hidden;\n   138→    border-radius: var(--radius-xl);\n   139→    padding: 2rem;\n   140→    background-size: cover;\n   141→    background-position: center;\n   142→  }\n   143→\n   144→  @media (min-width: 768px) {\n   145→    .hero {\n   146→      padding: 2rem 4rem;\n   147→    }\n   148→  }\n   149→\n   150→  .hero__content {\n   151→    max-width: 720px;\n   152→    display: flex;\n   153→    flex-direction: column;\n   154→    gap: 1.5rem;\n   155→  }\n   156→\n   157→  .hero__badge {\n   158→    display: inline-flex;\n   159→    align-items: center;\n   160→    gap: 0.5rem;\n   161→    padding: 0.25rem 0.75rem;\n   162→    border-radius: var(--radius-full);\n   163→    background: linear-gradient(to right, rgba(132, 204, 22, 0.15), rgba(251, 146, 60, 0.15));\n   164→    color: var(--color-primary);\n   165→    border: 1px solid rgba(132, 204, 22, 0.3);\n   166→    width: fit-content;\n   167→  }\n   168→\n   169→  .hero__badge span.material-symbols-outlined {\n   170→    font-size: 0.875rem;\n   171→  }\n   172→\n   173→  .hero__badge span:last-child {\n   174→    font-size: 0.75rem;\n   175→    font-weight: 700;\n   176→    text-transform: uppercase;\n   177