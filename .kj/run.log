01:20:12.272 [agent:output] [coder] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C3EUB7SV65YE5UvfPyJWnj","type":"tool_result","content":"     1→import {\n     2→  GoogleAuthProvider,\n     3→  signInWithPopup,\n     4→  signOut,\n     5→  onAuthStateChanged,\n     6→} from 'firebase/auth';\n     7→import { doc, getDoc, setDoc, serverTimestamp } from 'firebase/firestore';\n     8→import { auth, db } from './config.js';\n     9→import { validateInvitationCode, markCodeAsUsed } from './invitation-codes.js';\n    10→\n    11→/**\n    12→ * @typedef {Object} AuthResult\n    13→ * @property {boolean} success\n    14→ * @property {import('firebase/auth').User} [user]\n    15→ * @property {boolean} [isNewUser] - true if the user has no Firestore profile yet\n    16→ * @property {string} [error]\n    17→ */\n    18→\n    19→const googleProvider = new GoogleAuthProvider();\n    20→\n    21→/**\n    22→ * Sign in with Google. If the user has no Firestore profile, returns isNewUser=true\n    23→ * so the caller can request an invitation code before creating the profile.\n    24→ * @returns {Promise<AuthResult>}\n    25→ */\n    26→export async function loginWithGoogle() {\n    27→  try {\n    28→    const credential = await signInWithPopup(auth, googleProvider);\n    29→    const user = credential.user;\n    30→\n    31→    const userDoc = await getDoc(doc(db, 'users', user.uid));\n    32→    if (userDoc.exists()) {\n    33→      return { success: true, user, isNewUser: false };\n    34→    }\n    35→\n    36→    return { success: true, user, isNewUser: true };\n    37→  } catch (err) {\n    38→    return { success: false, error: mapFirebaseError(err.code) };\n    39→  }\n    40→}\n    41→\n    42→/**\n    43→ * Complete registration for a new Google user by validating the invitation code\n    44→ * and creating their Firestore profile.\n    45→ * @param {import('firebase/auth').User} user\n    46→ * @param {string} invitationCode\n    47→ * @returns {Promise<AuthResult>}\n    48→ */\n    49→export async function completeRegistration(user, invitationCode) {\n    50→  if (!user) {\n    51→    return { success: false, error: 'Usuario no autenticado' };\n    52→  }\n    53→\n    54→  if (!invitationCode || invitationCode.trim().length === 0) {\n    55→    return { success: false, error: 'El codigo de invitacion es obligatorio' };\n    56→  }\n    57→\n    58→  const codeValidation = await validateInvitationCode(invitationCode);\n    59→  if (!codeValidation.valid) {\n    60→    return { success: false, error: codeValidation.error };\n    61→  }\n    62→\n    63→  try {\n    64→    await setDoc(doc(db, 'users', user.uid), {\n    65→      email: user.email,\n    66→      displayName: user.displayName || '',\n    67→      role: 'student',\n    68→      cohortId: codeValidation.cohortId,\n    69→      createdAt: serverTimestamp(),\n    70→    });\n    71→\n    72→    await markCodeAsUsed(codeValidation.docId);\n    73→\n    74→    return { success: true, user };\n    75→  } catch (err) {\n    76→    return { success: false, error: mapFirebaseError(err.code) };\n    77→  }\n    78→}\n    79→\n    80→/**\n    81→ * Sign out the current user.\n    82→ * @returns {Promise<AuthResult>}\n    83→ */\n    84→export async function logoutUser() {\n    85→  try {\n    86→    await signOut(auth);\n    87→    return { success: true };\n    88→  } catch (err) {\n    89→    return { success: false, error: err.message };\n    90→  }\n    91→}\n    92→\n    93→/**\n    94→ * Subscribe to auth state changes.\n    95→ * @param {function(import('firebase/auth').User|null): void} callback\n    96→ * @returns {function(): void} Unsubscribe function\n    97→ */\n    98→export function onAuthChange(callback) {\n    99→  return onAuthStateChanged(auth, callback);\n   100→}\n   101→\n   102→/**\n   103→ * Get the currently authenticated user.\n   104→ * @returns {import('firebase/auth').User|null}\n   105→ */\n   106→export function getCurrentUser() {\n   107→  return auth.currentUser;\n   108→}\n   109→\n   110→/**\n   111→ * Map Firebase error codes to user-friendly messages.\n   112→ * @param {string} code\n   113→ * @returns {string}\n   114→ */\n   115→export function mapFirebaseError(code) {\n   116→  const errors = {\n   117→    'auth/popup-closed-by-user': 'Se cerro la ventana de inicio de sesion',\n   118→    'auth/popup-blocked': 'El navegador bloqueo la ventana emergente. Permite pop-ups e intenta de nuevo',\n   119→    'auth/cancelled-popup-request': 'Se cancelo la solicitud de inicio de sesion',\n   120→    'auth/account-exists-with-different-credential': 'Ya existe una cuenta con este email usando otro metodo',\n   121→    'auth/too-many-requests': 'Demasiados intentos. Intenta mas tarde',\n   122→  };\n   123→\n   124→  return errors[code] || 'Error de autenticacion. Intenta de nuevo';\n   125→}\n   126→"}]},"parent_tool_use_id":"toolu_01JPRvgEcpYxbW6C68j5BjvR","session_id":"7178526a-f4c2-4836-bbb3-d8ca7b58fdc9","uuid":"c0396c77-446b-45ab-953b-2aa07d4933a6"} (stream=stdout)
