 this._loading = true;\n   443→    this._error = '';\n   444→    const result = await fetchAllModules();\n   445→    this._loading = false;\n   446→    if (result.success) {\n   447→      this._modules = result.modules;\n   448→    } else {\n   449→      this._error = result.error;\n   450→    }\n   451→  }\n   452→\n   453→  async _toggleExpand(moduleId) {\n   454→    if (this._expandedModule === moduleId) {\n   455→      this._expandedModule = null;\n   456→      return;\n   457→    }\n   458→    this._expandedModule = moduleId;\n   459→    if (!this._moduleLessons[moduleId]) {\n   460→      const result = await fetchLessons(moduleId);\n   461→      if (result.success) {\n   462→        this._moduleLessons = { ...this._moduleLessons, [moduleId]: result.lessons };\n   463→      }\n   464→    }\n   465→  }\n   466→\n   467→  /* ── Module form ───── */\n   468→\n   469→  _openCreateModule() {\n   470→    this._editingModuleId = null;\n   471→    this._moduleFormData = { ...this._emptyModuleForm(), order: this._modules.length + 1 };\n   472→    this._moduleFormError = '';\n   473→    this._showModuleForm = true;\n   474→  }\n   475→\n   476→  _openEditModule(mod) {\n   477→    this._editingModuleId = mod.id;\n   478→    this._moduleFormData = { title: mod.title, description: mod.description || '', order: mod.order };\n   479→    this._moduleFormError = '';\n   480→    this._showModuleForm = true;\n   481→  }\n   482→\n   483→  _closeModuleForm() {\n   484→    this._showModuleForm = false;\n   485→    this._editingModuleId = null;\n   486→    this._moduleFormError = '';\n   487→  }\n   488→\n   489→  _handleModuleInput(e) {\n   490→    const input = /** @type {HTMLInputElement} */ (e.target);\n   491→    const value = input.name === 'order' ? parseInt(input.value, 10) || 0 : input.value;\n   492→    this._moduleFormData = { ...this._moduleFormData, [input.name]: value };\n   493→  }\n   494→\n   495→  async _handleModuleSubmit(e) {\n   496→    e.preventDefault();\n   497→    this._moduleFormError = '';\n   498→\n   499→    const validation = validateModule(this._moduleFormData);\n   500→    if (!validation.valid) {\n   501→      this._moduleFormError = validation.error;\n   502→      return;\n   503→    }\n   504→\n   505→    this._saving = true;\n   506→\n   507→    if (this._editingModuleId) {\n   508→      const result = await updateModule(this._editingModuleId, this._moduleFormData);\n   509→      this._saving = false;\n   510→      if (result.success) {\n   511→        this._closeModuleForm();\n   512→        await this._loadModules();\n   513→      } else {\n   514→        this._moduleFormError = result.error;\n   515→      }\n   516→    } else {\n   517→      const result = await createModule(this._moduleFormData);\n   518→      this._saving = false;\n   519→      if (result.success) {\n   520→        if (this._notifyStudents) {\n   521→          this._sendModuleNotification(this._moduleFormData.title);\n   522→        }\n   523→        this._closeModuleForm();\n   524→        await this._loadModules();\n   525→      } else {\n   526→        this._moduleFormError = result.error;\n   527→      }\n   528→    }\n   529→  }\n   530→\n   531→  async _sendModuleNotification(moduleTitle) {\n   532→    const usersResult = await fetchAllUsers();\n   533→    if (!usersResult.success) return;\n   534→    const studentIds = usersResult.users\n   535→      .filter((u) => u.role === 'student')\n   536→      .map((u) => u.uid);\n   537→    if (studentIds.length === 0) return;\n   538→    await notifyUsers(studentIds, {\n   539→      type: 'new_module',\n   540→      message: `Nuevo módulo disponible: ${moduleTitle}`,\n   541→    });\n   542→  }\n   543→\n   544→  async _handleDeleteModule(mod) {\n   545→    const result = await deleteModule(mod.id);\n   546→    if (result.success) {\n   547→      await this._loadModules();\n   548→      if (this._expandedModule === mod.id) this._expandedModule = null;\n   549→    }\n   550→  }\n   551→\n   552→  /* ── Reordering ───── */\n   553→\n   554→  async _moveModule(moduleId, direction) {\n   555→    const result = await reorderModule(this._modules, moduleId, direction);\n   556→    if (result.success) await this._loadModules();\n   557→  }\n   558→\n   559→  async _moveLesson(moduleId, lessonId, direction) {\n   560→    const lessons = this._moduleLessons[moduleId] || [];\n   561→    const result = await reorderLesson(moduleId, lessons, lessonId, direction);\n   562→    if (result.success) {\n   563→      const res = await fetchLessons(moduleId);\n   564→      if (res.success) this._moduleLessons = { ...this._moduleLessons, [moduleId]: res.lessons };\n   565→    }\n   566→  }\n   567→\n   568→  /* ── Lesson form ───── */\n   569→\n   570→  _openCreateLesson(moduleId) {\n   571→    this._lessonFormModuleId = moduleId;\n   572→    this._editingLessonId = null;\n   573→    const lessons = this._moduleLessons[moduleId] || [];\n   574→    this._lessonFormData = { ...this._emptyLessonForm(), order: lessons.length + 1 };\n   575→    this._lessonFormError = '';\n   576→    this._showLessonForm = true;\n   577→  }\n   578→\n   579→  _openEditLesson(moduleId, lesson) {\n   580→    this._lessonFormModuleId = moduleId;\n   581→    this._editingLessonId = lesson.id;\n   582→    this._lessonFormData = {\n   583→      title: lesson.title,\n   584→      description: lesson.description || '',\n   585→      order: lesson.order,\n   586→      videoUrl: lesson.videoUrl || '',\n   587→      documentation: lesson.documentation || '',\n   588→    };\n   589→    this._lessonFormError = '';\n   590→    this._showLessonForm = true;\n   591→  }\n   592→\n   593→  _closeLessonForm() {\n   594→    this._showLessonForm = false;\n   595→    this._editingLessonId = null;\n   596→    this._lessonFormModuleId = null;\n   597→    this._lessonFormError = '';\n   598→  }\n   599→\n   600→  _handleLessonInput(e) {\n   601→    const input = /** @type {HTMLInputElement|HTMLTextAreaElement} */ (e.target);\n   602→    const value = input.name === 'order' ? parseInt(input.value, 10) || 0 : input.value;\n   603→    this._lessonFormData = { ...this._lessonFormData, [input.name]: value };\n   604→  }\n   605→\n   606→  async _handleLessonSubmit(e) {\n   607→    e.preventDefault();\n   608→    this._lessonFormError = '';\n   609→\n   610→    const validation = validateLesson(this._lessonFormData);\n   611→    if (!validation.valid) {\n   612→      this._lessonFormError = validation.error;\n   613→      return;\n   614→    }\n   615→\n   616→    this._saving = true;\n   617→    const mid = this._lessonFormModuleId;\n   618→\n   619→    if (this._editingLessonId) {\n   620→      const result = await updateLesson(mid, this._editingLessonId, this._lessonFormData);\n   621→      this._saving = false;\n   622→      if (result.success) {\n   623→        this._closeLessonForm();\n   624→        const res = await fetchLessons(mid);\n   625→        if (res.success) this._moduleLessons = { ...this._moduleLessons, [mid]: res.lessons };\n   626→      } else {\n   627→        this._lessonFormError = result.error;\n   628→      }\n   629→    } else {\n   630→      const result = await createLesson(mid, this._lessonFormData);\n   631→      this._saving = false;\n   632→      if (result.success) {\n   633→        this._closeLessonForm();\n   634→        const res = await fetchLessons(mid);\n   635→        if (res.success) this._moduleLessons = { ...this._moduleLessons, [mid]: res.lessons };\n   636→      } else {\n   637→        this._lessonFormError = result.error;\n   638→      }\n   639→    }\n   640→  }\n   641→\n   642→  async _handleDeleteLesson(moduleId, lessonId) {\n   643→    const result = await deleteLesson(moduleId, lessonId);\n   644→    if (result.success) {\n   645→      const res = await fetchLessons(moduleId);\n   646→      if (res.success) this._moduleLessons = { ...this._moduleLessons, [moduleId]: res.lessons };\n   647→    }\n   648→  }\n   649→\n   650→  /* ── Render ───── */\n   651→\n   652→  render() {\n   653→    if (this._loading) {\n   654→      return html`<div class=\"loading\"><div class=\"spinner\"></div><p>Cargando módulos...</p></div>`;\n   655→    }\n   656→\n   657→    if (this._error) {\n   658→      return html`<div class=\"error-msg\">${this._error}</div>`;\n   659→    }\n   660→\n   661→    const filtered = filterBySearch(this._modules, ['title', 'description'], this._searchQuery);\n   662→\n   663→    return html`\n   664→      ${materialIconsLink}\n   665→      <div class=\"toolbar\">\n   666→        <span>${this._modules.length} módulo${this._modules.length !== 1 ? 's' : ''}</span>\n   667→        <button class=\"btn btn--primary\" @click=${this._openCreateModule}>\n   668→          <span class=\"material-symbols-outlined\">add</span>\n   669→          Nuevo módulo\n   670→        </button>\n   671→      </div>\n   672→\n   673→      <input\n   674→        class=\"search-input\"\n   675→        type=\"text\"\n   676→        placeholder=\"Buscar módulos...\"\n   677→        .value=${this._searchQuery}\n   678→        @input=${(e) => { this._searchQuery = e.target.value; }}\n   679→      />\n   680→\n   681→      ${this._modules.length === 0\n   682→        ? html`<div class=\"empty-state\"><span class=\"material-symbols-outlined\">menu_book</span><p>No hay módulos creados</p></div>`\n   683→        : filtered.length === 0\n   684→          ? html`<div class=\"no-results\">Sin resultados. Prueba con otro término de búsqueda.</div>`\n   685→          : filtered.map((mod) => this._renderModule(mod))}\n   686→\n   687→      ${this._showModuleForm ? this._renderModuleForm() : ''}\n   688→      ${this._showLessonForm ? this._renderLessonForm() : ''}\n   689→    `;\n   690→  }\n   691→\n   692→  _renderModule(mod) {\n   693→    const isExpanded = this._expandedModule === mod.id;\n   694→    const lessons = this._moduleLessons[mod.id] || [];\n   695→    const modIndex = this._modules.findIndex((m) => m.id === mod.id);\n   696→    const isFirst = modIndex === 0;\n   697→    const isLast = modIndex === this._modules.length - 1;\n   698→\n   699→    return html`\n   700→      <div class=\"module-card\">\n   701→        <div class=\"module-header\" @click=${() => this._toggleExpand(mod.id)}>\n   702→          <div class=\"module-info\">\n   703→            <div class=\"reorder-btns\" @click=${(e) => e.stopPropagation()}>\n   704→              <button class=\"reorder-btn\" ?disabled=${isFirst} @click=${() => this._moveModule(mod.id, 'up')} title=\"Mover arriba\">\n   705→                <span class=\"material-symbols-outlined\">keyboard_arrow_up</span>\n   706→              </button>\n   707→              <button class=\"reorder-btn\" ?disabled=${isLast} @click=${() => this._moveModule(mod.id, 'down')} title=\"Mover abajo\">\n   708→                <span class=\"material-symbols-outlined\">keyboard_arrow_down</span>\n   709→              </button>\n   710→            </div>\n   711→            <div class=\"module-order\">${mod.order}</div>\n   712→            <div>\n   713→              <div class=\"module-title\">${mod.title}</div>\n   714→              ${mod.description ? html`<div class=\"module-desc\">${mod.description}</div>` : ''}\n   715→            </div>\n   716→          </div>\n   717→          <div class=\"module-actions\">\n   718→            <button class=\"btn btn--secondary btn--small\" @click=${(e) => { e.stopPropagation(); this._openEditModule(mod); }}>Editar</button>\n   719→            <button class=\"btn btn--danger btn--small\" @click=${(e) => { e.stopPropagation(); this._handleDeleteModule(mod); }}>Eliminar</button>\n   720→            <span class=\"material-symbols-outlined\">${isExpanded ? 'expand_less' : 'expand_more'}</span>\n   721→          </div>\n   722→        </div>\n   723→\n   724→        ${isExpanded ? html`\n   725→          <div class=\"lessons-panel\">\n   726→            <div class=\"lessons-header\">\n   727→              <h4>Clases (${lessons.length})</h4>\n   728→              <button class=\"btn btn--primary btn--small\" @click=${() => this._openCreateLesson(mod.id)}>\n   729→                <span class=\"material-symbols-outlined\">add</span> Clase\n   730→              </button>\n   731→            </div>\n   732→\n   733→            ${lessons.length === 0\n   734→              ? html`<div class=\"no-lessons\">No hay clases en este módulo</div>`\n   735→              : lessons.map((lesson, li) => html`\n   736→                  <div class=\"lesson-item\">\n   737→                    <div class=\"lesson-info\">\n   738→                      <div class=\"reorder-btns\">\n   739→                        <button class=\"reorder-btn\" ?disabled=${li === 0} @click=${() => this._moveLesson(mod.id, lesson.id, 'up')} title=\"Mover arriba\">\n   740→                          <span class=\"material-symbols-outlined\">keyboard_arrow_up</span>\n   741→                        </button>\n   742→                        <button class=\"reorder-btn\" ?disabled=${li === lessons.length - 1} @click=${() => this._moveLesson(mod.id, lesson.id, 'down')} title=\"Mover abajo\">\n   743→                          <span class=\"material-symbols-outlined\">keyboard_arrow_down</span>\n   744→                        </button>\n   745→                      </div>\n   746→                      <div class=\"lesson-order\">${lesson.order}</div>\n   747→                      <div class=\"lesson-title\">${lesson.title}</div>\n   748→                    </div>\n   749→                    <div class=\"lesson-meta\">\n   750→                      <span class=\"lesson-badge ${lesson.videoUrl ? '' : 'lesson-badge--empty'}\">\n   751→                        ${lesson.videoUrl ? 'Video' : 'Sin video'}\n   752→                      </span>\n   753→                      <span class=\"lesson-badge ${lesson.documentation ? '' : 'lesson-badge--empty'}\">\n   754→                        ${lesson.documentation ? 'Docs' : 'Sin docs'}\n   755→                      </span>\n   756→                      <button class=\"btn btn--secondary btn--small\" @click=${() => this._openEditLesson(mod.id, lesson)}>Editar</button>\n   757→                      <button class=\"btn btn--danger btn--small\" @click=${() => this._handleDeleteLesson(mod.id, lesson.id)}>Eliminar</button>\n   758→                    </div>\n   759→                  </div>\n   760→                `)}\n   761→          </div>\n   762→        ` : ''}\n   763→      </div>\n   764→    `;\n   765→  }\n   766→\n   767→  _renderModuleForm() {\n   768→    const title = this._editingModuleId ? 'Editar módulo' : 'Nuevo módulo';\n   769→    return html`\n   770→      <div class=\"form-overlay\" @click=${this._closeModuleForm}>\n   771→        <div class=\"form-card\" @click=${(e) => e.stopPropagation()}>\n   772→          <h3>${title}</h3>\n   773→          <form @submit=${this._handleModuleSubmit}>\n   774→            <div class=\"form-group\">\n   775→              <label for=\"mod-title\">Título</label>\n   776→              <input id=\"mod-title\" name=\"title\" type=\"text\" .value=${this._moduleFormData.title} @input=${this._handleModuleInput} required />\n   777→            </div>\n   778→            <div class=\"form-group\">\n   779→              <label for=\"mod-desc\">Descripción</label>\n   780→              <input id=\"mod-desc\" name=\"description\" type=\"text\" .value=${this._moduleFormData.description} @input=${this._handleModuleInput} />\n   781→            </div>\n   782→            <div class=\"form-group\">\n   783→              <label for=\"mod-order\">Orden</label>\n   784→              <input id=\"mod-order\" name=\"order\" type=\"number\" min=\"0\" .value=${String(this._moduleFormData.order)} @input=${this._handleModuleInput} required />\n   785→            </div>\n   786→            ${!this._editingModuleId ? html`\n   787→              <div class=\"form-check\">\n   788→                <input type=\"checkbox\" id=\"notify-module\" .checked=${this._notifyStudents} @change=${(e) => { this._notifyStudents = e.target.checked; }} />\n   789→                <label for=\"notify-module\">Notificar a los alumnos</label>\n   790→              </div>\n   791→            ` : ''}\n   792→            ${this._moduleFormError ? html`<div class=\"form-error\">${this._moduleFormError}</div>` : ''}\n   793→            <div class=\"form-actions\">\n   794→              <button type=\"button\" class=\"btn btn--secondary\" @click=${this._closeModuleForm}>Cancelar</button>\n   795→              <button type=\"submit\" class=\"btn btn--primary\" ?disabled=${this._saving}>\n   796→                ${this._saving ? 'Guardando...' : this._editingModuleId ? 'Guardar' : 'Crear'}\n   797→              </button>\n   798→            </div>\n   799→          </form>\n   800→        </div>\n   801→      </div>\n   802→    `;\n   803→  }\n   804→\n   805→  _renderLessonForm() {\n   806→    const title = this._editingLessonId ? 'Editar clase' : 'Nueva clase';\n   807→    return html`\n   808→      <div class=\"form-overlay\" @click=${this._closeLessonForm}>\n   809→        <div class=\"form-card\" @click=${(e) => e.stopPropagation()}>\n   810→          <h3>${title}</h3>\n   811→          <form @submit=${this._handleLessonSubmit}>\n   812→            <div class=\"form-group\">\n   813→              <label for=\"les-title\">Título</label>\n   814→              <input id=\"les-title\" name=\"title\" type=\"text\" .value=${this._lessonFormData.title} @input=${this._handleLessonInput} required />\n   815→            </div>\n   816→            <div class=\"form-group\">\n   817→              <label for=\"les-desc\">Descripción</label>\n   818→              <input id=\"les-desc\" name=\"description\" type=\"text\" .value=${this._lessonFormData.description} @input=${this._handleLessonInput} />\n   819→            </div>\n   820→            <div class=\"form-group\">\n   821→              <label for=\"les-order\">Orden</label>\n   822→              <input id=\"les-order\" name=\"order\" type=\"number\" min=\"0\" .value=${String(this._lessonFormData.order)} @input=${this._handleLessonInput} required />\n   823→            </div>\n   824→            <div class=\"form-group\">\n   825→              <label for=\"les-video\">URL de Video (YouTube)</label>\n   826→              <input id=\"les-video\" name=\"videoUrl\" type=\"url\" .value=${this._lessonFormData.videoUrl} @input=${this._handleLessonInput} placeholder=\"https://youtube.com/watch?v=...\" />\n   827→            </div>\n   828→            <div class=\"form-group\">\n   829→              <label for=\"les-docs\">Documentación (Markdown)</label>\n   830→              <textarea id=\"les-docs\" name=\"documentation\" .value=${this._lessonFormData.documentation} @input=${this._handleLessonInput} placeholder=\"# Título de la clase...\"></textarea>\n   831→            </div>\n   832→            ${this._lessonFormError ? html`<div class=\"form-error\">${this._lessonFormError}</div>` : ''}\n   833→            <div class=\"form-actions\">\n   834→              <button type=\"button\" class=\"btn btn--secondary\" @click=${this._closeLessonForm}>Cancelar</button>\n   835→              <button type=\"submit\" class=\"btn btn--primary\" ?disabled=${this._saving}>\n   836→                ${this._saving ? 'Guardando...' : this._editingLessonId ? 'Guardar' : 'Crear'}\n   837→              </button>\n   838→            </div>\n   839→          </form>\n   840→        </div>\n   841→      </div>\n   842→    `;\n   843→  }\n   844→}\n   845→\n   846→customElements.define('admin-modules-list', AdminModulesList);\n   847→"}]},"parent_tool_use_id":"toolu_01PviopKjwtvPxPXj5fcZ46W","session_id":"6dab462c-976e-4fe8-a358-d44adb2c1366","uuid":"6977358b-da13-4600-a3a8-85cfa1a84c22"} (stream=stdout)
