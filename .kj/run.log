01:23:00.387 [agent:output] [coder] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017jRnGU2uf94e14JRbgTz3E","type":"tool_result","content":"     1→import {\n     2→  collection,\n     3→  doc,\n     4→  getDoc,\n     5→  getDocs,\n     6→  addDoc,\n     7→  updateDoc,\n     8→  deleteDoc,\n     9→  query,\n    10→  orderBy,\n    11→  where,\n    12→  serverTimestamp,\n    13→  writeBatch,\n    14→} from 'firebase/firestore';\n    15→import { db } from './config.js';\n    16→import { computeSwap } from '../reorder-utils.js';\n    17→\n    18→const COLLECTION = 'modules';\n    19→\n    20→/**\n    21→ * @typedef {Object} Module\n    22→ * @property {string} [id]\n    23→ * @property {string} title\n    24→ * @property {string} [description]\n    25→ * @property {number} order\n    26→ * @property {*} [createdAt]\n    27→ */\n    28→\n    29→/**\n    30→ * @typedef {Object} Lesson\n    31→ * @property {string} [id]\n    32→ * @property {string} title\n    33→ * @property {string} [description]\n    34→ * @property {number} order\n    35→ * @property {string} [videoUrl]\n    36→ * @property {string} [documentation]\n    37→ * @property {*} [createdAt]\n    38→ */\n    39→\n    40→/**\n    41→ * Validate module data.\n    42→ * @param {Partial<Module>} data\n    43→ * @returns {{ valid: boolean, error?: string }}\n    44→ */\n    45→export function validateModule(data) {\n    46→  if (!data.title || data.title.trim().length === 0) {\n    47→    return { valid: false, error: 'El título es obligatorio' };\n    48→  }\n    49→\n    50→  if (data.order === undefined || data.order === null || typeof data.order !== 'number' || data.order < 0) {\n    51→    return { valid: false, error: 'El orden debe ser un número positivo' };\n    52→  }\n    53→\n    54→  return { valid: true };\n    55→}\n    56→\n    57→/**\n    58→ * Validate lesson data.\n    59→ * @param {Partial<Lesson>} data\n    60→ * @returns {{ valid: boolean, error?: string }}\n    61→ */\n    62→export function validateLesson(data) {\n    63→  if (!data.title || data.title.trim().length === 0) {\n    64→    return { valid: false, error: 'El título es obligatorio' };\n    65→  }\n    66→\n    67→  if (data.order === undefined || data.order === null || typeof data.order !== 'number' || data.order < 0) {\n    68→    return { valid: false, error: 'El orden debe ser un número positivo' };\n    69→  }\n    70→\n    71→  return { valid: true };\n    72→}\n    73→\n    74→/**\n    75→ * Fetch all modules ordered by order ascending.\n    76→ * @returns {Promise<{success: boolean, modules?: Module[], error?: string}>}\n    77→ */\n    78→export async function fetchAllModules() {\n    79→  try {\n    80→    const ref = collection(db, COLLECTION);\n    81→    const q = query(ref, orderBy('order', 'asc'));\n    82→    const snapshot = await getDocs(q);\n    83→\n    84→    const modules = snapshot.docs.map((d) => ({ id: d.id, ...d.data() }));\n    85→    return { success: true, modules };\n    86→  } catch (err) {\n    87→    return { success: false, error: 'Error al cargar módulos' };\n    88→  }\n    89→}\n    90→\n    91→/**\n    92→ * Fetch modules filtered by course name.\n    93→ * @param {string} courseName\n    94→ * @returns {Promise<{success: boolean, modules?: Module[], error?: string}>}\n    95→ */\n    96→export async function fetchModulesByCourse(courseName) {\n    97→  if (!courseName) return fetchAllModules();\n    98→\n    99→  try {\n   100→    const ref = collection(db, COLLECTION);"}]},"parent_tool_use_id":"toolu_017tkSLw7CGRsjySeyqz2Ko1","session_id":"29ef6fdd-2401-4391-a139-b7ef9e423188","uuid":"9d5c3e41-6547-4e04-a938-2bbae8d38dba"} (stream=stdout)
