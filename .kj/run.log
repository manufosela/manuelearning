height: 1.5rem; border: 3px solid #e2e8f0; border-top-color: #84cc16; border-radius: 50%; animation: spin 0.6s linear infinite; margin: 0 auto 0.75rem; }\n   109→    @keyframes spin { to { transform: rotate(360deg); } }\n   110→    .empty-state { text-align: center; padding: 3rem; color: #64748b; }\n   111→  `;\n   112→\n   113→  constructor() {\n   114→    super();\n   115→    this._quizzes = [];\n   116→    this._loading = true;\n   117→    this._error = '';\n   118→    this._showForm = false;\n   119→    this._editingId = null;\n   120→    this._formData = this._emptyForm();\n   121→    this._formError = '';\n   122→    this._saving = false;\n   123→    this._viewingResponses = null;\n   124→    this._responses = [];\n   125→    this._showStats = null;\n   126→    this._statsLoading = false;\n   127→    this._statsData = null;\n   128→    this._usersMap = {};\n   129→  }\n   130→\n   131→  connectedCallback() {\n   132→    super.connectedCallback();\n   133→    waitForAuth().then(() => this._loadQuizzes());\n   134→  }\n   135→\n   136→  _emptyForm() {\n   137→    return {\n   138→      title: '',\n   139→      moduleId: '',\n   140→      lessonId: '',\n   141→      questions: [{ text: '', type: 'open', options: [] }],\n   142→    };\n   143→  }\n   144→\n   145→  async _loadQuizzes() {\n   146→    this._loading = true;\n   147→    const result = await fetchAllQuizzes();\n   148→    this._loading = false;\n   149→    if (result.success) { this._quizzes = result.quizzes; } else { this._error = result.error; }\n   150→  }\n   151→\n   152→  _openCreate() {\n   153→    this._editingId = null;\n   154→    this._formData = this._emptyForm();\n   155→    this._formError = '';\n   156→    this._showForm = true;\n   157→  }\n   158→\n   159→  _openEdit(quiz) {\n   160→    this._editingId = quiz.id;\n   161→    this._formData = {\n   162→      title: quiz.title || '',\n   163→      moduleId: quiz.moduleId || '',\n   164→      lessonId: quiz.lessonId || '',\n   165→      questions: (quiz.questions || []).map((q) => ({ ...q, options: q.options || [] })),\n   166→    };\n   167→    this._formError = '';\n   168→    this._showForm = true;\n   169→  }\n   170→\n   171→  _closeForm() { this._showForm = false; this._editingId = null; this._formError = ''; }\n   172→\n   173→  _handleInput(e) {\n   174→    const input = /** @type {HTMLInputElement} */ (e.target);\n   175→    this._formData = { ...this._formData, [input.name]: input.value };\n   176→  }\n   177→\n   178→  _handleQuestionInput(index, field, value) {\n   179→    const questions = [...this._formData.questions];\n   180→    questions[index] = { ...questions[index], [field]: value };\n   181→    this._formData = { ...this._formData, questions };\n   182→  }\n   183→\n   184→  _addQuestion() {\n   185→    this._formData = {\n   186→      ...this._formData,\n   187→      questions: [...this._formData.questions, { text: '', type: 'open', options: [] }],\n   188→    };\n   189→  }\n   190→\n   191→  _removeQuestion(index) {\n   192→    const questions = this._formData.questions.filter((_, i) => i !== index);\n   193→    this._formData = { ...this._formData, questions };\n   194→  }\n   195→\n   196→  async _handleSubmit(e) {\n   197→    e.preventDefault();\n   198→    this._formError = '';\n   199→    const validation = validateQuiz(this._formData);\n   200→    if (!validation.valid) { this._formError = validation.error; return; }\n   201→\n   202→    this._saving = true;\n   203→    let result;\n   204→    if (this._editingId) {\n   205→      result = await updateQuiz(this._editingId, {\n   206→        title: this._formData.title.trim(),\n   207→        moduleId: this._formData.moduleId,\n   208→        lessonId: this._formData.lessonId || '',\n   209→        questions: this._formData.questions,\n   210→      });\n   211→    } else {\n   212→      result = await createQuiz(this._formData);\n   213→    }\n   214→    this._saving = false;\n   215→    if (result.success) { this._closeForm(); await this._loadQuizzes(); } else { this._formError = result.error; }\n   216→  }\n   217→\n   218→  async _handleDelete(quizId) {\n   219→    const result = await deleteQuiz(quizId);\n   220→    if (result.success) await this._loadQuizzes();\n   221→  }\n   222→\n   223→  _exportResponses(quiz) {\n   224→    const responses = this._statsData?.responses || this._responses;\n   225→    const questionCount = quiz.questions?.length || 0;\n   226→    const headers = ['Usuario', 'Fecha', ...Array.from({ length: questionCount }, (_, i) => `Pregunta ${i + 1}`)];\n   227→    const rows = responses.map((r) => [\n   228→      this._getUserName(r.userId),\n   229→      this._formatDate(r.completedAt),\n   230→      ...Array.from({ length: questionCount }, (_, i) => r.answers[i] || ''),\n   231→    ]);\n   232→    const safeName = quiz.title.replace(/[^a-zA-Z0-9]/g, '_').toLowerCase();\n   233→    exportCsv(headers, rows, `quiz_${safeName}.csv`);\n   234→  }\n   235→\n   236→  async _toggleResponses(quizId) {\n   237→    if (this._viewingResponses === quizId) { this._viewingResponses = null; return; }\n   238→    this._viewingResponses = quizId;\n   239→    const result = await getQuizResponses(quizId);\n   240→    this._responses = result.success ? result.responses : [];\n   241→  }\n   242→\n   243→  async _openStats(quiz) {\n   244→    this._showStats = quiz;\n   245→    this._statsLoading = true;\n   246→    this._statsData = null;\n   247→\n   248→    const [responsesResult, usersResult] = await Promise.all([\n   249→      getQuizResponses(quiz.id),\n   250→      Object.keys(this._usersMap).length === 0 ? fetchAllUsers() : Promise.resolve(null),\n   251→    ]);\n   252→\n   253→    if (usersResult?.success) {\n   254→      const map = {};\n   255→      for (const u of usersResult.users) { map[u.uid] = u.displayName || u.email; }\n   256→      this._usersMap = map;\n   257→    }\n   258→\n   259→    if (responsesResult.success) {\n   260→      const responses = responsesResult.responses;\n   261→      const questions = quiz.questions || [];\n   262→      let totalCorrect = 0;\n   263→      let totalGraded = 0;\n   264→\n   265→      const questionStats = questions.map((q, i) => {\n   266→        const answers = responses.map((r) => (r.answers || [])[i] || '').filter(Boolean);\n   267→        if (q.type === 'multiple') {\n   268→          const counts = {};\n   269→          for (const opt of q.options || []) { counts[opt] = 0; }\n   270→          let qCorrect = 0;\n   271→          for (const a of answers) {\n   272→            counts[a] = (counts[a] || 0) + 1;\n   273→            if (q.correctAnswer && a === q.correctAnswer) qCorrect++;\n   274→          }\n   275→          if (q.correctAnswer) {\n   276→            totalCorrect += qCorrect;\n   277→            totalGraded += answers.length;\n   278→          }\n   279→          return { ...q, index: i, distribution: counts, totalAnswered: answers.length, correctCount: qCorrect, incorrectCount: answers.length - qCorrect };\n   280→        }\n   281→        return { ...q, index: i, openAnswers: answers, totalAnswered: answers.length };\n   282→      });\n   283→\n   284→      const totalIncorrect = totalGraded - totalCorrect;\n   285→      const correctPct = totalGraded > 0 ? Math.round((totalCorrect / totalGraded) * 100) : 0;\n   286→      const incorrectPct = totalGraded > 0 ? 100 - correctPct : 0;\n   287→\n   288→      this._statsData = { totalResponses: responses.length, questionStats, responses, totalCorrect, totalIncorrect, totalGraded, correctPct, incorrectPct };\n   289→    }\n   290→\n   291→    this._statsLoading = false;\n   292→  }\n   293→\n   294→  _closeStats() { this._showStats = null; this._statsData = null; }\n   295→\n   296→  _formatDate(ts) {\n   297→    if (!ts) return '';\n   298→    const d = ts.toDate ? ts.toDate() : new Date(ts);\n   299→    return d.toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });\n   300→  }\n   301→\n   302→  _getUserName(userId) {\n   303→    return this._usersMap[userId] || userId;\n   304→  }\n   305→\n   306→  render() {\n   307→    if (this._loading) return html`<div class=\"loading\"><div class=\"spinner\"></div><p>Cargando quizzes...</p></div>`;\n   308→    if (this._error) return html`<div class=\"error-msg\">${this._error}</div>`;\n   309→\n   310→    return html`\n   311→      ${materialIconsLink}\n   312→      <div class=\"toolbar\">\n   313→        <span>${this._quizzes.length} quiz${this._quizzes.length !== 1 ? 'zes' : ''}</span>\n   314→        <button class=\"btn btn--primary\" @click=${this._openCreate}>\n   315→          <span class=\"material-symbols-outlined\">add</span> Nuevo quiz\n   316→        </button>\n   317→      </div>\n   318→\n   319→      ${this._quizzes.length === 0\n   320→        ? html`<div class=\"empty-state\"><p>No hay quizzes creados</p></div>`\n   321→        : this._quizzes.map((q) => this._renderQuiz(q))}\n   322→\n   323→      ${this._showForm ? this._renderForm() : ''}\n   324→      ${this._showStats ? this._renderStatsModal() : ''}\n   325→    `;\n   326→  }\n   327→\n   328→  _renderStatsModal() {\n   329→    const quiz = this._showStats;\n   330→    return html`\n   331→      <div class=\"form-overlay\" @click=${this._closeStats}>\n   332→        <div class=\"form-card\" @click=${(e) => e.stopPropagation()} style=\"max-width: 700px;\">\n   333→          <h3>Estadísticas: ${quiz.title}</h3>\n   334→\n   335→          ${this._statsLoading ? html`\n   336→            <div class=\"loading\"><div class=\"spinner\"></div><p>Cargando estadísticas...</p></div>\n   337→          ` : !this._statsData ? html`\n   338→            <div class=\"error-msg\">Error al cargar las estadísticas</div>\n   339→          ` : this._statsData.totalResponses === 0 ? html`\n   340→            <div class=\"empty-state\"><p>Aún no hay respuestas para este quiz</p></div>\n   341→          ` : html`\n   342→            <div class=\"stats-summary\">\n   343→              <div class=\"stats-card\">\n   344→                <div class=\"stats-card__value\">${this._statsData.totalResponses}</div>\n   345→                <div class=\"stats-card__label\">Respuestas totales</div>\n   346→              </div>\n   347→              <div class=\"stats-card\">\n   348→                <div class=\"stats-card__value\">${quiz.questions?.length || 0}</div>\n   349→                <div class=\"stats-card__label\">Preguntas</div>\n   350→              </div>\n   351→              ${this._statsData.totalGraded > 0 ? html`\n   352→                <div class=\"stats-card stats-card--correct\">\n   353→                  <div class=\"stats-card__value\">${this._statsData.totalCorrect} (${this._statsData.correctPct}%)</div>\n   354→                  <div class=\"stats-card__label\">Correctas</div>\n   355→                </div>\n   356→                <div class=\"stats-card stats-card--incorrect\">\n   357→                  <div class=\"stats-card__value\">${this._statsData.totalIncorrect} (${this._statsData.incorrectPct}%)</div>\n   358→                  <div class=\"stats-card__label\">Incorrectas</div>\n   359→                </div>\n   360→              ` : ''}\n   361→            </div>\n   362→\n   363→            ${this._statsData.questionStats.map((qs) => this._renderQuestionStats(qs))}\n   364→\n   365→            <div class=\"stats-students\">\n   366→              <div class=\"stats-students__title\">Respuestas por estudiante (${this._statsData.totalResponses})</div>\n   367→              ${this._statsData.responses.map((r) => html`\n   368→                <div class=\"stats-student\">\n   369→                  <div class=\"stats-student__name\">\n   370→                    ${this._getUserName(r.userId)}\n   371→                    <span class=\"stats-student__date\">${this._formatDate(r.completedAt)}</span>\n   372→                  </div>\n   373→                  <div class=\"stats-student__answers\">\n   374→                    ${(r.answers || []).map((a, i) => {\n   375→                      const q = (this._showStats.questions || [])[i];\n   376→                      const hasCorrect = q?.type === 'multiple' && q?.correctAnswer;\n   377→                      const isCorrect = hasCorrect && a === q.correctAnswer;\n   378→                      const cssClass = hasCorrect ? (isCorrect ? 'stats-student__answer--correct' : 'stats-student__answer--incorrect') : '';\n   379→                      return html`\n   380→                        <div class=\"${cssClass}\"><strong>P${i + 1}:</strong> ${a} ${hasCorrect ? (isCorrect ? '✓' : '✗') : ''}</div>\n   381→                      `;\n   382→                    })}\n   383→                  </div>\n   384→                </div>\n   385→              `)}\n   386→            </div>\n   387→          `}\n   388→\n   389→          <div class=\"form-actions\">\n   390→            <button class=\"btn btn--secondary\" @click=${this._closeStats}>Cerrar</button>\n   391→            ${this._statsData?.totalResponses > 0 ? html`\n   392→              <button class=\"btn btn--primary\" @click=${() => this._exportResponses(quiz)}>\n   393→                <span class=\"material-symbols-outlined\" style=\"font-size: 0.875rem;\">download</span> Exportar CSV\n   394→              </button>\n   395→            ` : ''}\n   396→          </div>\n   397→        </div>\n   398→      </div>\n   399→    `;\n   400→  }\n   401→\n   402→  _renderQuestionStats(qs) {\n   403→    const total = qs.totalAnswered;\n   404→    return html`\n   405→      <div class=\"stats-question\">\n   406→        <div class=\"stats-question__title\">\n   407→          P${qs.index + 1}: ${qs.text}\n   408→          <span class=\"stats-question__type\">(${qs.type === 'multiple' ? 'Selección múltiple' : 'Respuesta abierta'})</span>\n   409→        </div>\n   410→        ${qs.type === 'multiple' && qs.distribution ? html`\n   411→          ${qs.correctAnswer && total > 0 ? html`\n   412→            <div style=\"font-size: 0.813rem; color: #64748b; margin-bottom: 0.5rem;\">\n   413→              Correctas: <strong style=\"color: #15803d;\">${qs.correctCount}/${total} (${Math.round((qs.correctCount / total) * 100)}%)</strong>\n   414→              · Incorrectas: <strong style=\"color: #991b1b;\">${qs.incorrectCount}/${total} (${Math.round((qs.incorrectCount / total) * 100)}%)</strong>\n   415→            </div>\n   416→          ` : ''}\n   417→          ${Object.entries(qs.distribution).map(([option, count]) => {\n   418→            const pct = total > 0 ? Math.round((count / total) * 100) : 0;\n   419→            const isCorrect = qs.correctAnswer === option;\n   420→            return html`\n   421→              <div class=\"stats-bar\">\n   422→                <span class=\"stats-bar__label\" title=\"${option}\">${option} ${isCorrect ? '✓' : ''}</span>\n   423→                <div class=\"stats-bar__track\">\n   424→                  <div class=\"stats-bar__fill ${isCorrect ? 'stats-bar__fill--correct' : qs.correctAnswer ? 'stats-bar__fill--incorrect' : ''}\" style=\"width: ${pct}%\"></div>\n   425→                </div>\n   426→                <span class=\"stats-bar__count\">${count} (${pct}%)</span>\n   427→              </div>\n   428→            `;\n   429→          })}\n   430→        ` : html`\n   431→          <div style=\"font-size: 0.813rem; color: #64748b;\">${total} respuesta${total !== 1 ? 's' : ''} recibida${total !== 1 ? 's' : ''}</div>\n   432→        `}\n   433→      </div>\n   434→    `;\n   435→  }\n   436→\n   437→  _renderQuiz(q) {\n   438→    const isViewing = this._viewingResponses === q.id;\n   439→    return html`\n   440→      <div class=\"quiz-card\">\n   441→        <div class=\"quiz-header\">\n   442→          <span class=\"quiz-title\">${q.title}</span>\n   443→          <div class=\"quiz-actions\">\n   444→            <button class=\"btn btn--secondary btn--small\" @click=${() => this._openEdit(q)}>Editar</button>\n   445→            <button class=\"btn btn--secondary btn--small\" @click=${() => this._openStats(q)}>\n   446→              <span class=\"material-symbols-outlined\" style=\"font-size: 0.875rem;\">bar_chart</span> Estadísticas\n   447→            </button>\n   448→            <button class=\"btn btn--secondary btn--small\" @click=${() => this._toggleResponses(q.id)}>\n   449→              ${isViewing ? 'Ocultar' : 'Respuestas'}\n   450→            </button>\n   451→            <button class=\"btn btn--danger btn--small\" @click=${() => this._handleDelete(q.id)}>Eliminar</button>\n   452→          </div>\n   453→        </div>\n   454→        <div class=\"quiz-meta\">${q.questions?.length || 0} preguntas · Módulo: ${q.moduleId}</div>\n   455→\n   456→        ${isViewing ? html`\n   457→          <div class=\"responses-panel\">\n   458→            ${this._responses.length > 0 ? html`\n   459→              <div style=\"margin-bottom: 0.75rem;\">\n   460→                <button class=\"btn btn--secondary btn--small\" @click=${() => this._exportResponses(q)}>\n   461→                  <span class=\"material-symbols-outlined\" style=\"font-size: 0.875rem;\">download</span>\n   462→                  Exportar resultados\n   463→                </button>\n   464→              </div>\n   465→            ` : ''}\n   466→            ${this._responses.length === 0\n   467→              ? html`<p class=\"quiz-meta\">Sin respuestas aún</p>`\n   468→              : this._responses.map((r) => html`\n   469→                  <div class=\"response-item\">\n   470→                    <div class=\"response-user\">${r.userId}</div>\n   471→                    ${r.answers.map((a, i) => html`<div class=\"response-answer\"><strong>P${i + 1}:</strong> ${a}</div>`)}\n   472→                  </div>\n   473→                `)}\n   474→          </div>\n   475→        ` : ''}\n   476→      </div>\n   477→    `;\n   478→  }\n   479→\n   480→  _renderForm() {\n   481→    return html`\n   482→      <div class=\"form-overlay\" @click=${this._closeForm}>\n   483→        <div class=\"form-card\" @click=${(e) => e.stopPropagation()}>\n   484→          <h3>${this._editingId ? 'Editar quiz' : 'Nuevo quiz'}</h3>\n   485→          <form @submit=${this._handleSubmit}>\n   486→            <div class=\"form-group\">\n   487→              <label for=\"quiz-title\">Título</label>\n   488→              <input id=\"quiz-title\" name=\"title\" type=\"text\" .value=${this._formData.title} @input=${this._handleInput} required />\n   489→            </div>\n   490→            <div class=\"form-group\">\n   491→              <label for=\"quiz-module\">ID del Módulo</label>\n   492→              <input id=\"quiz-module\" name=\"moduleId\" type=\"text\" .value=${this._formData.moduleId} @input=${this._handleInput} required />\n   493→            </div>\n   494→            <div class=\"form-group\">\n   495→              <label for=\"quiz-lesson\">ID de la Clase (opcional)</label>\n   496→              <input id=\"quiz-lesson\" name=\"lessonId\" type=\"text\" .value=${this._formData.lessonId} @input=${this._handleInput} />\n   497→            </div>\n   498→\n   499→            <h4 style=\"margin: 1rem 0 0.75rem; font-size: 0.875rem; color: #0f172a;\">Preguntas</h4>\n   500→            ${this._formData.questions.map((q, i) => html`\n   501→              <div class=\"question-block\">\n   502→                <div class=\"question-block-header\">\n   503→                  <span class=\"question-number\">Pregunta ${i + 1}</span>\n   504→                  ${this._formData.questions.length > 1 ? html`\n   505→                    <button type=\"button\" class=\"btn btn--danger btn--small\" @click=${() => this._removeQuestion(i)}>Quitar</button>\n   506→                  ` : ''}\n   507→                </div>\n   508→                <div class=\"form-group\">\n   509→                  <input type=\"text\" .value=${q.text} @input=${(e) => this._handleQuestionInput(i, 'text', e.target.value)} placeholder=\"Texto de la pregunta\" required />\n   510→                </div>\n   511→                <div class=\"form-group\">\n   512→                  <select .value=${q.type} @change=${(e) => this._handleQuestionInput(i, 'type', e.target.value)}>\n   513→                    <option value=\"open\">Respuesta abierta</option>\n   514→                    <option value=\"multiple\">Selección múltiple</option>\n   515→                  </select>\n   516→                </div>\n   517→                ${q.type === 'multiple' ? html`\n   518→                  <div class=\"form-group\">\n   519→                    <label>Opciones (una por línea)</label>\n   520→                    <textarea\n   521→                      .value=${(q.options || []).join('\\n')}\n   522→                      @input=${(e) => this._handleQuestionInput(i, 'options', e.target.value.split('\\n').filter(Boolean))}\n   523→                      placeholder=\"Opción A\\nOpción B\\nOpción C\"\n   524→                      rows=\"3\"\n   525→                    ></textarea>\n   526→                  </div>\n   527→                  <div class=\"form-group\">\n   528→                    <label>Respuesta correcta</label>\n   529→                    <select .value=${q.correctAnswer || ''} @change=${(e) => this._handleQuestionInput(i, 'correctAnswer', e.target.value)}>\n   530→                      <option value=\"\">-- Seleccionar --</option>\n   531→                      ${(q.options || []).map((opt) => html`<option value=${opt} ?selected=${q.correctAnswer === opt}>${opt}</option>`)}\n   532→                    </select>\n   533→                  </div>\n   534→                ` : ''}\n   535→              </div>\n   536→            `)}\n   537→\n   538→            <button type=\"button\" class=\"btn btn--secondary\" @click=${this._addQuestion} style=\"margin-bottom: 1rem;\">\n   539→              + Añadir pregunta\n   540→            </button>\n   541→\n   542→            ${this._formError ? html`<div class=\"form-error\">${this._formError}</div>` : ''}\n   543→            <div class=\"form-actions\">\n   544→              <button type=\"button\" class=\"btn btn--secondary\" @click=${this._closeForm}>Cancelar</button>\n   545→              <button type=\"submit\" class=\"btn btn--primary\" ?disabled=${this._saving}>${this._saving ? 'Guardando...' : this._editingId ? 'Guardar' : 'Crear'}</button>\n   546→            </div>\n   547→          </form>\n   548→        </div>\n   549→      </div>\n   550→    `;\n   551→  }\n   552→}\n   553→\n   554→customElements.define('admin-quizzes-list', AdminQuizzesList);\n   555→"}]},"parent_tool_use_id":null,"session_id":"9154919e-bd9a-4b77-8ff1-a9fd5df9d7fe","uuid":"764e121c-de20-46f4-8007-e0d929b7fa26","tool_use_result":{"type":"text","file":{"filePath":"/home/manu/ws_firebase/manuelearning/src/components/admin-quizzes-list.js","content":"import { LitElement, html, css } from 'lit';\nimport {\n  fetchAllQuizzes,\n  createQuiz,\n  updateQuiz,\n  deleteQuiz,\n  getQuizResponses,\n  validateQuiz,\n} from '../lib/firebase/quizzes.js';\nimport { fetchAllUsers } from '../lib/firebase/users.js';\nimport { waitForAuth } from '../lib/auth-ready.js';\nimport { exportCsv } from '../lib/csv-export.js';\nimport { materialIconsLink } from './shared/material-icons.js';\n\n/**\n * @element admin-quizzes-list\n * Admin panel for managing quizzes and viewing responses.\n */\nexport class AdminQuizzesList extends LitElement {\n  static properties = {\n    _quizzes: { type: Array, state: true },\n    _loading: { type: Boolean, state: true },\n    _error: { type: String, state: true },\n    _showForm: { type: Boolean, state: true },\n    _editingId: { type: String, state: true },\n    _formData: { type: Object, state: true },\n    _formError: { type: String, state: true },\n    _saving: { type: Boolean, state: true },\n    _viewingResponses: { type: String, state: true },\n    _responses: { type: Array, state: true },\n    _showStats: { type: Object, state: true },\n    _statsLoading: { type: Boolean, state: true },\n    _statsData: { type: Object, state: true },\n    _usersMap: { type: Object, state: true },\n  };\n\n  static styles = css`\n    :host { display: block; }\n\n    .toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }\n    .btn { display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.5rem 1rem; border: none; border-radius: 0.5rem; font-size: 0.813rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: background-color 0.15s; }\n    .btn--primary { background: linear-gradient(to right, #84cc16, #fb923c); color: #0f172a; }\n    .btn--primary:hover { background: #d11111; }\n    .btn--secondary { background: #f1f5f9; color: #334155; }\n    .btn--secondary:hover { background: #e2e8f0; }\n    .btn--danger { background: #fef2f2; color: #991b1b; }\n    .btn--danger:hover { background: #fee2e2; }\n    .btn--small { padding: 0.375rem 0.75rem; font-size: 0.75rem; }\n    .btn:disabled { opacity: 0.6; cursor: not-allowed; }\n\n    .quiz-card { background: #fff; border-radius: 0.75rem; padding: 1.25rem; box-shadow: 0 1px 3px rgb(0 0 0 / 0.1); margin-bottom: 1rem; }\n    .quiz-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }\n    .quiz-title { font-size: 1rem; font-weight: 700; color: #0f172a; }\n    .quiz-meta { font-size: 0.813rem; color: #64748b; }\n    .quiz-actions { display: flex; gap: 0.5rem; }\n\n    .responses-panel { border-top: 1px solid #f1f5f9; margin-top: 1rem; padding-top: 1rem; }\n    .response-item { background: #f8fafc; padding: 0.75rem; border-radius: 0.5rem; margin-bottom: 0.5rem; font-size: 0.875rem; }\n    .response-user { font-weight: 600; color: #0f172a; margin-bottom: 0.25rem; }\n    .response-answer { color: #334155; }\n\n    .form-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; z-index: 100; }\n    .form-card { background: #fff; border-radius: 0.75rem; padding: 2rem; width: 100%; max-width: 560px; box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.25); max-height: 90vh; overflow-y: auto; }\n    .form-card h3 { margin: 0 0 1.5rem; font-size: 1.125rem; font-weight: 700; color: #0f172a; }\n    .form-group { margin-bottom: 1rem; }\n    .form-group label { display: block; font-size: 0.813rem; font-weight: 600; color: #334155; margin-bottom: 0.375rem; }\n    .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem; font-family: inherit; box-sizing: border-box; }\n    .form-group input:focus, .form-group textarea:focus { outline: none; border-color: #84cc16; box-shadow: 0 0 0 3px rgba(132,204,22,0.1); }\n    .form-error { color: #991b1b; font-size: 0.813rem; margin-bottom: 1rem; }\n    .form-actions { display: flex; justify-content: flex-end; gap: 0.5rem; margin-top: 1.5rem; }\n\n    .question-block { background: #f8fafc; padding: 1rem; border-radius: 0.5rem; margin-bottom: 0.75rem; border: 1px solid #e2e8f0; }\n    .question-block-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }\n    .question-number { font-size: 0.75rem; font-weight: 700; color: #475569; }\n\n    .stats-summary { display: flex; gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap; }\n    .stats-card { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 0.5rem; padding: 1rem 1.25rem; flex: 1; min-width: 120px; text-align: center; }\n    .stats-card__value { font-size: 1.5rem; font-weight: 800; color: #0f172a; }\n    .stats-card__label { font-size: 0.75rem; color: #64748b; margin-top: 0.25rem; }\n\n    .stats-question { margin-bottom: 1.25rem; }\n    .stats-question__title { font-size: 0.875rem; font-weight: 700; color: #0f172a; margin-bottom: 0.5rem; }\n    .stats-question__type { font-size: 0.75rem; color: #64748b; font-weight: 400; }\n    .stats-bar { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.375rem; }\n    .stats-bar__label { font-size: 0.813rem; color: #334155; min-width: 120px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n    .stats-bar__track { flex: 1; height: 1.25rem; background: #e2e8f0; border-radius: 0.25rem; overflow: hidden; }\n    .stats-bar__fill { height: 100%; background: linear-gradient(to right, #84cc16, #a3e635); border-radius: 0.25rem; transition: width 0.3s; }\n    .stats-bar__count { font-size: 0.75rem; color: #64748b; min-width: 2.5rem; text-align: right; }\n\n    .stats-students { margin-top: 1.5rem; }\n    .stats-students__title { font-size: 0.938rem; font-weight: 700; color: #0f172a; margin-bottom: 0.75rem; }\n    .stats-student { background: #f8fafc; padding: 0.75rem 1rem; border-radius: 0.5rem; margin-bottom: 0.5rem; border: 1px solid #e2e8f0; }\n    .stats-student__name { font-weight: 600; color: #0f172a; font-size: 0.875rem; margin-bottom: 0.375rem; }\n    .stats-student__date { font-size: 0.75rem; color: #94a3b8; }\n    .stats-student__answers { font-size: 0.813rem; color: #334155; }\n    .stats-student__answers div { margin-top: 0.25rem; }\n    .stats-student__answer--correct { color: #15803d; }\n    .stats-student__answer--incorrect { color: #991b1b; }\n    .stats-card--correct { border-color: #86efac; background: #f0fdf4; }\n    .stats-card--correct .stats-card__value { color: #15803d; }\n    .stats-card--incorrect { border-color: #fca5a5; background: #fef2f2; }\n    .stats-card--incorrect .stats-card__value { color: #991b1b; }\n    .stats-bar__fill--correct { background: linear-gradient(to right, #22c55e, #86efac); }\n    .stats-bar__fill--incorrect { background: linear-gradient(to right, #ef4444, #fca5a5); }\n\n    .loading, .error-msg { text-align: center; padding: 3rem; color: #475569; }\n    .error-msg { color: #991b1b; }\n    .spinner { width: 1.5rem; height: 1.5rem; border: 3px solid #e2e8f0; border-top-color: #84cc16; border-radius: 50%; animation: spin 0.6s linear infinite; margin: 0 auto 0.75rem; }\n    @keyframes spin { to { transform: rotate(360deg); } }\n    .empty-state { text-align: center; padding: 3rem; color: #64748b; }\n  `;\n\n  constructor() {\n    super();\n    this._quizzes = [];\n    this._loading = true;\n    this._error = '';\n    this._showForm = false;\n    this._editingId = null;\n    this._formData = this._emptyForm();\n    this._formError = '';\n    this._saving = false;\n    this._viewingResponses = null;\n    this._responses = [];\n    this._showStats = null;\n    this._statsLoading = false;\n    this._statsData = null;\n    this._usersMap = {};\n  }\n\n  connectedCallback() {\n    super.connectedCallback();\n    waitForAuth().then(() => this._loadQuizzes());\n  }\n\n  _emptyForm() {\n    return {\n      title: '',\n      moduleId: '',\n      lessonId: '',\n      questions: [{ text: '', type: 'open', options: [] }],\n    };\n  }\n\n  async _loadQuizzes() {\n    this._loading = true;\n    const result = await fetchAllQuizzes();\n    this._loading = false;\n    if (result.success) { this._quizzes = result.quizzes; } else { this._error = result.error; }\n  }\n\n  _openCreate() {\n    this._editingId = null;\n    this._formData = this._emptyForm();\n    this._formError = '';\n    this._showForm = true;\n  }\n\n  _openEdit(quiz) {\n    this._editingId = quiz.id;\n    this._formData = {\n      title: quiz.title || '',\n      moduleId: quiz.moduleId || '',\n      lessonId: quiz.lessonId || '',\n      questions: (quiz.questions || []).map((q) => ({ ...q, options: q.options || [] })),\n    };\n    this._formError = '';\n    this._showForm = true;\n  }\n\n  _closeForm() { this._showForm = false; this._editingId = null; this._formError = ''; }\n\n  _handleInput(e) {\n    const input = /** @type {HTMLInputElement} */ (e.target);\n    this._formData = { ...this._formData, [input.name]: input.value };\n  }\n\n  _handleQuestionInput(index, field, value) {\n    const questions = [...this._formData.questions];\n    questions[index] = { ...questions[index], [field]: value };\n    this._formData = { ...this._formData, questions };\n  }\n\n  _addQuestion() {\n    this._formData = {\n      ...this._formData,\n      questions: [...this._formData.questions, { text: '', type: 'open', options: [] }],\n    };\n  }\n\n  _removeQuestion(index) {\n    const questions = this._formData.questions.filter((_, i) => i !== index);\n    this._formData = { ...this._formData, questions };\n  }\n\n  async _handleSubmit(e) {\n    e.preventDefault();\n    this._formError = '';\n    const validation = validateQuiz(this._formData);\n    if (!validation.valid) { this._formError = validation.error; return; }\n\n    this._saving = true;\n    let result;\n    if (this._editingId) {\n      result = await updateQuiz(this._editingId, {\n        title: this._formData.title.trim(),\n        moduleId: this._formData.moduleId,\n        lessonId: this._formData.lessonId || '',\n        questions: this._formData.questions,\n      });\n    } else {\n      result = await createQuiz(this._formData);\n    }\n    this._saving = false;\n    if (result.success) { this._closeForm(); await this._loadQuizzes(); } else { this._formError = result.error; }\n  }\n\n  async _handleDelete(quizId) {\n    const result = await deleteQuiz(quizId);\n    if (result.success) await this._loadQuizzes();\n  }\n\n  _exportResponses(quiz) {\n    const responses = this._statsData?.responses || this._responses;\n    const questionCount = quiz.questions?.length || 0;\n    const headers = ['Usuario', 'Fecha', ...Array.from({ length: questionCount }, (_, i) => `Pregunta ${i + 1}`)];\n    const rows = responses.map((r) => [\n      this._getUserName(r.userId),\n      this._formatDate(r.completedAt),\n      ...Array.from({ length: questionCount }, (_, i) => r.answers[i] || ''),\n    ]);\n    const safeName = quiz.title.replace(/[^a-zA-Z0-9]/g, '_').toLowerCase();\n    exportCsv(headers, rows, `quiz_${safeName}.csv`);\n  }\n\n  async _toggleResponses(quizId) {\n    if (this._viewingResponses === quizId) { this._viewingResponses = null; return; }\n    this._viewingResponses = quizId;\n    const result = await getQuizResponses(quizId);\n    this._responses = result.success ? result.responses : [];\n  }\n\n  async _openStats(quiz) {\n    this._showStats = quiz;\n    this._statsLoading = true;\n    this._statsData = null;\n\n    const [responsesResult, usersResult] = await Promise.all([\n      getQuizResponses(quiz.id),\n      Object.keys(this._usersMap).length === 0 ? fetchAllUsers() : Promise.resolve(null),\n    ]);\n\n    if (usersResult?.success) {\n      const map = {};\n      for (const u of usersResult.users) { map[u.uid] = u.displayName || u.email; }\n      this._usersMap = map;\n    }\n\n    if (responsesResult.success) {\n      const responses = responsesResult.responses;\n      const questions = quiz.questions || [];\n      let totalCorrect = 0;\n      let totalGraded = 0;\n\n      const questionStats = questions.map((q, i) => {\n        const answers = responses.map((r) => (r.answers || [])[i] || '').filter(Boolean);\n        if (q.type === 'multiple') {\n          const counts = {};\n          for (const opt of q.options || []) { counts[opt] = 0; }\n          let qCorrect = 0;\n          for (const a of answers) {\n            counts[a] = (counts[a] || 0) + 1;\n            if (q.correctAnswer && a === q.correctAnswer) qCorrect++;\n          }\n          if (q.correctAnswer) {\n            totalCorrect += qCorrect;\n            totalGraded += answers.length;\n          }\n          return { ...q, index: i, distribution: counts, totalAnswered: answers.length, correctCount: qCorrect, incorrectCount: answers.length - qCorrect };\n        }\n        return { ...q, index: i, openAnswers: answers, totalAnswered: answers.length };\n      });\n\n      const totalIncorrect = totalGraded - totalCorrect;\n      const correctPct = totalGraded > 0 ? Math.round((totalCorrect / totalGraded) * 100) : 0;\n      const incorrectPct = totalGraded > 0 ? 100 - correctPct : 0;\n\n      this._statsData = { totalResponses: responses.length, questionStats, responses, totalCorrect, totalIncorrect, totalGraded, correctPct, incorrectPct };\n    }\n\n    this._statsLoading = false;\n  }\n\n  _closeStats() { this._showStats = null; this._statsData = null; }\n\n  _formatDate(ts) {\n    if (!ts) return '';\n    const d = ts.toDate ? ts.toDate() : new Date(ts);\n    return d.toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });\n  }\n\n  _getUserName(userId) {\n    return this._usersMap[userId] || userId;\n  }\n\n  render() {\n    if (this._loading) return html`<div class=\"loading\"><div class=\"spinner\"></div><p>Cargando quizzes...</p></div>`;\n    if (this._error) return html`<div class=\"error-msg\">${this._error}</div>`;\n\n    return html`\n      ${materialIconsLink}\n      <div class=\"toolbar\">\n        <span>${this._quizzes.length} quiz${this._quizzes.length !== 1 ? 'zes' : ''}</span>\n        <button class=\"btn btn--primary\" @click=${this._openCreate}>\n          <span class=\"material-symbols-outlined\">add</span> Nuevo quiz\n        </button>\n      </div>\n\n      ${this._quizzes.length === 0\n        ? html`<div class=\"empty-state\"><p>No hay quizzes creados</p></div>`\n        : this._quizzes.map((q) => this._renderQuiz(q))}\n\n      ${this._showForm ? this._renderForm() : ''}\n      ${this._showStats ? this._renderStatsModal() : ''}\n    `;\n  }\n\n  _renderStatsModal() {\n    const quiz = this._showStats;\n    return html`\n      <div class=\"form-overlay\" @click=${this._closeStats}>\n        <div class=\"form-card\" @click=${(e) => e.stopPropagation()} style=\"max-width: 700px;\">\n          <h3>Estadísticas: ${quiz.title}</h3>\n\n          ${this._statsLoading ? html`\n            <div class=\"loading\"><div class=\"spinner\"></div><p>Cargando estadísticas...</p></div>\n          ` : !this._statsData ? html`\n            <div class=\"error-msg\">Error al cargar las estadísticas</div>\n          ` : this._statsData.totalResponses === 0 ? html`\n            <div class=\"empty-state\"><p>Aún no hay respuestas para este quiz</p></div>\n          ` : html`\n            <div class=\"stats-summary\">\n              <div class=\"stats-card\">\n                <div class=\"stats-card__value\">${this._statsData.totalResponses}</div>\n                <div class=\"stats-card__label\">Respuestas totales</div>\n              </div>\n              <div class=\"stats-card\">\n                <div class=\"stats-card__value\">${quiz.questions?.length || 0}</div>\n                <div class=\"stats-card__label\">Preguntas</div>\n              </div>\n              ${this._statsData.totalGraded > 0 ? html`\n                <div class=\"stats-card stats-card--correct\">\n                  <div class=\"stats-card__value\">${this._statsData.totalCorrect} (${this._statsData.correctPct}%)</div>\n                  <div class=\"stats-card__label\">Correctas</div>\n                </div>\n                <div class=\"stats-card stats-card--incorrect\">\n                  <div class=\"stats-card__value\">${this._statsData.totalIncorrect} (${this._statsData.incorrectPct}%)</div>\n                  <div class=\"stats-card__label\">Incorrectas</div>\n                </div>\n              ` : ''}\n            </div>\n\n            ${this._statsData.questionStats.map((qs) => this._renderQuestionStats(qs))}\n\n            <div class=\"stats-students\">\n              <div class=\"stats-students__title\">Respuestas por estudiante (${this._statsData.totalResponses})</div>\n              ${this._statsData.responses.map((r) => html`\n                <div class=\"stats-student\">\n                  <div class=\"stats-student__name\">\n                    ${this._getUserName(r.userId)}\n                    <span class=\"stats-student__date\">${this._formatDate(r.completedAt)}</span>\n                  </div>\n                  <div class=\"stats-student__answers\">\n                    ${(r.answers || []).map((a, i) => {\n                      const q = (this._showStats.questions || [])[i];\n                      const hasCorrect = q?.type === 'multiple' && q?.correctAnswer;\n                      const isCorrect = hasCorrect && a === q.correctAnswer;\n                      const cssClass = hasCorrect ? (isCorrect ? 'stats-student__answer--correct' : 'stats-student__answer--incorrect') : '';\n                      return html`\n                        <div class=\"${cssClass}\"><strong>P${i + 1}:</strong> ${a} ${hasCorrect ? (isCorrect ? '✓' : '✗') : ''}</div>\n                      `;\n                    })}\n                  </div>\n                </div>\n              `)}\n            </div>\n          `}\n\n          <div class=\"form-actions\">\n            <button class=\"btn btn--secondary\" @click=${this._closeStats}>Cerrar</button>\n            ${this._statsData?.totalResponses > 0 ? html`\n              <button class=\"btn btn--primary\" @click=${() => this._exportResponses(quiz)}>\n                <span class=\"material-symbols-outlined\" style=\"font-size: 0.875rem;\">download</span> Exportar CSV\n              </button>\n            ` : ''}\n          </div>\n        </div>\n      </div>\n    `;\n  }\n\n  _renderQuestionStats(qs) {\n    const total = qs.totalAnswered;\n    return html`\n      <div class=\"stats-question\">\n        <div class=\"stats-question__title\">\n          P${qs.index + 1}: ${qs.text}\n          <span class=\"stats-question__type\">(${qs.type === 'multiple' ? 'Selección múltiple' : 'Respuesta abierta'})</span>\n        </div>\n        ${qs.type === 'multiple' && qs.distribution ? html`\n          ${qs.correctAnswer && total > 0 ? html`\n            <div style=\"font-size: 0.813rem; color: #64748b; margin-bottom: 0.5rem;\">\n              Correctas: <strong style=\"color: #15803d;\">${qs.correctCount}/${total} (${Math.round((qs.correctCount / total) * 100)}%)</strong>\n              · Incorrectas: <strong style=\"color: #991b1b;\">${qs.incorrectCount}/${total} (${Math.round((qs.incorrectCount / total) * 100)}%)</strong>\n            </div>\n          ` : ''}\n          ${Object.entries(qs.distribution).map(([option, count]) => {\n            const pct = total > 0 ? Math.round((count / total) * 100) : 0;\n            const isCorrect = qs.correctAnswer === option;\n            return html`\n              <div class=\"stats-bar\">\n                <span class=\"stats-bar__label\" title=\"${option}\">${option} ${isCorrect ? '✓' : ''}</span>\n                <div class=\"stats-bar__track\">\n                  <div class=\"stats-bar__fill ${isCorrect ? 'stats-bar__fill--correct' : qs.correctAnswer ? 'stats-bar__fill--incorrect' : ''}\" style=\"width: ${pct}%\"></div>\n                </div>\n                <span class=\"stats-bar__count\">${count} (${pct}%)</span>\n              </div>\n            `;\n          })}\n        ` : html`\n          <div style=\"font-size: 0.813rem; color: #64748b;\">${total} respuesta${total !== 1 ? 's' : ''} recibida${total !== 1 ? 's' : ''}</div>\n        `}\n      </div>\n    `;\n  }\n\n  _renderQuiz(q) {\n    const isViewing = this._viewingResponses === q.id;\n    return html`\n      <div class=\"quiz-card\">\n        <div class=\"quiz-header\">\n          <span class=\"quiz-title\">${q.title}</span>\n          <div class=\"quiz-actions\">\n            <button class=\"btn btn--secondary btn--small\" @click=${() => this._openEdit(q)}>Editar</button>\n            <button class=\"btn btn--secondary btn--small\" @click=${() => this._openStats(q)}>\n              <span class=\"material-symbols-outlined\" style=\"font-size: 0.875rem;\">bar_chart</span> Estadísticas\n            </button>\n            <button class=\"btn btn--secondary btn--small\" @click=${() => this._toggleResponses(q.id)}>\n              ${isViewing ? 'Ocultar' : 'Respuestas'}\n            </button>\n            <button class=\"btn btn--danger btn--small\" @click=${() => this._handleDelete(q.id)}>Eliminar</button>\n          </div>\n        </div>\n        <div class=\"quiz-meta\">${q.questions?.length || 0} preguntas · Módulo: ${q.moduleId}</div>\n\n        ${isViewing ? html`\n          <div class=\"responses-panel\">\n            ${this._responses.length > 0 ? html`\n              <div style=\"margin-bottom: 0.75rem;\">\n                <button class=\"btn btn--secondary btn--small\" @click=${() => this._exportResponses(q)}>\n                  <span class=\"material-symbols-outlined\" style=\"font-size: 0.875rem;\">download</span>\n                  Exportar resultados\n                </button>\n              </div>\n            ` : ''}\n            ${this._responses.length === 0\n              ? html`<p class=\"quiz-meta\">Sin respuestas aún</p>`\n              : this._responses.map((r) => html`\n                  <div class=\"response-item\">\n                    <div class=\"response-user\">${r.userId}</div>\n                    ${r.answers.map((a, i) => html`<div class=\"response-answer\"><strong>P${i + 1}:</strong> ${a}</div>`)}\n                  </div>\n                `)}\n          </div>\n        ` : ''}\n      </div>\n    `;\n  }\n\n  _renderForm() {\n    return html`\n      <div class=\"form-overlay\" @click=${this._closeForm}>\n        <div class=\"form-card\" @click=${(e) => e.stopPropagation()}>\n          <h3>${this._editingId ? 'Editar quiz' : 'Nuevo quiz'}</h3>\n          <form @submit=${this._handleSubmit}>\n            <div class=\"form-group\">\n              <label for=\"quiz-title\">Título</label>\n              <input id=\"quiz-title\" name=\"title\" type=\"text\" .value=${this._formData.title} @input=${this._handleInput} required />\n            </div>\n            <div class=\"form-group\">\n              <label for=\"quiz-module\">ID del Módulo</label>\n              <input id=\"quiz-module\" name=\"moduleId\" type=\"text\" .value=${this._formData.moduleId} @input=${this._handleInput} required />\n            </div>\n            <div class=\"form-group\">\n              <label for=\"quiz-lesson\">ID de la Clase (opcional)</label>\n              <input id=\"quiz-lesson\" name=\"lessonId\" type=\"text\" .value=${this._formData.lessonId} @input=${this._handleInput} />\n            </div>\n\n            <h4 style=\"margin: 1rem 0 0.75rem; font-size: 0.875rem; color: #0f172a;\">Preguntas</h4>\n            ${this._formData.questions.map((q, i) => html`\n              <div class=\"question-block\">\n                <div class=\"question-block-header\">\n                  <span class=\"question-number\">Pregunta ${i + 1}</span>\n                  ${this._formData.questions.length > 1 ? html`\n                    <button type=\"button\" class=\"btn btn--danger btn--small\" @click=${() => this._removeQuestion(i)}>Quitar</button>\n                  ` : ''}\n                </div>\n                <div class=\"form-group\">\n                  <input type=\"text\" .value=${q.text} @input=${(e) => this._handleQuestionInput(i, 'text', e.target.value)} placeholder=\"Texto de la pregunta\" required />\n                </div>\n                <div class=\"form-group\">\n                  <select .value=${q.type} @change=${(e) => this._handleQuestionInput(i, 'type', e.target.value)}>\n                    <option value=\"open\">Respuesta abierta</option>\n                    <option value=\"multiple\">Selección múltiple</option>\n                  </select>\n                </div>\n                ${q.type === 'multiple' ? html`\n                  <div class=\"form-group\">\n                    <label>Opciones (una por línea)</label>\n                    <textarea\n                      .value=${(q.options || []).join('\\n')}\n                      @input=${(e) => this._handleQuestionInput(i, 'options', e.target.value.split('\\n').filter(Boolean))}\n                      placeholder=\"Opción A\\nOpción B\\nOpción C\"\n                      rows=\"3\"\n                    ></textarea>\n                  </div>\n                  <div class=\"form-group\">\n                    <label>Respuesta correcta</label>\n                    <select .value=${q.correctAnswer || ''} @change=${(e) => this._handleQuestionInput(i, 'correctAnswer', e.target.value)}>\n                      <option value=\"\">-- Seleccionar --</option>\n                      ${(q.options || []).map((opt) => html`<option value=${opt} ?selected=${q.correctAnswer === opt}>${opt}</option>`)}\n                    </select>\n                  </div>\n                ` : ''}\n              </div>\n            `)}\n\n            <button type=\"button\" class=\"btn btn--secondary\" @click=${this._addQuestion} style=\"margin-bottom: 1rem;\">\n              + Añadir pregunta\n            </button>\n\n            ${this._formError ? html`<div class=\"form-error\">${this._formError}</div>` : ''}\n            <div class=\"form-actions\">\n              <button type=\"button\" class=\"btn btn--secondary\" @click=${this._closeForm}>Cancelar</button>\n              <button type=\"submit\" class=\"btn btn--primary\" ?disabled=${this._saving}>${this._saving ? 'Guardando...' : this._editingId ? 'Guardar' : 'Crear'}</button>\n            </div>\n          </form>\n        </div>\n      </div>\n    `;\n  }\n}\n\ncustomElements.define('admin-quizzes-list', AdminQuizzesList);\n","numLines":555,"startLine":1,"totalLines":555}}} (stream=stdout)
