   208→\n   209→    .badge {\n   210→      font-size: 0.688rem;\n   211→      font-weight: 700;\n   212→      padding: 0.125rem 0.5rem;\n   213→      border-radius: 9999px;\n   214→      background: #f0fdf4;\n   215→      color: #15803d;\n   216→    }\n   217→  `;\n   218→\n   219→  constructor() {\n   220→    super();\n   221→    this._results = [];\n   222→    this._loading = true;\n   223→    this._error = '';\n   224→    this._expandedQuiz = null;\n   225→  }\n   226→\n   227→  connectedCallback() {\n   228→    super.connectedCallback();\n   229→    waitForAuth().then((user) => this._loadResults(user));\n   230→  }\n   231→\n   232→  async _loadResults(user) {\n   233→    this._loading = true;\n   234→    this._error = '';\n   235→\n   236→    const result = await getUserQuizResults(user.uid);\n   237→\n   238→    if (result.success) {\n   239→      this._results = result.results;\n   240→    } else {\n   241→      this._error = result.error;\n   242→    }\n   243→\n   244→    this._loading = false;\n   245→  }\n   246→\n   247→  render() {\n   248→    if (this._loading) {\n   249→      return html`<div class=\"loading\"><div class=\"spinner\"></div><p>Cargando resultados...</p></div>`;\n   250→    }\n   251→\n   252→    if (this._error) {\n   253→      return html`<div class=\"error-msg\">${this._error}</div>`;\n   254→    }\n   255→\n   256→    return html`\n   257→      ${materialIconsLink}\n   258→      <div class=\"results-header\">\n   259→        <h2>Mis resultados de quizzes</h2>\n   260→        <p>${this._results.length > 0\n   261→          ? `Has completado ${this._results.length} quiz${this._results.length !== 1 ? 'zes' : ''}`\n   262→          : ''}</p>\n   263→      </div>\n   264→\n   265→      ${this._results.length === 0\n   266→        ? html`\n   267→            <div class=\"empty-state\">\n   268→              <span class=\"material-symbols-outlined\">quiz</span>\n   269→              <p>Aún no has completado ningún quiz.</p>\n   270→        