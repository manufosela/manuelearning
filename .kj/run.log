eturn { success: false, error: 'Error al eliminar el módulo' };\n   201→  }\n   202→}\n   203→\n   204→/* ── Lessons (subcollection of a module) ────────────────────── */\n   205→\n   206→/**\n   207→ * Fetch all lessons for a module.\n   208→ * @param {string} moduleId\n   209→ * @returns {Promise<{success: boolean, lessons?: Lesson[], error?: string}>}\n   210→ */\n   211→export async function fetchLessons(moduleId) {\n   212→  if (!moduleId) return { success: false, error: 'ID del módulo es obligatorio' };\n   213→\n   214→  try {\n   215→    const ref = collection(db, COLLECTION, moduleId, 'lessons');\n   216→    const q = query(ref, orderBy('order', 'asc'));\n   217→    const snapshot = await getDocs(q);\n   218→\n   219→    const lessons = snapshot.docs.map((d) => ({ id: d.id, ...d.data() }));\n   220→    return { success: true, lessons };\n   221→  } catch (err) {\n   222→    return { success: false, error: 'Error al cargar las clases' };\n   223→  }\n   224→}\n   225→\n   226→/**\n   227→ * Fetch a single lesson.\n   228→ * @param {string} moduleId\n   229→ * @param {string} lessonId\n   230→ * @returns {Promise<{success: boolean, lesson?: Lesson, error?: string}>}\n   231→ */\n   232→export async function fetchLesson(moduleId, lessonId) {\n   233→  if (!moduleId) return { success: false, error: 'ID del módulo es obligatorio' };\n   234→  if (!lessonId) return { success: false, error: 'ID de la clase es obligatorio' };\n   235→\n   236→  try {\n   237→    const snap = await getDoc(doc(db, COLLECTION, moduleId, 'lessons', lessonId));\n   238→    if (!snap.exists()) return { success: false, error: 'Clase no encontrada' };\n   239→    return { success: true, lesson: { id: snap.id, ...snap.data() } };\n   240→  } catch (err) {\n   241→    return { success: false, error: 'Error al cargar la clase' };\n   242→  }\n   243→}\n   244→\n   245→/**\n   246→ * Create a lesson in a module.\n   247→ * @param {string} moduleId\n   248→ * @param {Omit<Lesson, 'id'>} data\n   249→ * @returns {Promise<{success: boolean, id?: string, error?: string}>}\n   250→ */\n   251→export async function createLesson(moduleId, data) {\n   252→  if (!moduleId) return { success: false, error: 'ID del módulo es obligatorio' };\n   253→\n   254→  const validation = validateLesson(data);\n   255→  if (!validation.valid) return { success: false, error: validation.error };\n   256→\n   257→  try {\n   258→    const ref = await addDoc(collection(db, COLLECTION, moduleId, 'lessons'), {\n   259→      title: data.title.trim(),\n   260→      description: data.description || '',\n   261→      order: data.order,\n   262→      videoUrl: data.videoUrl || '',\n   263→      documentation: data.documentation || '',\n   264→      createdAt: serverTimestamp(),\n   265→    });\n   266→    return { success: true, id: ref.id };\n   267→  } catch (err) {\n   268→    return { success: false, error: 'Error al crear la clase' };\n   269→  }\n   270→}\n   271→\n   272→/**\n   273→ * Update a lesson.\n   274→ * @param {string} moduleId\n   275→ * @param {string} lessonId\n   276→ * @param {Partial<Lesson>} updates\n   277→ * @returns {Promise<{success: boolean, error?: string}>}\n   278→ */\n   279→export async function updateLesson(moduleId, lessonId, updates) {\n   280→  if (!moduleId) return { success: false, error: 'ID del módulo es obligatorio' };\n   281→  if (!lessonId) return { success: false, error: 'ID de la clase es obligatorio' };\n   282→\n   283→  try {\n   284→    await updateDoc(doc(db, COLLECTION, moduleId, 'lessons', lessonId), updates);\n   285→    return { success: true };\n   286→  } catch (err) {\n   287→    return { success: false, error: 'Error al actualizar la clase' };\n   288→  }\n   289→}\n   290→\n   291→/**\n   292→ * Delete a lesson.\n   293→ * @param {string} moduleId\n   294→ * @param {string} lessonId\n   295→ * @returns {Promise<{success: boolean, error?: string}>}\n   296→ */\n   297→export async function deleteLesson(moduleId, lessonId) {\n   298→  if (!moduleId) return { success: false, error: 'ID del módulo es obligatorio' };\n   299→  if (!lessonId) return { success: false, error: 'ID de la clase es obligatorio' };\n   300→\n   301→  try {\n   302→    await deleteDoc(doc(db, COLLECTION, moduleId, 'lessons', lessonId));\n   303→    return { success: true };\n   304→  } catch (err) {\n   305→    return { success: false, error: 'Error al eliminar la clase' };\n   306→  }\n   307→}\n   308→\n   309→/* ── Reordering ────────────────────────────────────────────── */\n   310→\n   311→/**\n   312→ * Move a module up or down by swapping order with its neighbor.\n   313→ * @param {{ id: string, order: number }[]} modules - Current modules sorted by order\n   314→ * @param {string} moduleId\n   315→ * @param {'up' | 'down'} direction\n   316→ * @returns {Promise<{success: boolean, error?: string}>}\n   317→ */\n   318→export async function reorderModule(modules, moduleId, direction) {\n   319→  const swap = computeSwap(modules, moduleId, direction);\n   320→  if (!swap) return { success: false, error: 'No se puede mover en esa dirección' };\n   321→\n   322→  try {\n   323→    const batch = writeBatch(db);\n   324→    batch.update(doc(db, COLLECTION, swap.item.id), { order: swap.item.order });\n   325→    batch.update(doc(db, COLLECTION, swap.neighbor.id), { order: swap.neighbor.order });\n   326→    await batch.commit();\n   327→    return { success: true };\n   328→  } catch (err) {\n   329→    return { success: false, error: 'Error al reordenar el módulo' };\n   330→  }\n   331→}\n   332→\n   333→/**\n   334→ * Move a lesson up or down by swapping order with its neighbor.\n   335→ * @param {string} moduleId\n   336→ * @param {{ id: string, order: number }[]} lessons - Current lessons sorted by order\n   337→ * @param {string} lessonId\n   338→ * @param {'up' | 'down'} direction\n   339→ * @returns {Promise<{success: boolean, error?: string}>}\n   340→ */\n   341→export async function reorderLesson(moduleId, lessons, lessonId, direction) {\n   342→  const swap = computeSwap(lessons, lessonId, direction);\n   343→  if (!swap) return { success: false, error: 'No se puede mover en esa dirección' };\n   344→\n   345→  try {\n   346→    const batch = writeBatch(db);\n   347→    batch.update(doc(db, COLLECTION, moduleId, 'lessons', swap.item.id), { order: swap.item.order });\n   348→    batch.update(doc(db, COLLECTION, moduleId, 'lessons', swap.neighbor.id), { order: swap.neighbor.order });\n   349→    await batch.commit();\n   350→    return { success: true };\n   351→  } catch (err) {\n   352→    return { success: false, error: 'Error al reordenar la clase' };\n   353→  }\n   354→}\n   355→"}]},"parent_tool_use_id":"toolu_01PviopKjwtvPxPXj5fcZ46W","session_id":"6dab462c-976e-4fe8-a358-d44adb2c1366","uuid":"397af950-add8-4c17-a78b-4326912dc908"} (stream=stdout)
