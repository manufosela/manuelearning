02:08:52.907 [agent:output] [coder] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RFkztcBMUQXd642cHL4taD","type":"tool_result","content":"     1→import { collection, getDocs, query, where } from 'firebase/firestore';\n     2→import { db } from './config.js';\n     3→\n     4→/**\n     5→ * @typedef {Object} AdminDashboardStats\n     6→ * @property {number} totalUsers\n     7→ * @property {number} activeUsersLast7Days\n     8→ * @property {number} totalQuizzes\n     9→ * @property {number} quizzesCompleted\n    10→ * @property {number} approvalRate - percentage 0-100\n    11→ * @property {{ cohortId: string, cohortName: string, avgProgress: number }[]} progressByCohort\n    12→ */\n    13→\n    14→/**\n    15→ * Count total registered users.\n    16→ * @returns {Promise<number>}\n    17→ */\n    18→export async function countTotalUsers() {\n    19→  const snapshot = await getDocs(collection(db, 'users'));\n    20→  return snapshot.size;\n    21→}\n    22→\n    23→/**\n    24→ * Count users who completed at least one lesson in the last 7 days.\n    25→ * @returns {Promise<number>}\n    26→ */\n    27→export async function countActiveUsersLast7Days() {\n    28→  const sevenDaysAgo = new Date();\n    29→  sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);\n    30→\n    31→  const ref = collection(db, 'progress');\n    32→  const q = query(ref, where('completed', '==', true));\n    33→  const snapshot = await getDocs(q);\n    34→\n    35→  const activeUserIds = new Set();\n    36→  for (const doc of snapshot.docs) {\n    37→    const data = doc.data();\n    38→    if (data.completedAt && data.completedAt.toDate) {\n    39→      const completedDate = data.completedAt.toDate();\n    40→      if (completedDate >= sevenDaysAgo) {\n    41→        activeUserIds.add(data.userId);\n    42→      }\n    43→    }\n    44→  }\n    45→\n    46→  return activeUserIds.size;\n    47→}\n    48→\n    49→/**\n    50→ * Count total quiz responses (completed quizzes).\n    51→ * @returns {Promise<number>}\n    52→ */\n    53→export async function countQuizzesCompleted() {\n    54→  const snapshot = await getDocs(collection(db, 'quizResponses'));\n    55→  return snapshot.size;\n    56→}\n    57→\n    58→/**\n    59→ * Calculate average progress per cohort.\n    60→ * Returns an array with one entry per cohort, including the average completion\n    61→ * percentage of all users in that cohort.\n    62→ * @returns {Promise<{ cohortId: string, cohortName: string, avgProgress: number }[]>}\n    63→ */\n    64→export async function getProgressByCohort() {\n    65→  const usersSnap = await getDocs(collection(db, 'users'));\n    66→  const cohortsSnap = await getDocs(collection(db, 'cohorts'));\n    67→  const progressSnap = await getDocs(\n    68→    query(collection(db, 'progress'), where('completed', '==', true)),\n    69→  );\n    70→  const modulesSnap = await getDocs(collection(db, 'modules'));\n    71→\n    72→  const cohortMap = new Map();\n    73→  for (const doc of cohortsSnap.docs) {\n    74→    cohortMap.set(doc.id, doc.data().name);\n    75→  }\n    76→\n    77→  let totalLessons = 0;\n    78→  for (const doc of modulesSnap.docs) {\n    79→    const data = doc.data();\n    80→    totalLessons += data.lessonCount || 0;\n    81→  }\n    82→\n    83→  const progressByUser = new Map();\n    84→  for (const doc of progressSnap.docs) {\n    85→    const data = doc.data();\n    86→    const count = progressByUser.get(data.userId) || 0;\n    87→    progressByUser.set(data.userId, count + 1);\n    88→  }\n    89→\n    90→  const cohortProgress = new Map();\n    91→  for (const doc of usersSnap.docs) {\n    92→    const user = doc.data();\n    93→    const cohortId = user.cohortId;\n    94→    if (!cohortId) continue;\n    95→\n    96→    if (!cohortProgress.has(cohortId)) {\n    97→      cohortProgress.set(cohortId, { total: 0, sumPercent: 0 });\n    98→    }\n    99→\n   100→    const entry = cohortProgress.get(cohortId);\n   101→    entry.total += 1;\n   102→    const completed = progressByUser.get(doc.id) || 0;\n   103→    const percent = totalLessons > 0 ? Math.round((completed / totalLessons) * 100) : 0;\n   104→    entry.sumPercent += percent;\n   105→  }\n   106→\n   107→  const result = [];\n   108→  for (const [cohortId, stats] of cohortProgress) {\n   109→    result.push({\n   110→      cohortId,\n   111→      cohortName: cohortMap.get(cohortId) || cohortId,\n   112→      avgProgress: stats.total > 0 ? Math.round(stats.sumPercent / stats.total) : 0,\n   113→    });\n   114→  }\n   115→\n   116→  return result;\n   117→}\n   118→\n   119→/**\n   120→ * Fetch all admin dashboard stats in one call.\n   121→ * @returns {Promise<{success: boolean, stats?: AdminDashboardStats, error?: string}>}\n   122→ */\n   123→export async function fetchAdminDashboardStats() {\n   124→  try {\n   125→    const [totalUsers, activeUsersLast7Days, quizzesCompleted, progressByCohort] =\n   126→      await Promise.all([\n   127→        countTotalUsers(),\n   128→        countActiveUsersLast7Days(),\n   129→        countQuizzesCompleted(),\n   130→        getProgressByCohort(),\n   131→      ]);\n   132→\n   133→    const totalQuizzes = (await getDocs(collection(db, 'quizzes'))).size;\n   134→    const approvalRate = totalQuizzes > 0 ? Math.round((quizzesCompleted / totalQuizzes) * 100) : 0;\n   135→\n   136→    return {\n   137→      success: true,\n   138→      stats: {\n   139→        totalUsers,\n   140→        activeUsersLast7Days,\n   141→        totalQuizzes,\n   142→        quizzesCompleted,\n   143→        approvalRate,\n   144→        progressByCohort,\n   145→      },\n   146→    };\n   147→  } catch (err) {\n   148→    return { success: false, error: 'Error al cargar estadísticas del dashboard' };\n   149→  }\n   150→}\n   151→"}]},"parent_tool_use_id":"toolu_01JkAY4iRZBT4gU6S9PgBH7M","session_id":"9154919e-bd9a-4b77-8ff1-a9fd5df9d7fe","uuid":"fe9c225d-56d9-48ad-89e2-7d40aee75fe5"} (stream=stdout)
