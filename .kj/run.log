n   126→  </script>\n   127→  <script>\n   128→    import { onAuthChange, logoutUser } from '../lib/firebase/auth.js';\n   129→\n   130→    const loginBtn = document.getElementById('header-login-btn');\n   131→    const userBlock = document.getElementById('header-user');\n   132→    const userAvatar = document.getElementById('header-user-avatar');\n   133→    const userName = document.getElementById('header-user-name');\n   134→    const logoutBtn = document.getElementById('header-logout-btn');\n   135→\n   136→    if (loginBtn && userBlock) {\n   137→      onAuthChange((user) => {\n   138→        if (user) {\n   139→          loginBtn.style.display = 'none';\n   140→          userBlock.style.display = 'flex';\n   141→          userName.textContent = user.displayName || user.email;\n   142→          if (user.photoURL) {\n   143→            userAvatar.src = user.photoURL;\n   144→            userAvatar.alt = user.displayName || '';\n   145→            userAvatar.style.display = 'block';\n   146→          } else {\n   147→            userAvatar.style.display = 'none';\n   148→          }\n   149→        } else {\n   150→          loginBtn.style.display = '';\n   151→          userBlock.style.display = 'none';\n   152→        }\n   153→      });\n   154→\n   155→      logoutBtn?.addEventListener('click', async () => {\n   156→        await logoutUser();\n   157→        window.location.href = '/';\n   158→      });\n   159→    }\n   160→  </script>\n   161→</body>\n   162→</html>\n   163→\n   164→<style is:global>\n   165→  @import '../styles/global.css';\n   166→</style>\n   167→\n   168→<style>\n   169→  /* --- Page wrapper --- */\n   170→  .page-wrapper {\n   171→    display: flex;\n   172→    flex-direction: column;\n   173→    min-height: 100vh;\n   174→    overflow-x: hidden;\n   175→  }\n   176→\n   177→  /* --- Header --- */\n   178→  .site-header {\n   179→    display: flex;\n   180→    align-items: center;\n   181→    justify-content: space-between;\n   182→  