.75rem);\n    54→    font-weight: 700;\n    55→    color: var(--color-text-primary);\n    56→    margin-top: 0.5rem;\n    57→  }\n    58→\n    59→  .error-page__subtitle {\n    60→    font-size: 1rem;\n    61→    color: var(--color-text-secondary);\n    62→    margin-top: 0.75rem;\n    63→    line-height: 1.6;\n    64→  }\n    65→\n    66→  .error-page__actions {\n    67→    display: flex;\n    68→    gap: 1rem;\n    69→    justify-content: center;\n    70→    margin-top: 2rem;\n    71→    flex-wrap: wrap;\n    72→  }\n    73→</style>\n    74→"}]},"parent_tool_use_id":null,"session_id":"4661b799-4826-4795-9452-6719b55dcaae","uuid":"870bb681-f3eb-4f80-985f-8ca317628bd3","tool_use_result":{"type":"text","file":{"filePath":"/home/manu/ws_firebase/manuelearning/src/pages/404.astro","content":"---\nimport MainLayout from '../layouts/MainLayout.astro';\n---\n\n<MainLayout title=\"404 | Página no encontrada\">\n  <section class=\"error-page\">\n    <div class=\"error-page__content\">\n      <span class=\"material-symbols-outlined error-page__icon\">explore_off</span>\n      <p class=\"error-page__code\">404</p>\n      <h1 class=\"error-page__title\">Página no encontrada</h1>\n      <p class=\"error-page__subtitle\">\n        La página que buscas no existe o ha sido movida.\n      </p>\n      <div class=\"error-page__actions\">\n        <a href=\"/\" class=\"btn btn--primary btn--md\">Ir al inicio</a>\n        <a href=\"/dashboard\" class=\"btn btn--secondary btn--md\">Ir al dashboard</a>\n      </div>\n    </div>\n  </section>\n</MainLayout>\n\n<style>\n  .error-page {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    min-height: calc(100vh - 200px);\n    padding: 2rem var(--section-px);\n    text-align: center;\n  }\n\n  .error-page__content {\n    max-width: 480px;\n  }\n\n  .error-page__icon {\n    font-size: 4rem;\n    color: var(--color-text-muted);\n    margin-bottom: 1rem;\n  }\n\n  .error-page__code {\n    font-family: var(--font-display);\n    font-size: clamp(5rem, 15vw, 8rem);\n    font-weight: 900;\n    line-height: 1;\n    color: var(--color-primary);\n    letter-spacing: -0.04em;\n  }\n\n  .error-page__title {\n    font-family: var(--font-display);\n    font-size: clamp(1.25rem, 3vw, 1.75rem);\n    font-weight: 700;\n    color: var(--color-text-primary);\n    margin-top: 0.5rem;\n  }\n\n  .error-page__subtitle {\n    font-size: 1rem;\n    color: var(--color-text-secondary);\n    margin-top: 0.75rem;\n    line-height: 1.6;\n  }\n\n  .error-page__actions {\n    display: flex;\n    gap: 1rem;\n    justify-content: center;\n    margin-top: 2rem;\n    flex-wrap: wrap;\n  }\n</style>\n","numLines":74,"startLine":1,"totalLines":74}}} (stream=stdout)
