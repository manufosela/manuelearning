20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);\n  --shadow-2xl: 0 25px 50px -12px rgb(0 0 0 / 0.25);\n\n  /* Transitions */\n  --transition-fast: 150ms ease;\n  --transition-base: 300ms ease;\n}\n\n/* --- Reset --- */\n*,\n*::before,\n*::after {\n  box-sizing: border-box;\n  margin: 0;\n  padding: 0;\n}\n\nhtml {\n  scroll-behavior: smooth;\n  -webkit-text-size-adjust: 100%;\n}\n\nbody {\n  font-family: var(--font-display);\n  background-color: var(--color-bg-light);\n  color: var(--color-text-primary);\n  line-height: 1.6;\n  min-height: 100vh;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n}\n\nimg {\n  max-width: 100%;\n  height: auto;\n  display: block;\n}\n\na {\n  color: inherit;\n  text-decoration: none;\n}\n\nbutton {\n  cursor: pointer;\n  border: none;\n  background: none;\n  font-family: inherit;\n  font-size: inherit;\n}\n\nul, ol {\n  list-style: none;\n}\n\n/* --- Utility classes --- */\n.container {\n  max-width: var(--container-max);\n  margin-inline: auto;\n  padding-inline: var(--section-px);\n}\n\n.sr-only {\n  position: absolute;\n  width: 1px;\n  height: 1px;\n  padding: 0;\n  margin: -1px;\n  overflow: hidden;\n  clip: rect(0, 0, 0, 0);\n  white-space: nowrap;\n  border: 0;\n}\n\n/* --- Buttons --- */\n.btn {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  font-weight: 700;\n  border-radius: var(--radius-md);\n  transition: all var(--transition-base);\n  white-space: nowrap;\n}\n\n.btn--primary {\n  background: var(--gradient-primary);\n  color: #0f172a;\n  box-shadow: 0 4px 14px var(--color-primary-shadow);\n}\n\n.btn--primary:hover {\n  filter: brightness(1.1);\n}\n\n.btn--outline {\n  background-color: transparent;\n  color: var(--color-secondary);\n  border: 1px solid var(--color-secondary);\n  backdrop-filter: blur(12px);\n}\n\n.btn--outline:hover {\n  background-color: rgba(34, 211, 238, 0.1);\n}\n\n.btn--secondary {\n  background-color: var(--color-bg-slate-50);\n  color: var(--color-text-primary);\n  border: 1px solid var(--color-border);\n}\n\n.btn--secondary:hover {\n  background-color: var(--color-border);\n}\n\n.btn--lg {\n  height: 3.5rem;\n  padding-inline: 2rem;\n  font-size: 1rem;\n  min-width: 200px;\n}\n\n.btn--md {\n  height: 3rem;\n  padding-inline: 2rem;\n  font-size: 0.875rem;\n}\n\n.btn--sm {\n  height: 2.5rem;\n  padding-inline: 1.25rem;\n  font-size: 0.875rem;\n  min-width: 120px;\n}\n\n/* --- Section headings --- */\n.section-label {\n  color: var(--color-primary);\n  font-size: 0.875rem;\n  font-weight: 700;\n  text-transform: uppercase;\n  letter-spacing: 0.2em;\n}\n\n.section-title {\n  font-size: clamp(2rem, 5vw, 3rem);\n  font-weight: 900;\n  letter-spacing: -0.02em;\n  line-height: 1.1;\n}\n\n.section-divider {\n  height: 0.375rem;\n  width: 6rem;\n  background: var(--gradient-primary);\n  border-radius: var(--radius-full);\n  margin-top: 0.5rem;\n}\n","numLines":214,"startLine":1,"totalLines":214}}} (stream=stdout)
