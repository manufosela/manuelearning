  317→  @media (min-width: 1024px) {\n   318→    .why-lean__grid {\n   319→      grid-template-columns: 1fr 1fr;\n   320→    }\n   321→  }\n   322→\n   323→  .why-lean__image-wrapper {\n   324→    position: relative;\n   325→  }\n   326→\n   327→  .why-lean__image {\n   328→    aspect-ratio: 1 / 1;\n   329→    border-radius: var(--radius-2xl);\n   330→    overflow: hidden;\n   331→    box-shadow: var(--shadow-2xl);\n   332→  }\n   333→\n   334→  .why-lean__image img {\n   335→    width: 100%;\n   336→    height: 100%;\n   337→    object-fit: cover;\n   338→  }\n   339→\n   340→  .why-lean__stats {\n   341→    display: none;\n   342→    position: absolute;\n   343→    bottom: -1.5rem;\n   344→    right: -1.5rem;\n   345→    gap: 0.75rem;\n   346→  }\n   347→\n   348→  @media (min-width: 768px) {\n   349→    .why-lean__stats {\n   350→      display: flex;\n   351→    }\n   352→  }\n   353→\n   354→  .why-lean__stat {\n   355→    background: var(--gradient-primary);\n   356→    color: #0f172a;\n   357→    padding: 1rem 1.25rem;\n   358→    border-radius: var(--radius-xl);\n   359→    box-shadow: var(--shadow-xl);\n   360→    text-align: center;\n   361→    min-width: 5.5rem;\n   362→  }\n   363→\n   364→  .why-lean__stat-number {\n   365→    font-size: 1.75rem;\n   366→    font-weight: 900;\n   367→    line-height: 1;\n   368→  }\n   369→\n   370→  .why-lean__stat-label {\n   371→    font-size: 0.625rem;\n   372→    font-weight: 600;\n   373→    text-transform: uppercase;\n   374→    letter-spacing: 0.05em;\n   375→    margin-top: 0.25rem;\n   376→  }\n   377→\n   378→  .why-lean__content {\n   379→    display: flex;\n   380→    flex-direction: column;\n   381→    gap: 2rem;\n   382→  }\n   383→\n   384→  .why-lean__title {\n   385→    font-size: clamp(2rem, 5vw, 3rem);\n   386→    font-weight: 900;\n   387→    line-height: 1.15;\n   388→    color: var(--color-text-primary);\n   389→  }\n   390→\n   391→  .why-lean__description {\n   392→    font-size: 1.125rem;\n   393→    color: var(--color-text-secondary);\n   394→    line-height: 1.7;\n   395→  }\n   396→\n   397→  .why-lean__features {\n   398→    display: flex;\n   399→    flex-direction: column;\n   400→    gap: 1rem;\n   401→  }\n   402→\n   403→  .why-lean__features li {\n   404→    display: flex;\n   405→    align-items: flex-start;\n   406→    gap: 0.75rem;\n   407→  }\n   408→\n   409→  .why-lean__features li span.material-symbols-outlined {\n   410→    color: var(--color-primary);\n   411→    flex-shrink: 0;\n   412→  }\n   413→\n   414→</style>\n   415→"}]},"parent_tool_use_id":null,"session_id":"985edf6b-e54e-4efc-8f06-97f1925862cd","uuid":"49bc1eaa-7a1d-4de0-bef2-9835a640b18b","tool_use_result":{"type":"text","file":{"filePath":"/home/manu/ws_firebase/manuelearning/src/pages/index.astro","content":"---\nimport MainLayout from '../layouts/MainLayout.astro';\nimport { SITE } from '../config/site.config.js';\n---\n\n<MainLayout>\n  <!-- Hero Section -->\n  <section class=\"hero-wrapper\">\n    <div class=\"hero\" style=\"background-image: linear-gradient(to right, #0f172a 0%, #1a2e05 100%), url('/images/hero-background.jpg');\">\n      <div class=\"hero__content\">\n        <div class=\"hero__badge\">\n          <span class=\"material-symbols-outlined\">verified</span>\n          <span>Formación directa, práctica y sin filtros</span>\n        </div>\n        <h1 class=\"hero__title\">\n          Aprende tecnología de verdad.\n          <br /><span class=\"hero__title--accent\">Sin rodeos.</span>\n        </h1>\n        <p class=\"hero__description\">\n          Plataforma de formación online de Mánu Fosela — cursos prácticos de desarrollo web, Docker y más, para quien quiera aprender con quien ya lo ha vivido.\n        </p>\n        <div class=\"hero__actions\">\n          <a href=\"/cursos\" class=\"btn btn--primary btn--lg hero__btn-white\">Ver cursos disponibles</a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Services Section -->\n  <section class=\"services\" id=\"services\">\n    <div class=\"services__header\">\n      <h2 class=\"section-label\">Cursos</h2>\n      <h3 class=\"section-title\">¿Qué cursos ofrezco?</h3>\n      <div class=\"section-divider\"></div>\n    </div>\n    <div class=\"services__grid\">\n      <article class=\"service-card\">\n        <div class=\"service-card__icon\">\n          <span class=\"material-symbols-outlined\">deployed_code</span>\n        </div>\n        <h4 class=\"service-card__title\">Docker desde cero</h4>\n        <p class=\"service-card__text\">Contenedores, imágenes, volúmenes, redes y docker-compose. Del \"funciona en mi máquina\" al despliegue real.</p>\n      </article>\n      <article class=\"service-card\">\n        <div class=\"service-card__icon\">\n          <span class=\"material-symbols-outlined\">code</span>\n        </div>\n        <h4 class=\"service-card__title\">JavaScript moderno</h4>\n        <p class=\"service-card__text\">Fundamentos sólidos, DOM, fetch, promesas y patrones reales. El JS que se usa, no el de los libros.</p>\n      </article>\n      <article class=\"service-card\">\n        <div class=\"service-card__icon\">\n          <span class=\"material-symbols-outlined\">directions_car</span>\n        </div>\n        <h4 class=\"service-card__title\">Aprende a conducir</h4>\n        <p class=\"service-card__text\">Teoría, señales, maniobras y test de práctica. Todo lo que necesitas para sacarte el carné.</p>\n      </article>\n    </div>\n  </section>\n\n  <!-- Why Lean Section -->\n  <section class=\"why-lean\" id=\"why-lean\">\n    <div class=\"why-lean__grid\">\n      <div class=\"why-lean__image-wrapper\">\n        <div class=\"why-lean__image\">\n          <img src=\"/images/engineer-tablet.jpg\" alt=\"Profesional de construcción revisando planos digitales en una tablet\" />\n        </div>\n        <div class=\"why-lean__stats\">\n          <div class=\"why-lean__stat\">\n            <p class=\"why-lean__stat-number\">+25</p>\n            <p class=\"why-lean__stat-label\">desarrollando software</p>\n          </div>\n          <div class=\"why-lean__stat\">\n            <p class=\"why-lean__stat-number\">+15</p>\n            <p class=\"why-lean__stat-label\">mentorizando juniors</p>\n          </div>\n          <div class=\"why-lean__stat\">\n            <p class=\"why-lean__stat-number\">+10</p>\n            <p class=\"why-lean__stat-label\">liderando equipos</p>\n          </div>\n        </div>\n      </div>\n      <div class=\"why-lean__content\">\n        <h2 class=\"section-label\">¿Para quién es esto?</h2>\n        <h3 class=\"why-lean__title\">Para quien quiere aprender con alguien de verdad</h3>\n        <p class=\"why-lean__description\">\n          Esta plataforma no es un marketplace ni una academia masiva. Es un espacio de formación personal donde comparto lo que sé con personas a las que conozco o que me conocen. Si estás empezando en el mundo del desarrollo, si quieres entender Docker de una vez, o si buscas algo más cercano que un tutorial de YouTube — puede que estés en el sitio correcto.\n        </p>\n        <ul class=\"why-lean__features\">\n          <li>\n            <span class=\"material-symbols-outlined\">check_circle</span>\n            <span>Acceso solo por invitación — aprendes con contexto y sin ruido</span>\n          </li>\n          <li>\n            <span class=\"material-symbols-outlined\">check_circle</span>\n            <span>Cursos basados en proyectos reales, no en ejemplos de juguete</span>\n          </li>\n          <li>\n            <span class=\"material-symbols-outlined\">check_circle</span>\n            <span>Soporte directo — puedes preguntarme a mí</span>\n          </li>\n        </ul>\n        <a href=\"/solicitar-acceso\" class=\"btn btn--primary btn--md\" id=\"cta-access\">Solicitar acceso</a>\n      </div>\n    </div>\n  </section>\n\n</MainLayout>\n\n<script>\n  import { onAuthChange } from '../lib/firebase/auth.js';\n\n  const ctaBtn = document.getElementById('cta-access');\n  if (ctaBtn) {\n    onAuthChange((user) => {\n      if (user) {\n        ctaBtn.href = '/cursos';\n        ctaBtn.textContent = 'Ir a mis cursos';\n      }\n    });\n  }\n</script>\n\n<style>\n  /* --- Hero --- */\n  .hero-wrapper {\n    padding: 2rem var(--section-px);\n  }\n\n  .hero {\n    position: relative;\n    min-height: 560px;\n    display: flex;\n    flex-direction: column;\n    align-items: flex-start;\n    justify-content: center;\n    overflow: hidden;\n    border-radius: var(--radius-xl);\n    padding: 2rem;\n    background-size: cover;\n    background-position: center;\n  }\n\n  @media (min-width: 768px) {\n    .hero {\n      padding: 2rem 4rem;\n    }\n  }\n\n  .hero__content {\n    max-width: 720px;\n    display: flex;\n    flex-direction: column;\n    gap: 1.5rem;\n  }\n\n  .hero__badge {\n    display: inline-flex;\n    align-items: center;\n    gap: 0.5rem;\n    padding: 0.25rem 0.75rem;\n    border-radius: var(--radius-full);\n    background: linear-gradient(to right, rgba(132, 204, 22, 0.15), rgba(251, 146, 60, 0.15));\n    color: var(--color-primary);\n    border: 1px solid rgba(132, 204, 22, 0.3);\n    width: fit-content;\n  }\n\n  .hero__badge span.material-symbols-outlined {\n    font-size: 0.875rem;\n  }\n\n  .hero__badge span:last-child {\n    font-size: 0.75rem;\n    font-weight: 700;\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n  }\n\n  .hero__title {\n    font-size: clamp(2.5rem, 6vw, 3.75rem);\n    font-weight: 900;\n    line-height: 1.1;\n    letter-spacing: -0.02em;\n    background: var(--gradient-primary);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    background-clip: text;\n  }\n\n  .hero__title--accent {\n    opacity: 0.85;\n  }\n\n  .hero__description {\n    color: #f1f5f9;\n    font-size: clamp(1rem, 2vw, 1.25rem);\n    font-weight: 400;\n    line-height: 1.6;\n    opacity: 0.9;\n  }\n\n  .hero__actions {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 1rem;\n    padding-top: 1rem;\n  }\n\n  .hero__btn-white {\n    background: var(--gradient-primary);\n    color: #0f172a;\n    box-shadow: var(--shadow-lg);\n  }\n\n  .hero__btn-white:hover {\n    transform: scale(1.05);\n    filter: brightness(1.1);\n  }\n\n  /* --- Services --- */\n  .services {\n    padding: var(--section-py) var(--section-px);\n    background-color: var(--color-bg-white);\n  }\n\n  .services__header {\n    max-width: var(--container-max);\n    margin-inline: auto;\n    display: flex;\n    flex-direction: column;\n    gap: 1rem;\n    margin-bottom: 4rem;\n    text-align: center;\n    align-items: center;\n  }\n\n  .services__grid {\n    max-width: var(--container-max);\n    margin-inline: auto;\n    display: grid;\n    grid-template-columns: 1fr;\n    gap: 2rem;\n  }\n\n  @media (min-width: 768px) {\n    .services__grid {\n      grid-template-columns: repeat(3, 1fr);\n    }\n  }\n\n  .service-card {\n    position: relative;\n    display: flex;\n    flex-direction: column;\n    gap: 1.5rem;\n    border-radius: var(--radius-xl);\n    border: 2px solid var(--color-border);\n    background-color: var(--color-bg-white);\n    padding: 2rem;\n    transition: all var(--transition-base);\n  }\n\n  .service-card:hover {\n    box-shadow: var(--shadow-2xl);\n    border-color: var(--color-primary);\n  }\n\n  .service-card__icon {\n    width: 3.5rem;\n    height: 3.5rem;\n    border-radius: var(--radius-md);\n    background-color: rgba(34, 211, 238, 0.1);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    color: var(--color-secondary);\n    transition: all var(--transition-base);\n  }\n\n  .service-card:hover .service-card__icon {\n    background-color: var(--color-secondary);\n    color: #0f172a;\n  }\n\n  .service-card__icon span {\n    font-size: 1.875rem;\n  }\n\n  .service-card__title {\n    font-size: 1.25rem;\n    font-weight: 700;\n    color: var(--color-text-primary);\n  }\n\n  .service-card__text {\n    color: var(--color-text-secondary);\n    line-height: 1.7;\n  }\n\n  /* --- Why Lean --- */\n  .why-lean {\n    padding: 6rem var(--section-px);\n    background-color: var(--color-bg-slate-50);\n    color: var(--color-text-primary);\n  }\n\n  .why-lean__grid {\n    max-width: var(--container-max);\n    margin-inline: auto;\n    display: grid;\n    grid-template-columns: 1fr;\n    gap: 4rem;\n    align-items: center;\n  }\n\n  @media (min-width: 1024px) {\n    .why-lean__grid {\n      grid-template-columns: 1fr 1fr;\n    }\n  }\n\n  .why-lean__image-wrapper {\n    position: relative;\n  }\n\n  .why-lean__image {\n    aspect-ratio: 1 / 1;\n    border-radius: var(--radius-2xl);\n    overflow: hidden;\n    box-shadow: var(--shadow-2xl);\n  }\n\n  .why-lean__image img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n  }\n\n  .why-lean__stats {\n    display: none;\n    position: absolute;\n    bottom: -1.5rem;\n    right: -1.5rem;\n    gap: 0.75rem;\n  }\n\n  @media (min-width: 768px) {\n    .why-lean__stats {\n      display: flex;\n    }\n  }\n\n  .why-lean__stat {\n    background: var(--gradient-primary);\n    color: #0f172a;\n    padding: 1rem 1.25rem;\n    border-radius: var(--radius-xl);\n    box-shadow: var(--shadow-xl);\n    text-align: center;\n    min-width: 5.5rem;\n  }\n\n  .why-lean__stat-number {\n    font-size: 1.75rem;\n    font-weight: 900;\n    line-height: 1;\n  }\n\n  .why-lean__stat-label {\n    font-size: 0.625rem;\n    font-weight: 600;\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n    margin-top: 0.25rem;\n  }\n\n  .why-lean__content {\n    display: flex;\n    flex-direction: column;\n    gap: 2rem;\n  }\n\n  .why-lean__title {\n    font-size: clamp(2rem, 5vw, 3rem);\n    font-weight: 900;\n    line-height: 1.15;\n    color: var(--color-text-primary);\n  }\n\n  .why-lean__description {\n    font-size: 1.125rem;\n    color: var(--color-text-secondary);\n    line-height: 1.7;\n  }\n\n  .why-lean__features {\n    display: flex;\n    flex-direction: column;\n    gap: 1rem;\n  }\n\n  .why-lean__features li {\n    display: flex;\n    align-items: flex-start;\n    gap: 0.75rem;\n  }\n\n  .why-lean__features li span.material-symbols-outlined {\n    color: var(--color-primary);\n    flex-shrink: 0;\n  }\n\n</style>\n","numLines":415,"startLine":1,"totalLines":415}}} (stream=stdout)
