und-color: var(--color-primary);\n   331→  }\n   332→\n   333→  .site-footer__social a span {\n   334→    font-size: 1.125rem;\n   335→  }\n   336→\n   337→  .site-footer__links h4 {\n   338→    color: var(--color-text-white);\n   339→    font-weight: 700;\n   340→    margin-bottom: 1.5rem;\n   341→    text-transform: uppercase;\n   342→    font-size: 0.75rem;\n   343→    letter-spacing: 0.15em;\n   344→  }\n   345→\n   346→  .site-footer__links ul {\n   347→    display: flex;\n   348→    flex-direction: column;\n   349→    gap: 1rem;\n   350→    font-size: 0.875rem;\n   351→  }\n   352→\n   353→  .site-footer__links li {\n   354→    display: flex;\n   355→    gap: 0.5rem;\n   356→    align-items: center;\n   357→  }\n   358→\n   359→  .site-footer__links li span {\n   360→    font-size: 0.875rem;\n   361→  }\n   362→\n   363→  .site-footer__links a:hover {\n   364→    color: var(--color-text-white);\n   365→    transition: color var(--transition-fast);\n   366→  }\n   367→\n   368→  .site-footer__bottom {\n   369→    max-width: var(--container-max);\n   370→    margin-inline: auto;\n   371→    padding-top: 2rem;\n   372→    border-top: 1px solid var(--color-border-dark);\n   373→    display: flex;\n   374→    flex-direction: column;\n   375→    gap: 1rem;\n   376→    align-items: center;\n   377→    font-size: 0.75rem;\n   378→  }\n   379→\n   380→  @media (min-width: 768px) {\n   381→    .site-footer__bottom {\n   382→      flex-direction: row;\n   383→      justify-content: space-between;\n   384→    }\n   385→  }\n   386→\n   387→  .site-footer__legal {\n   388→    display: flex;\n   389→    gap: 1.5rem;\n   390→  }\n   391→\n   392→  .site-footer__legal a:hover {\n   393→    color: var(--color-text-white);\n   394→    transition: color var(--transition-fast);\n   395→  }\n   396→</style>\n   397→"}]},"parent_tool_use_id":null,"session_id":"52a847a5-ff07-442c-ae2c-a5b9cdc021c7","uuid":"4fc770bb-34f1-42e9-a583-0106d8a0418f","tool_use_result":{"type":"text","file":{"filePath":"/home/manu/ws_firebase/manuelearning/src/layouts/MainLayout.astro","content":"---\n/**\n * @typedef {Object} Props\n * @property {string} [title] - Page title\n * @property {string} [description] - Meta description\n * @property {boolean} [hideAuthButton] - Hide the login button in header\n */\n\nimport { SITE } from '../config/site.config.js';\n\n/** @type {Props} */\nconst {\n  title = `${SITE.name} | ${SITE.tagline}`,\n  description = SITE.tagline,\n  hideAuthButton = false,\n} = Astro.props;\n---\n\n<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <meta name=\"description\" content={description} />\n  <link rel=\"icon\" type=\"image/svg+xml\" href=\"/favicon.svg\" />\n  <link rel=\"manifest\" href=\"/manifest.json\" />\n  <meta name=\"theme-color\" content=\"#84cc16\" />\n  <meta name=\"apple-mobile-web-app-capable\" content=\"yes\" />\n  <meta name=\"apple-mobile-web-app-status-bar-style\" content=\"black-translucent\" />\n  <meta name=\"apple-mobile-web-app-title\" content=\"ManuElearning\" />\n  <link rel=\"apple-touch-icon\" href=\"/icons/apple-touch-icon.png\" />\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\" />\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin />\n  <link\n    href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Lexend:wght@400;500;600;700;800;900&display=swap\"\n    rel=\"stylesheet\"\n  />\n  <link\n    href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap\"\n    rel=\"stylesheet\"\n  />\n  <title>{title}</title>\n</head>\n<body>\n  <div class=\"page-wrapper\">\n    <!-- Header -->\n    <header class=\"site-header\">\n      <a href=\"/\" class=\"site-header__brand\">\n        <img src=\"/logo.svg\" alt={SITE.name} class=\"site-header__logo\" />\n      </a>\n      {!hideAuthButton && (\n        <div class=\"site-header__auth\" id=\"header-auth\">\n          <a href=\"/login\" class=\"btn btn--primary btn--sm\" id=\"header-login-btn\">Acceder</a>\n          <div class=\"header-user\" id=\"header-user\" style=\"display:none;\">\n            <a href=\"/dashboard\" class=\"header-user__link\">\n              <img id=\"header-user-avatar\" class=\"header-user__avatar\" src=\"\" alt=\"\" />\n              <span id=\"header-user-name\" class=\"header-user__name\"></span>\n            </a>\n            <button id=\"header-logout-btn\" class=\"header-user__logout\" aria-label=\"Cerrar sesión\">\n              <span class=\"material-symbols-outlined\">logout</span>\n            </button>\n          </div>\n        </div>\n      )}\n    </header>\n\n    <!-- Main content -->\n    <main class=\"site-main\">\n      <slot />\n    </main>\n\n    <!-- Footer -->\n    <footer class=\"site-footer\">\n      <div class=\"site-footer__grid\">\n        <div class=\"site-footer__brand\">\n          <div class=\"site-footer__logo\">\n            <img src=\"/logo.svg\" alt={SITE.name} height=\"32\" />\n          </div>\n          <p>{SITE.tagline}</p>\n          <div class=\"site-footer__social\">\n            <a href=\"#\" aria-label=\"Web\"><span class=\"material-symbols-outlined\">public</span></a>\n            <a href=\"#\" aria-label=\"Chat\"><span class=\"material-symbols-outlined\">chat</span></a>\n            <a href=\"#\" aria-label=\"Email\"><span class=\"material-symbols-outlined\">mail</span></a>\n          </div>\n        </div>\n        <div class=\"site-footer__links\">\n          <h4>Cursos</h4>\n          <ul>\n            <li><a href=\"/curso?c=docker\">Docker</a></li>\n            <li><a href=\"/curso?c=javascript\">JavaScript</a></li>\n            <li><a href=\"/cursos\">Ver todos</a></li>\n          </ul>\n        </div>\n        <div class=\"site-footer__links\">\n          <h4>Recursos</h4>\n          <ul>\n            <li><a href=\"#\">GitHub del curso</a></li>\n            <li><a href=\"#\">Blog</a></li>\n            <li><a href=\"#\">Sobre Mánu</a></li>\n          </ul>\n        </div>\n        <div class=\"site-footer__links\">\n          <h4>Contacto</h4>\n          <ul>\n            <li><span class=\"material-symbols-outlined\">location_on</span> Madrid, España</li>\n            <li><span class=\"material-symbols-outlined\">mail</span> {SITE.contactEmail}</li>\n          </ul>\n        </div>\n      </div>\n      <div class=\"site-footer__bottom\">\n        <p>&copy; {SITE.copyrightYear} {SITE.name}. Todos los derechos reservados.</p>\n        <div class=\"site-footer__legal\">\n          <a href=\"/privacidad\">Política de Privacidad</a>\n          <a href=\"/terminos\">Términos de Servicio</a>\n          <a href=\"/cookies\">Política de Cookies</a>\n        </div>\n      </div>\n    </footer>\n  </div>\n  <script>\n    if ('serviceWorker' in navigator) {\n      window.addEventListener('load', () => {\n        navigator.serviceWorker.register('/service-worker.js');\n      });\n    }\n  </script>\n  <script>\n    import { onAuthChange, logoutUser } from '../lib/firebase/auth.js';\n\n    const loginBtn = document.getElementById('header-login-btn');\n    const userBlock = document.getElementById('header-user');\n    const userAvatar = document.getElementById('header-user-avatar');\n    const userName = document.getElementById('header-user-name');\n    const logoutBtn = document.getElementById('header-logout-btn');\n\n    if (loginBtn && userBlock) {\n      onAuthChange((user) => {\n        if (user) {\n          loginBtn.style.display = 'none';\n          userBlock.style.display = 'flex';\n          userName.textContent = user.displayName || user.email;\n          if (user.photoURL) {\n            userAvatar.src = user.photoURL;\n            userAvatar.alt = user.displayName || '';\n            userAvatar.style.display = 'block';\n          } else {\n            userAvatar.style.display = 'none';\n          }\n        } else {\n          loginBtn.style.display = '';\n          userBlock.style.display = 'none';\n        }\n      });\n\n      logoutBtn?.addEventListener('click', async () => {\n        await logoutUser();\n        window.location.href = '/';\n      });\n    }\n  </script>\n</body>\n</html>\n\n<style is:global>\n  @import '../styles/global.css';\n</style>\n\n<style>\n  /* --- Page wrapper --- */\n  .page-wrapper {\n    display: flex;\n    flex-direction: column;\n    min-height: 100vh;\n    overflow-x: hidden;\n  }\n\n  /* --- Header --- */\n  .site-header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    white-space: nowrap;\n    border-bottom: 1px solid var(--color-border);\n    padding: 1rem var(--section-px);\n    background-color: var(--color-bg-white);\n    position: sticky;\n    top: 0;\n    z-index: 50;\n  }\n\n  .site-header__brand {\n    display: flex;\n    align-items: center;\n  }\n\n  .site-header__logo {\n    height: 2rem;\n    width: auto;\n  }\n\n  .site-header__auth {\n    display: flex;\n    align-items: center;\n  }\n\n  .header-user {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n  }\n\n  .header-user__link {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n    text-decoration: none;\n    color: var(--color-text-primary);\n  }\n\n  .header-user__avatar {\n    width: 2rem;\n    height: 2rem;\n    border-radius: var(--radius-full);\n    object-fit: cover;\n  }\n\n  .header-user__logout {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    color: var(--color-text-secondary);\n    padding: 0.25rem;\n    border-radius: var(--radius-sm);\n    transition: color var(--transition-fast);\n  }\n\n  .header-user__logout:hover {\n    color: #991b1b;\n  }\n\n  .header-user__logout .material-symbols-outlined {\n    font-size: 1.25rem;\n  }\n\n  .header-user__name {\n    display: none;\n    font-size: 0.875rem;\n    font-weight: 600;\n    max-width: 150px;\n    overflow: hidden;\n    text-overflow: ellipsis;\n    white-space: nowrap;\n  }\n\n  @media (min-width: 768px) {\n    .header-user__name {\n      display: inline;\n    }\n  }\n\n  /* --- Main --- */\n  .site-main {\n    flex: 1;\n  }\n\n  /* --- Footer --- */\n  .site-footer {\n    background-color: var(--color-bg-slate-950);\n    color: var(--color-text-on-dark);\n    padding: 5rem var(--section-px) 3rem;\n  }\n\n  .site-footer__grid {\n    max-width: var(--container-max);\n    margin-inline: auto;\n    display: grid;\n    grid-template-columns: 1fr;\n    gap: 3rem;\n    margin-bottom: 4rem;\n  }\n\n  @media (min-width: 768px) {\n    .site-footer__grid {\n      grid-template-columns: 1fr 1fr 1fr 1fr;\n    }\n  }\n\n  .site-footer__brand p {\n    font-size: 0.875rem;\n    line-height: 1.7;\n    margin-bottom: 1.5rem;\n  }\n\n  .site-footer__logo {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n    color: var(--color-text-white);\n    margin-bottom: 1.5rem;\n  }\n\n  .site-footer__logo span {\n    font-size: 1.5rem;\n  }\n\n  .site-footer__logo h2 {\n    font-size: 1.125rem;\n    font-weight: 900;\n    letter-spacing: -0.02em;\n  }\n\n  .site-footer__social {\n    display: flex;\n    gap: 1rem;\n  }\n\n  .site-footer__social a {\n    width: 2rem;\n    height: 2rem;\n    border-radius: var(--radius-full);\n    background-color: #1e293b;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    color: var(--color-text-white);\n    transition: background-color var(--transition-base);\n  }\n\n  .site-footer__social a:hover {\n    background-color: var(--color-primary);\n  }\n\n  .site-footer__social a span {\n    font-size: 1.125rem;\n  }\n\n  .site-footer__links h4 {\n    color: var(--color-text-white);\n    font-weight: 700;\n    margin-bottom: 1.5rem;\n    text-transform: uppercase;\n    font-size: 0.75rem;\n    letter-spacing: 0.15em;\n  }\n\n  .site-footer__links ul {\n    display: flex;\n    flex-direction: column;\n    gap: 1rem;\n    font-size: 0.875rem;\n  }\n\n  .site-footer__links li {\n    display: flex;\n    gap: 0.5rem;\n    align-items: center;\n  }\n\n  .site-footer__links li span {\n    font-size: 0.875rem;\n  }\n\n  .site-footer__links a:hover {\n    color: var(--color-text-white);\n    transition: color var(--transition-fast);\n  }\n\n  .site-footer__bottom {\n    max-width: var(--container-max);\n    margin-inline: auto;\n    padding-top: 2rem;\n    border-top: 1px solid var(--color-border-dark);\n    display: flex;\n    flex-direction: column;\n    gap: 1rem;\n    align-items: center;\n    font-size: 0.75rem;\n  }\n\n  @media (min-width: 768px) {\n    .site-footer__bottom {\n      flex-direction: row;\n      justify-content: space-between;\n    }\n  }\n\n  .site-footer__legal {\n    display: flex;\n    gap: 1.5rem;\n  }\n\n  .site-footer__legal a:hover {\n    color: var(--color-text-white);\n    transition: color var(--transition-fast);\n  }\n</style>\n","numLines":397,"startLine":1,"totalLines":397}}} (stream=stdout)
