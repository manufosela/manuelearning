02:09:22.242 [agent:output] [coder] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016UP5z6nEVoyTy6aE4UtDuy","type":"tool_result","content":"     1→import {\n     2→  collection,\n     3→  doc,\n     4→  getDoc,\n     5→  getDocs,\n     6→  addDoc,\n     7→  updateDoc,\n     8→  deleteDoc,\n     9→  query,\n    10→  where,\n    11→  orderBy,\n    12→  serverTimestamp,\n    13→} from 'firebase/firestore';\n    14→import { db } from './config.js';\n    15→\n    16→const QUIZZES = 'quizzes';\n    17→const RESPONSES = 'quizResponses';\n    18→\n    19→/**\n    20→ * @typedef {Object} QuizQuestion\n    21→ * @property {string} text\n    22→ * @property {'open'|'multiple'} type\n    23→ * @property {string[]} [options]\n    24→ * @property {string} [correctAnswer]\n    25→ */\n    26→\n    27→/**\n    28→ * @typedef {Object} Quiz\n    29→ * @property {string} [id]\n    30→ * @property {string} title\n    31→ * @property {string} moduleId\n    32→ * @property {string} lessonId\n    33→ * @property {QuizQuestion[]} questions\n    34→ * @property {*} [createdAt]\n    35→ */\n    36→\n    37→/**\n    38→ * Validate quiz data.\n    39→ * @param {Partial<Quiz>} data\n    40→ * @returns {{ valid: boolean, error?: string }}\n    41→ */\n    42→export function validateQuiz(data) {\n    43→  if (!data.title || data.title.trim().length === 0) {\n    44→    return { valid: false, error: 'El título es obligatorio' };\n    45→  }\n    46→\n    47→  if (!data.moduleId) {\n    48→    return { valid: false, error: 'El módulo es obligatorio' };\n    49→  }\n    50→\n    51→  if (!data.questions || data.questions.length === 0) {\n    52→    return { valid: false, error: 'Debe tener al menos una pregunta' };\n    53→  }\n    54→\n    55→  for (const q of data.questions) {\n    56→    if (!q.text || q.text.trim().length === 0) {\n    57→      return { valid: false, error: 'Todas las preguntas deben tener texto' };\n    58→    }\n    59→    if (q.type === 'multiple' && (!q.options || q.options.length === 0)) {\n    60→      return { valid: false, error: 'Las preguntas de selección múltiple necesitan opciones' };\n    61→    }\n    62→  }\n    63→\n    64→  return { valid: true };\n    65→}\n    66→\n    67→/**\n    68→ * Fetch all quizzes.\n    69→ * @returns {Promise<{success: boolean, quizzes?: Quiz[], error?: string}>}\n    70→ */\n    71→export async function fetchAllQuizzes() {\n    72→  try {\n    73→    const ref = collection(db, QUIZZES);\n    74→    const q = query(ref, orderBy('createdAt', 'desc'));\n    75→    const snapshot = await getDocs(q);\n    76→    const quizzes = snapshot.docs.map((d) => ({ id: d.id, ...d.data() }));\n    77→    return { success: true, quizzes };\n    78→  } catch (err) {\n    79→    return { success: false, error: 'Error al cargar quizzes' };\n    80→  }\n    81→}\n    82→\n    83→/**\n    84→ * Fetch a single quiz.\n    85→ * @param {string} id\n    86→ * @returns {Promise<{success: boolean, quiz?: Quiz, error?: string}>}\n    87→ */\n    88→export async function fetchQuiz(id) {\n    89→  if (!id) return { success: false, error: 'ID es obligatorio' };\n    90→\n    91→  try {\n    92→    const snap = await getDoc(doc(db, QUIZZES, id));\n    93→    if (!snap.exists()) return { success: false, error: 'Quiz no encontrado' };\n    94→    return { success: true, quiz: { id: snap.id, ...snap.data() } };\n    95→  } catch (err) {\n    96→    return { success: false, error: 'Error al cargar el quiz' };\n    97→  }\n    98→}\n    99→\n   100→/**\n   101→ * Create a new quiz.\n   102→ * @param {Omit<Quiz, 'id'>} data\n   103→ * @returns {Promise<{success: boolean, id?: string, error?: string}>}\n   104→ */\n   105→export async function createQuiz(data) {\n   106→  const validation = validateQuiz(data);\n   107→  if (!validation.valid) return { success: false, error: validation.error };\n   108→\n   109→  try {\n   110→    const ref = await addDoc(collection(db, QUIZZES), {\n   111→      title: data.title.trim(),\n   112→      moduleId: data.moduleId,\n   113→      lessonId: data.lessonId || '',\n   114→      questions: data.questions,\n   115→      createdAt: serverTimestamp(),\n   116→    });\n   117→    return { success: true, id: ref.id };\n   118→  } catch (err) {\n   119→    return { success: false, error: 'Error al crear el quiz' };\n   120→  }\n   121→}\n   122→\n   123→/**\n   124→ * Update a quiz.\n   125→ * @param {string} id\n   126→ * @param {Partial<Quiz>} updates\n   127→ * @returns {Promise<{success: boolean, error?: string}>}\n   128→ */\n   129→export async function updateQuiz(id, updates) {\n   130→  if (!id) return { success: false, error: 'ID es obligatorio' };\n   131→\n   132→  try {\n   133→    await updateDoc(doc(db, QUIZZES, id), updates);\n   134→    return { success: true };\n   135→  } catch (err) {\n   136→    return { success: false, error: 'Error al actualizar el quiz' };\n   137→  }\n   138→}\n   139→\n   140→/**\n   141→ * Delete a quiz.\n   142→ * @param {string} id\n   143→ * @returns {Promise<{success: boolean, error?: string}>}\n   144→ */\n   145→export async function deleteQuiz(id) {\n   146→  if (!id) return { success: false, error: 'ID es obligatorio' };\n   147→\n   148→  try {\n   149→    await deleteDoc(doc(db, QUIZZES, id));\n   150→    return { success: true };\n   151→  } catch (err) {\n   152→    return { success: false, error: 'Error al eliminar el quiz' };\n   153→  }\n   154→}\n   155→\n   156→/* ── Quiz Responses ─────────────────────────────────────────── */\n   157→\n   158→/**\n   159→ * Submit a quiz response.\n   160→ * @param {string} userId\n   161→ * @param {string} quizId\n   162→ * @param {string[]} answers\n   163→ * @returns {Promise<{success: boolean, id?: string, error?: string}>}\n   164→ */\n   165→export async function submitQuizResponse(userId, quizId, answers) {\n   166→  if (!userId) return { success: false, error: 'userId es obligatorio' };\n   167→  if (!quizId) return { success: false, error: 'quizId es obligatorio' };\n   168→  if (!answers || answers.length === 0) return { success: false, error: 'Las respuestas son obligatorias' };\n   169→\n   170→  try {\n   171→    const ref = await addDoc(collection(db, RESPONSES), {\n   172→      userId,\n   173→      quizId,\n   174→      answers,\n   175→      completedAt: serverTimestamp(),\n   176→    });\n   177→    return { success: true, id: ref.id };\n   178→  } catch (err) {\n   179→    return { success: false, error: 'Error al enviar las respuestas' };\n   180→  }\n   181→}\n   182→\n   183→/**\n   184→ * Get a user's response to a quiz.\n   185→ * @param {string} userId\n   186→ * @param {string} quizId\n   187→ * @returns {Promise<{success: boolean, response?: Object|null, error?: string}>}\n   188→ */\n   189→export async function getUserQuizResponse(userId, quizId) {\n   190→  if (!userId || !quizId) return { success: false, error: 'userId y quizId son obligatorios' };\n   191→\n   192→  try {\n   193→    const ref = collection(db, RESPONSES);\n   194→    const q = query(ref, where('userId', '==', userId), where('quizId', '==', quizId));\n   195→    const snapshot = await getDocs(q);\n   196→\n   197→    if (snapshot.docs.length === 0) return { success: true, response: null };\n   198→    return { success: true, response: { id: snapshot.docs[0].id, ...snapshot.docs[0].data() } };\n   199→  } catch (err) {\n   200→    return { success: false, error: 'Error al cargar la respuesta' };\n   201→  }\n   202→}\n   203→\n   204→/**\n   205→ * Get all responses for a quiz (admin).\n   206→ * @param {string} quizId\n   207→ * @returns {Promise<{success: boolean, responses?: Object[], error?: string}>}\n   208→ */\n   209→export async function getQuizResponses(quizId) {\n   210→  if (!quizId) return { success: false, error: 'quizId es obligatorio' };\n   211→\n   212→  try {\n   213→    const ref = collection(db, RESPONSES);\n   214→    const q = query(ref, where('quizId', '==', quizId));\n   215→    const snapshot = await getDocs(q);\n   216→\n   217→    const responses = snapshot.docs.map((d) => ({ id: d.id, ...d.data() }));\n   218→    return { success: true, responses };\n   219→  } catch (err) {\n   220→    return { success: false, error: 'Error al cargar las respuestas' };\n   221→  }\n   222→}\n   223→\n   224→/**\n   225→ * @typedef {Object} QuizResultDetail\n   226→ * @property {string} responseId\n   227→ * @property {string} quizId\n   228→ * @property {string} quizTitle\n   229→ * @property {QuizQuestion[]} questions\n   230→ * @property {string[]} userAnswers\n   231→ * @property {*} completedAt\n   232→ */\n   233→\n   234→/**\n   235→ * Get all quiz results for a user, including quiz details.\n   236→ * @param {string} userId\n   237→ * @returns {Promise<{success: boolean, results?: QuizResultDetail[], error?: string}>}\n   238→ */\n   239→export async function getUserQuizResults(userId) {\n   240→  if (!userId) return { success: false, error: 'userId es obligatorio' };\n   241→\n   242→  try {\n   243→    const ref = collection(db, RESPONSES);\n   244→    const q = query(ref, where('userId', '==', userId));\n   245→    const snapshot = await getDocs(q);\n   246→\n   247→    if (snapshot.docs.length === 0) {\n   248→      return { success: true, results: [] };\n   249→    }\n   250→\n   251→    const results = [];\n   252→    for (const responseDoc of snapshot.docs) {\n   253→      const responseData = responseDoc.data();\n   254→      const quizSnap = await getDoc(doc(db, QUIZZES, responseData.quizId));\n   255→\n   256→      if (quizSnap.exists()) {\n   257→        const quizData = quizSnap.data();\n   258→        results.push({\n   259→          responseId: responseDoc.id,\n   260→          quizId: responseData.quizId,\n   261→          quizTitle: quizData.title,\n   262→          questions: quizData.questions || [],\n   263→          userAnswers: responseData.answers || [],\n   264→          completedAt: responseData.completedAt,\n   265→        });\n   266→      }\n   267→    }\n   268→\n   269→    return { success: true, results };\n   270→  } catch (err) {\n   271→    return { success: false, error: 'Error al cargar los resultados de quizzes' };\n   272→  }\n   273→}\n   274→"}]},"parent_tool_use_id":null,"session_id":"9154919e-bd9a-4b77-8ff1-a9fd5df9d7fe","uuid":"237ab0d8-161a-4092-9e30-29e6006f6ac0","tool_use_result":{"type":"text","file":{"filePath":"/home/manu/ws_firebase/manuelearning/src/lib/firebase/quizzes.js","content":"import {\n  collection,\n  doc,\n  getDoc,\n  getDocs,\n  addDoc,\n  updateDoc,\n  deleteDoc,\n  query,\n  where,\n  orderBy,\n  serverTimestamp,\n} from 'firebase/firestore';\nimport { db } from './config.js';\n\nconst QUIZZES = 'quizzes';\nconst RESPONSES = 'quizResponses';\n\n/**\n * @typedef {Object} QuizQuestion\n * @property {string} text\n * @property {'open'|'multiple'} type\n * @property {string[]} [options]\n * @property {string} [correctAnswer]\n */\n\n/**\n * @typedef {Object} Quiz\n * @property {string} [id]\n * @property {string} title\n * @property {string} moduleId\n * @property {string} lessonId\n * @property {QuizQuestion[]} questions\n * @property {*} [createdAt]\n */\n\n/**\n * Validate quiz data.\n * @param {Partial<Quiz>} data\n * @returns {{ valid: boolean, error?: string }}\n */\nexport function validateQuiz(data) {\n  if (!data.title || data.title.trim().length === 0) {\n    return { valid: false, error: 'El título es obligatorio' };\n  }\n\n  if (!data.moduleId) {\n    return { valid: false, error: 'El módulo es obligatorio' };\n  }\n\n  if (!data.questions || data.questions.length === 0) {\n    return { valid: false, error: 'Debe tener al menos una pregunta' };\n  }\n\n  for (const q of data.questions) {\n    if (!q.text || q.text.trim().length === 0) {\n      return { valid: false, error: 'Todas las preguntas deben tener texto' };\n    }\n    if (q.type === 'multiple' && (!q.options || q.options.length === 0)) {\n      return { valid: false, error: 'Las preguntas de selección múltiple necesitan opciones' };\n    }\n  }\n\n  return { valid: true };\n}\n\n/**\n * Fetch all quizzes.\n * @returns {Promise<{success: boolean, quizzes?: Quiz[], error?: string}>}\n */\nexport async function fetchAllQuizzes() {\n  try {\n    const ref = collection(db, QUIZZES);\n    const q = query(ref, orderBy('createdAt', 'desc'));\n    const snapshot = await getDocs(q);\n    const quizzes = snapshot.docs.map((d) => ({ id: d.id, ...d.data() }));\n    return { success: true, quizzes };\n  } catch (err) {\n    return { success: false, error: 'Error al cargar quizzes' };\n  }\n}\n\n/**\n * Fetch a single quiz.\n * @param {string} id\n * @returns {Promise<{success: boolean, quiz?: Quiz, error?: string}>}\n */\nexport async function fetchQuiz(id) {\n  if (!id) return { success: false, error: 'ID es obligatorio' };\n\n  try {\n    const snap = await getDoc(doc(db, QUIZZES, id));\n    if (!snap.exists()) return { success: false, error: 'Quiz no encontrado' };\n    return { success: true, quiz: { id: snap.id, ...snap.data() } };\n  } catch (err) {\n    return { success: false, error: 'Error al cargar el quiz' };\n  }\n}\n\n/**\n * Create a new quiz.\n * @param {Omit<Quiz, 'id'>} data\n * @returns {Promise<{success: boolean, id?: string, error?: string}>}\n */\nexport async function createQuiz(data) {\n  const validation = validateQuiz(data);\n  if (!validation.valid) return { success: false, error: validation.error };\n\n  try {\n    const ref = await addDoc(collection(db, QUIZZES), {\n      title: data.title.trim(),\n      moduleId: data.moduleId,\n      lessonId: data.lessonId || '',\n      questions: data.questions,\n      createdAt: serverTimestamp(),\n    });\n    return { success: true, id: ref.id };\n  } catch (err) {\n    return { success: false, error: 'Error al crear el quiz' };\n  }\n}\n\n/**\n * Update a quiz.\n * @param {string} id\n * @param {Partial<Quiz>} updates\n * @returns {Promise<{success: boolean, error?: string}>}\n */\nexport async function updateQuiz(id, updates) {\n  if (!id) return { success: false, error: 'ID es obligatorio' };\n\n  try {\n    await updateDoc(doc(db, QUIZZES, id), updates);\n    return { success: true };\n  } catch (err) {\n    return { success: false, error: 'Error al actualizar el quiz' };\n  }\n}\n\n/**\n * Delete a quiz.\n * @param {string} id\n * @returns {Promise<{success: boolean, error?: string}>}\n */\nexport async function deleteQuiz(id) {\n  if (!id) return { success: false, error: 'ID es obligatorio' };\n\n  try {\n    await deleteDoc(doc(db, QUIZZES, id));\n    return { success: true };\n  } catch (err) {\n    return { success: false, error: 'Error al eliminar el quiz' };\n  }\n}\n\n/* ── Quiz Responses ─────────────────────────────────────────── */\n\n/**\n * Submit a quiz response.\n * @param {string} userId\n * @param {string} quizId\n * @param {string[]} answers\n * @returns {Promise<{success: boolean, id?: string, error?: string}>}\n */\nexport async function submitQuizResponse(userId, quizId, answers) {\n  if (!userId) return { success: false, error: 'userId es obligatorio' };\n  if (!quizId) return { success: false, error: 'quizId es obligatorio' };\n  if (!answers || answers.length === 0) return { success: false, error: 'Las respuestas son obligatorias' };\n\n  try {\n    const ref = await addDoc(collection(db, RESPONSES), {\n      userId,\n      quizId,\n      answers,\n      completedAt: serverTimestamp(),\n    });\n    return { success: true, id: ref.id };\n  } catch (err) {\n    return { success: false, error: 'Error al enviar las respuestas' };\n  }\n}\n\n/**\n * Get a user's response to a quiz.\n * @param {string} userId\n * @param {string} quizId\n * @returns {Promise<{success: boolean, response?: Object|null, error?: string}>}\n */\nexport async function getUserQuizResponse(userId, quizId) {\n  if (!userId || !quizId) return { success: false, error: 'userId y quizId son obligatorios' };\n\n  try {\n    const ref = collection(db, RESPONSES);\n    const q = query(ref, where('userId', '==', userId), where('quizId', '==', quizId));\n    const snapshot = await getDocs(q);\n\n    if (snapshot.docs.length === 0) return { success: true, response: null };\n    return { success: true, response: { id: snapshot.docs[0].id, ...snapshot.docs[0].data() } };\n  } catch (err) {\n    return { success: false, error: 'Error al cargar la respuesta' };\n  }\n}\n\n/**\n * Get all responses for a quiz (admin).\n * @param {string} quizId\n * @returns {Promise<{success: boolean, responses?: Object[], error?: string}>}\n */\nexport async function getQuizResponses(quizId) {\n  if (!quizId) return { success: false, error: 'quizId es obligatorio' };\n\n  try {\n    const ref = collection(db, RESPONSES);\n    const q = query(ref, where('quizId', '==', quizId));\n    const snapshot = await getDocs(q);\n\n    const responses = snapshot.docs.map((d) => ({ id: d.id, ...d.data() }));\n    return { success: true, responses };\n  } catch (err) {\n    return { success: false, error: 'Error al cargar las respuestas' };\n  }\n}\n\n/**\n * @typedef {Object} QuizResultDetail\n * @property {string} responseId\n * @property {string} quizId\n * @property {string} quizTitle\n * @property {QuizQuestion[]} questions\n * @property {string[]} userAnswers\n * @property {*} completedAt\n */\n\n/**\n * Get all quiz results for a user, including quiz details.\n * @param {string} userId\n * @returns {Promise<{success: boolean, results?: QuizResultDetail[], error?: string}>}\n */\nexport async function getUserQuizResults(userId) {\n  if (!userId) return { success: false, error: 'userId es obligatorio' };\n\n  try {\n    const ref = collection(db, RESPONSES);\n    const q = query(ref, where('userId', '==', userId));\n    const snapshot = await getDocs(q);\n\n    if (snapshot.docs.length === 0) {\n      return { success: true, results: [] };\n    }\n\n    const results = [];\n    for (const responseDoc of snapshot.docs) {\n      const responseData = responseDoc.data();\n      const quizSnap = await getDoc(doc(db, QUIZZES, responseData.quizId));\n\n      if (quizSnap.exists()) {\n        const quizData = quizSnap.data();\n        results.push({\n          responseId: responseDoc.id,\n          quizId: responseData.quizId,\n          quizTitle: quizData.title,\n          questions: quizData.questions || [],\n          userAnswers: responseData.answers || [],\n          completedAt: responseData.completedAt,\n        });\n      }\n    }\n\n    return { success: true, results };\n  } catch (err) {\n    return { success: false, error: 'Error al cargar los resultados de quizzes' };\n  }\n}\n","numLines":274,"startLine":1,"totalLines":274}}} (stream=stdout)
