      <p>Completa las lecciones del curso para desbloquear quizzes.</p>\n   271→            </div>\n   272→          `\n   273→        : this._results.map((r) => this._renderQuizCard(r))}\n   274→    `;\n   275→  }\n   276→\n   277→  _renderQuizCard(result) {\n   278→    const isExpanded = this._expandedQuiz === result.responseId;\n   279→\n   280→    return html`\n   281→      <div class=\"quiz-card\">\n   282→        <div\n   283→          class=\"quiz-card__header\"\n   284→          @click=${() => this._toggleQuiz(result.responseId)}\n   285→        >\n   286→          <span class=\"quiz-card__title\">${result.quizTitle}</span>\n   287→          <div class=\"quiz-card__meta\">\n   288→            <span class=\"badge\">Completado</span>\n   289→            <span class=\"quiz-card__date\">${this._formatDate(result.completedAt)}</span>\n   290→            <span class=\"material-symbols-outlined quiz-card__toggle ${isExpanded ? 'quiz-card__toggle--open' : ''}\">\n   291→              expand_more\n   292→            </span>\n   293→          </div>\n   294→        </div>\n   295→\n   296→        ${isExpanded\n   297→          ? html`\n   298→              <div class=\"quiz-detail\">\n   299→                ${result.questions.map((q, i) =>\n   300→                  this._renderQuestionDetail(q, result.userAnswers[i], i + 1),\n   301→                )}\n   302→              </div>\n   303→            `\n   304→          : ''}\n   305→      </div>\n   306→    `;\n   307→  }\n   308→\n   309→  _renderQuestionDetail(question, userAnswer, number) {\n   310→    return html`\n   311→      <div class=\"question-block\">\n   312→        <div class=\"question-label\">Pregunta ${number}</div>\n   313→        <div class=\"question-text\">${question.text}</div>\n   314→\n   315→        ${question.type === 'multiple' && question.options\n   316→          ? html`\n   317→              ${question.options.map(\n   318→                (opt) => html`\n   319→                  <div\n   320→                    class=\"option-item ${opt === userAnswer ? 'option-item--selected' : ''}\"\n   321→                  >\n   322→                    ${opt === userAnswer ? '▸ ' : ''}${opt}\n   323→                  </div>\n   324→                `,\n   325→              )}\n   326→            `\n   327→          : html`\n   328→              <div class=\"answer-row answer--user\">\n   329→                <span class=\"material-symbols-outlined\">edit</span>\n   330→                <span><strong>Tu respuesta:</strong> ${userAnswer || '(sin respuesta)'}</span>\n   331→              </div>\n   332→            `}\n   333→      </div>\n   334→    `;\n   335→  }\n   336→\n   337→  _toggleQuiz(responseId) {\n   338→    this._expandedQuiz = this._expandedQuiz === responseId ? null : responseId;\n   339→  }\n   340→\n   341→  _formatDate(ts) {\n   342→    if (!ts) return '';\n   343→    if (ts.toDate) return ts.toDate().toLocaleDateString('es-ES');\n   344→    if (typeof ts === 'string') return new Date(ts).toLocaleDateString('es-ES');\n   345→    return '';\n   346→  }\n   347→}\n   348→\n   349→customElements.define('quiz-results-view', QuizResultsView);\n   350→"}]},"parent_tool_use_id":"toolu_01PviopKjwtvPxPXj5fcZ46W","session_id":"6dab462c-976e-4fe8-a358-d44adb2c1366","uuid":"2fb9c29e-3e6b-4db1-b752-bfc5f9a81a40"} (stream=stdout)
