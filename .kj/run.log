00:00:58.389 [agent:output] [coder] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LtLtXvNDBr275MKrVfdbPE","type":"tool_result","content":"File created successfully at: /home/manu/ws_firebase/manuelearning/src/pages/sobre-manu.astro"}]},"parent_tool_use_id":null,"session_id":"8cf95677-f107-4d4d-8ba2-1a04a28121ac","uuid":"2d6d413a-5cf7-4e6a-b2eb-db23a4e7a7c2","tool_use_result":{"type":"create","filePath":"/home/manu/ws_firebase/manuelearning/src/pages/sobre-manu.astro","content":"---\nimport MainLayout from '../layouts/MainLayout.astro';\nimport { SITE } from '../config/site.config.js';\n---\n\n<MainLayout title={`Sobre Mánu | ${SITE.name}`}>\n  <section class=\"about-page\">\n    <div class=\"about-header\">\n      <h2 class=\"section-label\">Sobre Mánu</h2>\n      <h1 class=\"about-title\">Desarrollador, formador y apasionado de la web</h1>\n      <div class=\"section-divider\"></div>\n    </div>\n\n    <div class=\"about-content\">\n      <div class=\"about-intro\">\n        <div class=\"about-avatar\">\n          <span class=\"material-symbols-outlined\">person</span>\n        </div>\n        <div class=\"about-text\">\n          <p>\n            Soy <strong>Mánu Fosela</strong>, desarrollador web con más de 25 años de experiencia construyendo software, liderando equipos técnicos y mentorizando a personas que empiezan en este mundo.\n          </p>\n          <p>\n            He trabajado en proyectos de todo tipo: desde startups hasta grandes empresas, pasando por proyectos open source y formación técnica. Me apasiona la web, los estándares abiertos y enseñar lo que sé de forma directa y sin rodeos.\n          </p>\n        </div>\n      </div>\n\n      <div class=\"about-cards\">\n        <article class=\"about-card\">\n          <span class=\"material-symbols-outlined about-card__icon\">code</span>\n          <h3>Desarrollador</h3>\n          <p>JavaScript, Web Components, Node.js, Firebase, Docker, Astro, Lit... Trabajo con tecnologías modernas y llevo décadas en el ecosistema web.</p>\n        </article>\n        <article class=\"about-card\">\n          <span class=\"material-symbols-outlined about-card__icon\">school</span>\n          <h3>Formador</h3>\n          <p>He dado formación en empresas, universidades y de forma personal. Me gusta enseñar con proyectos reales, no con ejemplos de juguete.</p>\n        </article>\n        <article class=\"about-card\">\n          <span class=\"material-symbols-outlined about-card__icon\">groups</span>\n          <h3>Mentor</h3>\n          <p>Más de 15 años ayudando a desarrolladores junior a crecer. Creo en el aprendizaje cercano, con contexto y feedback directo.</p>\n        </article>\n      </div>\n\n      <div class=\"about-philosophy\">\n        <h2>Mi filosofía</h2>\n        <p>\n          Creo que la mejor forma de aprender es haciendo, con alguien al lado que ya haya pasado por ahí. Esta plataforma nace de esa idea: compartir lo que sé con personas que conozco, en un formato cercano y práctico.\n        </p>\n        <p>\n          No encontrarás aquí cursos genéricos ni vídeos de relleno. Cada lección está pensada para que aprendas algo útil, aplicable y real.\n        </p>\n      </div>\n\n      <div class=\"about-cta\">\n        <a href=\"/solicitar-acceso\" class=\"btn btn--primary btn--lg\">Solicitar acceso a la plataforma</a>\n      </div>\n    </div>\n  </section>\n</MainLayout>\n\n<style>\n  .about-page {\n    padding: var(--section-py) var(--section-px);\n    max-width: var(--container-max);\n    margin-inline: auto;\n  }\n\n  .about-header {\n    text-align: center;\n    margin-bottom: 4rem;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 1rem;\n  }\n\n  .about-title {\n    font-size: clamp(2rem, 5vw, 3rem);\n    font-weight: 900;\n    line-height: 1.15;\n    color: var(--color-text-primary);\n    max-width: 700px;\n  }\n\n  .about-content {\n    display: flex;\n    flex-direction: column;\n    gap: 4rem;\n  }\n\n  .about-intro {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 2rem;\n  }\n\n  @media (min-width: 768px) {\n    .about-intro {\n      flex-direction: row;\n      align-items: flex-start;\n    }\n  }\n\n  .about-avatar {\n    width: 8rem;\n    height: 8rem;\n    border-radius: var(--radius-full);\n    background: var(--gradient-primary);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n\n  .about-avatar span {\n    font-size: 4rem;\n    color: #0f172a;\n  }\n\n  .about-text {\n    display: flex;\n    flex-direction: column;\n    gap: 1rem;\n  }\n\n  .about-text p {\n    font-size: 1.125rem;\n    color: var(--color-text-secondary);\n    line-height: 1.7;\n  }\n\n  .about-cards {\n    display: grid;\n    grid-template-columns: 1fr;\n    gap: 2rem;\n  }\n\n  @media (min-width: 768px) {\n    .about-cards {\n      grid-template-columns: repeat(3, 1fr);\n    }\n  }\n\n  .about-card {\n    display: flex;\n    flex-direction: column;\n    gap: 1rem;\n    padding: 2rem;\n    border-radius: var(--radius-xl);\n    border: 2px solid var(--color-border);\n    background-color: var(--color-bg-white);\n    transition: all var(--transition-base);\n  }\n\n  .about-card:hover {\n    box-shadow: var(--shadow-2xl);\n    border-color: var(--color-primary);\n  }\n\n  .about-card__icon {\n    font-size: 2rem;\n    color: var(--color-secondary);\n  }\n\n  .about-card h3 {\n    font-size: 1.25rem;\n    font-weight: 700;\n    color: var(--color-text-primary);\n  }\n\n  .about-card p {\n    color: var(--color-text-secondary);\n    line-height: 1.7;\n  }\n\n  .about-philosophy {\n    background-color: var(--color-bg-slate-50);\n    padding: 2.5rem;\n    border-radius: var(--radius-2xl);\n  }\n\n  .about-philosophy h2 {\n    font-size: 1.5rem;\n    font-weight: 900;\n    color: var(--color-text-primary);\n    margin-bottom: 1.5rem;\n  }\n\n  .about-philosophy p {\n    font-size: 1.063rem;\n    color: var(--color-text-secondary);\n    line-height: 1.7;\n    margin-bottom: 1rem;\n  }\n\n  .about-philosophy p:last-child {\n    margin-bottom: 0;\n  }\n\n  .about-cta {\n    text-align: center;\n  }\n</style>\n","structuredPatch":[],"originalFile":null}} (stream=stdout)
